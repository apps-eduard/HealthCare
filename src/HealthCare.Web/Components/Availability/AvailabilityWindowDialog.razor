@namespace HealthCare.Web.Components.Availability
@inherits FeedbackComponent<AvailabilityWindowDialog.Args>
@using HealthCare.Contracts.Appointments
@using HealthCare.Web.Availability

<div style="display:flex;flex-direction:column;gap:12px;">
    <div>
        <label>@FieldLabel.Mark("Day of week")</label>
        <Select TItemValue="string"
                TItem="string"
                @bind-Value="_day"
                Disabled="@(_busy || IsEdit)"
                Style="width:100%;">
            <SelectOptions>
                @foreach (var day in AvailabilityPresentation.DaysOfWeekOrdered)
                {
                    <SelectOption TItemValue="string" TItem="string" Value="@day" Label="@day" />
                }
            </SelectOptions>
        </Select>
    </div>
    <div>
        <label>@FieldLabel.Mark("Start (clinic local HH:mm)")</label>
        <Input @bind-Value="_start" Disabled="_busy" Style="width:100%;" />
    </div>
    <div>
        <label>@FieldLabel.Mark("End (clinic local HH:mm)")</label>
        <Input @bind-Value="_end" Disabled="_busy" Style="width:100%;" />
    </div>
    <div>
        <label>Slot duration (minutes)</label>
        <AntDesign.InputNumber TValue="int"
                               @bind-Value="_duration"
                               Disabled="_busy"
                               Style="width:100%;"
                               Min="10"
                               Max="240" />
    </div>
    <div>
        <label>Effective from</label>
        <DatePicker TValue="DateTime?" @bind-Value="_effectiveFrom" Disabled="_busy" Style="width:100%;" />
    </div>
    <div>
        <label>Effective to (optional)</label>
        <DatePicker TValue="DateTime?" @bind-Value="_effectiveTo" Disabled="_busy" Style="width:100%;" />
    </div>
    @if (IsEdit)
    {
        <div style="display:flex;align-items:center;gap:8px;">
            <Switch @bind-Checked="_isActive" Disabled="_busy" />
            <span>Active</span>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <Alert Type="@AlertType.Error" Message="@_error" ShowIcon="true" />
    }
</div>
<div style="display:flex;gap:8px;justify-content:flex-end;margin-top:1rem;">
    <Button OnClick="CancelCloseAsync" Disabled="_busy">Cancel</Button>
    <Button Type="@ButtonType.Primary" OnClick="SubmitAsync" Loading="_busy" Disabled="_busy || !ClientValid">
        @(IsEdit ? "Save" : "Create")
    </Button>
</div>

@code {
    public sealed class Args
    {
        public Guid DoctorStaffMemberId { get; init; }
        public bool PlatformAdminBypass { get; init; }
        public DoctorAvailabilityResponse? Existing { get; init; }
    }

    [Inject] private IDoctorAvailabilityApiClient Api { get; set; } = default!;
    [Inject] private IUserNotificationService Notify { get; set; } = default!;
    [Inject] private IUiModalService Modals { get; set; } = default!;

    private bool IsEdit => Options.Existing is not null;
    private string _day = "Monday";
    private string _start = "09:00";
    private string _end = "12:00";
    private int _duration = 30;
    private DateTime? _effectiveFrom = DateTime.Today;
    private DateTime? _effectiveTo;
    private bool _isActive = true;
    private bool _busy;
    private string? _error;

    private bool ClientValid =>
        !string.IsNullOrWhiteSpace(_day)
        && AvailabilityPresentation.IsValidWindow(_start, _end)
        && AvailabilityPresentation.IsValidDuration(_duration)
        && _effectiveFrom is not null
        && (_effectiveTo is null || DateOnly.FromDateTime(_effectiveTo.Value) >= DateOnly.FromDateTime(_effectiveFrom.Value));

    protected override void OnInitialized()
    {
        if (Options.Existing is null)
        {
            return;
        }

        _day = Options.Existing.DayOfWeek;
        _start = Options.Existing.StartLocalTime;
        _end = Options.Existing.EndLocalTime;
        _duration = Options.Existing.SlotDurationMinutes;
        _effectiveFrom = Options.Existing.EffectiveFrom.ToDateTime(TimeOnly.MinValue);
        _effectiveTo = Options.Existing.EffectiveTo?.ToDateTime(TimeOnly.MinValue);
        _isActive = Options.Existing.IsActive;
    }

    private Task CancelCloseAsync() => OkCancelRef!.CancelAsync(new ModalClosingEventArgs());

    private Task ConfirmOkAsync() => OkCancelRef!.OkAsync(new ModalClosingEventArgs());

    private async Task SubmitAsync()
    {
        if (!ClientValid || _busy || _effectiveFrom is null)
        {
            _error = "Check day, times, duration (10–240), and effective dates.";
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            if (IsEdit && Options.Existing is not null)
            {
                await Api.UpdateAvailabilityAsync(
                    Options.DoctorStaffMemberId,
                    Options.Existing.Id,
                    new UpdateDoctorAvailabilityRequest
                    {
                        ExpectedVersion = Options.Existing.Version,
                        StartLocalTime = _start.Trim(),
                        EndLocalTime = _end.Trim(),
                        SlotDurationMinutes = _duration,
                        EffectiveFrom = DateOnly.FromDateTime(_effectiveFrom.Value),
                        EffectiveTo = _effectiveTo is DateTime to ? DateOnly.FromDateTime(to) : null,
                        ClearEffectiveTo = _effectiveTo is null,
                        IsActive = _isActive,
                    },
                    Options.PlatformAdminBypass);
                Notify.Success("Availability updated.");
                await ConfirmOkAsync();
            }
            else
            {
                await Api.CreateAvailabilityAsync(
                    Options.DoctorStaffMemberId,
                    new CreateDoctorAvailabilityRequest
                    {
                        DayOfWeek = _day,
                        StartLocalTime = _start.Trim(),
                        EndLocalTime = _end.Trim(),
                        SlotDurationMinutes = _duration,
                        EffectiveFrom = DateOnly.FromDateTime(_effectiveFrom.Value),
                        EffectiveTo = _effectiveTo is DateTime to ? DateOnly.FromDateTime(to) : null,
                    },
                    Options.PlatformAdminBypass);
                Notify.Success("Availability created.");
                await ConfirmOkAsync();
            }
        }
        catch (ApiProblemException ex) when (AvailabilityProblemMessages.IsConcurrencyConflict(ex))
        {
            var confirmed = await Modals.ConfirmAsync(
                "Record changed",
                "This availability was updated elsewhere. Close and reload?");
            _error = AvailabilityProblemMessages.ToUserMessage(ex);
            if (confirmed)
            {
                await ConfirmOkAsync();
            }
        }
        catch (ApiProblemException ex)
        {
            _error = AvailabilityProblemMessages.ToUserMessage(ex);
            Notify.Error(_error);
        }
        finally
        {
            _busy = false;
        }
    }
}
