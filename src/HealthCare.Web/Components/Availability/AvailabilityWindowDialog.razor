@namespace HealthCare.Web.Components.Availability
@implements IDialogContentComponent<AvailabilityWindowDialog.Args>
@using HealthCare.Contracts.Appointments
@using HealthCare.Web.Availability

<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
    <FluentSelect TOption="string" @bind-Value="_day" Label="Day of week" Required="true" Disabled="@(_busy || IsEdit)" Style="width:100%;">
        @foreach (var day in AvailabilityPresentation.DaysOfWeekOrdered)
        {
            <FluentOption Value="@day">@day</FluentOption>
        }
    </FluentSelect>
    <FluentTextField @bind-Value="_start" Label="Start (clinic local HH:mm)" Required="true" Disabled="_busy" Style="width:100%;" />
    <FluentTextField @bind-Value="_end" Label="End (clinic local HH:mm)" Required="true" Disabled="_busy" Style="width:100%;" />
    <FluentNumberField @bind-Value="_duration" Label="Slot duration (minutes)" Min="10" Max="240" Disabled="_busy" Style="width:100%;" />
    <FluentDatePicker @bind-Value="_effectiveFrom" Label="Effective from" Disabled="_busy" Style="width:100%;" />
    <FluentDatePicker @bind-Value="_effectiveTo" Label="Effective to (optional)" Disabled="_busy" Style="width:100%;" />
    @if (IsEdit)
    {
        <FluentSwitch @bind-Value="_isActive" Label="Active" Disabled="_busy" />
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false">@_error</FluentMessageBar>
    }
</FluentStack>
<FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Style="margin-top:1rem;justify-content:flex-end;">
    <FluentButton Appearance="Appearance.Outline" OnClick="CancelAsync" Disabled="_busy">Cancel</FluentButton>
    <FluentButton Appearance="Appearance.Accent" OnClick="SubmitAsync" Disabled="_busy || !ClientValid">
        @if (_busy) { <FluentProgressRing Style="width:16px;height:16px;margin-right:0.35rem;" /> }
        @(IsEdit ? "Save" : "Create")
    </FluentButton>
</FluentStack>

@code {
    public sealed class Args
    {
        public Guid DoctorStaffMemberId { get; init; }
        public bool PlatformAdminBypass { get; init; }
        public DoctorAvailabilityResponse? Existing { get; init; }
    }

    [Parameter] public Args Content { get; set; } = default!;
    [CascadingParameter] private FluentDialog Dialog { get; set; } = default!;
    [Inject] private IDoctorAvailabilityApiClient Api { get; set; } = default!;
    [Inject] private IUserNotificationService Notify { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;

    private bool IsEdit => Content.Existing is not null;
    private string _day = "Monday";
    private string _start = "09:00";
    private string _end = "12:00";
    private int _duration = 30;
    private DateTime? _effectiveFrom = DateTime.Today;
    private DateTime? _effectiveTo;
    private bool _isActive = true;
    private bool _busy;
    private string? _error;

    private bool ClientValid =>
        !string.IsNullOrWhiteSpace(_day)
        && AvailabilityPresentation.IsValidWindow(_start, _end)
        && AvailabilityPresentation.IsValidDuration(_duration)
        && _effectiveFrom is not null
        && (_effectiveTo is null || DateOnly.FromDateTime(_effectiveTo.Value) >= DateOnly.FromDateTime(_effectiveFrom.Value));

    protected override void OnInitialized()
    {
        if (Content.Existing is null)
        {
            return;
        }

        _day = Content.Existing.DayOfWeek;
        _start = Content.Existing.StartLocalTime;
        _end = Content.Existing.EndLocalTime;
        _duration = Content.Existing.SlotDurationMinutes;
        _effectiveFrom = Content.Existing.EffectiveFrom.ToDateTime(TimeOnly.MinValue);
        _effectiveTo = Content.Existing.EffectiveTo?.ToDateTime(TimeOnly.MinValue);
        _isActive = Content.Existing.IsActive;
    }

    private async Task CancelAsync() => await Dialog.CancelAsync();

    private async Task SubmitAsync()
    {
        if (!ClientValid || _busy || _effectiveFrom is null)
        {
            _error = "Check day, times, duration (10–240), and effective dates.";
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            if (IsEdit && Content.Existing is not null)
            {
                var updated = await Api.UpdateAvailabilityAsync(
                    Content.DoctorStaffMemberId,
                    Content.Existing.Id,
                    new UpdateDoctorAvailabilityRequest
                    {
                        ExpectedVersion = Content.Existing.Version,
                        StartLocalTime = _start.Trim(),
                        EndLocalTime = _end.Trim(),
                        SlotDurationMinutes = _duration,
                        EffectiveFrom = DateOnly.FromDateTime(_effectiveFrom.Value),
                        EffectiveTo = _effectiveTo is DateTime to ? DateOnly.FromDateTime(to) : null,
                        ClearEffectiveTo = _effectiveTo is null,
                        IsActive = _isActive,
                    },
                    Content.PlatformAdminBypass);
                Notify.Success("Availability updated.");
                await Dialog.CloseAsync(DialogResult.Ok(updated));
            }
            else
            {
                var created = await Api.CreateAvailabilityAsync(
                    Content.DoctorStaffMemberId,
                    new CreateDoctorAvailabilityRequest
                    {
                        DayOfWeek = _day,
                        StartLocalTime = _start.Trim(),
                        EndLocalTime = _end.Trim(),
                        SlotDurationMinutes = _duration,
                        EffectiveFrom = DateOnly.FromDateTime(_effectiveFrom.Value),
                        EffectiveTo = _effectiveTo is DateTime to ? DateOnly.FromDateTime(to) : null,
                    },
                    Content.PlatformAdminBypass);
                Notify.Success("Availability created.");
                await Dialog.CloseAsync(DialogResult.Ok(created));
            }
        }
        catch (ApiProblemException ex) when (AvailabilityProblemMessages.IsConcurrencyConflict(ex))
        {
            var confirm = await DialogService.ShowConfirmationAsync(
                "This availability was updated elsewhere. Close and reload?",
                "Record changed",
                "OK",
                "Stay");
            var result = await confirm.Result;
            _error = AvailabilityProblemMessages.ToUserMessage(ex);
            if (!result.Cancelled)
            {
                await Dialog.CloseAsync(DialogResult.Ok(false));
            }
        }
        catch (ApiProblemException ex)
        {
            _error = AvailabilityProblemMessages.ToUserMessage(ex);
            Notify.Error(_error);
        }
        finally
        {
            _busy = false;
        }
    }
}
