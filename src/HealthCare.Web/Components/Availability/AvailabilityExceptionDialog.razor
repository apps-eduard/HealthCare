@namespace HealthCare.Web.Components.Availability
@implements IDialogContentComponent<AvailabilityExceptionDialog.Args>
@using HealthCare.Contracts.Appointments
@using HealthCare.Web.Availability

<FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
    <FluentSelect TOption="string" Value="_type" ValueChanged="OnTypeChanged" Label="Exception type" Required="true" Disabled="_busy" Style="width:100%;">
        @foreach (var type in AvailabilityPresentation.ExceptionTypes)
        {
            <FluentOption Value="@type">@AvailabilityPresentation.ExceptionTypeLabel(type)</FluentOption>
        }
    </FluentSelect>
    <FluentDatePicker @bind-Value="_date" Label="Date (clinic local)" Disabled="_busy" Style="width:100%;" />
    @if (AvailabilityPresentation.ExceptionRequiresTimes(_type))
    {
        <FluentTextField @bind-Value="_start" Label="Start (HH:mm)" Required="true" Disabled="_busy" Style="width:100%;" />
        <FluentTextField @bind-Value="_end" Label="End (HH:mm)" Required="true" Disabled="_busy" Style="width:100%;" />
    }
    <FluentTextField @bind-Value="_reason" Label="Reason (optional)" Disabled="_busy" Style="width:100%;" />
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false">@_error</FluentMessageBar>
    }
</FluentStack>
<FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Style="margin-top:1rem;justify-content:flex-end;">
    <FluentButton Appearance="Appearance.Outline" OnClick="CancelAsync" Disabled="_busy">Cancel</FluentButton>
    <FluentButton Appearance="Appearance.Accent" OnClick="SubmitAsync" Disabled="_busy || !ClientValid">
        @if (_busy) { <FluentProgressRing Style="width:16px;height:16px;margin-right:0.35rem;" /> }
        Create
    </FluentButton>
</FluentStack>

@code {
    public sealed class Args
    {
        public Guid DoctorStaffMemberId { get; init; }
        public bool PlatformAdminBypass { get; init; }
    }

    [Parameter] public Args Content { get; set; } = default!;
    [CascadingParameter] private FluentDialog Dialog { get; set; } = default!;
    [Inject] private IDoctorAvailabilityApiClient Api { get; set; } = default!;
    [Inject] private IUserNotificationService Notify { get; set; } = default!;

    private string _type = "UnavailableFullDay";
    private DateTime? _date = DateTime.Today;
    private string? _start = "09:00";
    private string? _end = "12:00";
    private string? _reason;
    private bool _busy;
    private string? _error;

    private bool ClientValid
    {
        get
        {
            if (_date is null || string.IsNullOrWhiteSpace(_type))
            {
                return false;
            }

            if (!AvailabilityPresentation.ExceptionRequiresTimes(_type))
            {
                return true;
            }

            return AvailabilityPresentation.IsValidWindow(_start, _end);
        }
    }

    private Task OnTypeChanged(string value)
    {
        _type = value;
        if (!AvailabilityPresentation.ExceptionRequiresTimes(value))
        {
            _start = null;
            _end = null;
        }
        else
        {
            _start ??= "09:00";
            _end ??= "12:00";
        }

        return Task.CompletedTask;
    }

    private async Task CancelAsync() => await Dialog.CancelAsync();

    private async Task SubmitAsync()
    {
        if (!ClientValid || _busy || _date is null)
        {
            _error = "Check exception type, date, and time fields.";
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var requiresTimes = AvailabilityPresentation.ExceptionRequiresTimes(_type);
            var created = await Api.CreateExceptionAsync(
                Content.DoctorStaffMemberId,
                new CreateDoctorAvailabilityExceptionRequest
                {
                    Date = DateOnly.FromDateTime(_date.Value),
                    ExceptionType = _type,
                    StartLocalTime = requiresTimes ? _start?.Trim() : null,
                    EndLocalTime = requiresTimes ? _end?.Trim() : null,
                    Reason = string.IsNullOrWhiteSpace(_reason) ? null : _reason.Trim(),
                },
                Content.PlatformAdminBypass);
            Notify.Success("Exception created.");
            await Dialog.CloseAsync(DialogResult.Ok(created));
        }
        catch (ApiProblemException ex)
        {
            _error = AvailabilityProblemMessages.ToUserMessage(ex);
            Notify.Error(_error);
        }
        finally
        {
            _busy = false;
        }
    }
}
