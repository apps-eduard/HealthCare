@namespace HealthCare.Web.Components.Availability
@inherits FeedbackComponent<AvailabilityExceptionDialog.Args>
@using HealthCare.Contracts.Appointments
@using HealthCare.Web.Availability

<div style="display:flex;flex-direction:column;gap:12px;">
    <div>
        <label>@FieldLabel.Mark("Exception type")</label>
        <Select TItemValue="string"
                TItem="string"
                Value="_type"
                ValueChanged="OnTypeChanged"
                Disabled="_busy"
                Style="width:100%;">
            <SelectOptions>
                @foreach (var type in AvailabilityPresentation.ExceptionTypes)
                {
                    <SelectOption TItemValue="string"
                                  TItem="string"
                                  Value="@type"
                                  Label="@AvailabilityPresentation.ExceptionTypeLabel(type)" />
                }
            </SelectOptions>
        </Select>
    </div>
    <div>
        <label>Date (clinic local)</label>
        <DatePicker TValue="DateTime?" @bind-Value="_date" Disabled="_busy" Style="width:100%;" />
    </div>
    @if (AvailabilityPresentation.ExceptionRequiresTimes(_type))
    {
        <div>
            <label>@FieldLabel.Mark("Start (HH:mm)")</label>
            <Input @bind-Value="_start" Disabled="_busy" Style="width:100%;" />
        </div>
        <div>
            <label>@FieldLabel.Mark("End (HH:mm)")</label>
            <Input @bind-Value="_end" Disabled="_busy" Style="width:100%;" />
        </div>
    }
    <div>
        <label>Reason (optional)</label>
        <Input @bind-Value="_reason" Disabled="_busy" Style="width:100%;" />
    </div>
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <Alert Type="@AlertType.Error" Message="@_error" ShowIcon="true" />
    }
</div>
<div style="display:flex;gap:8px;justify-content:flex-end;margin-top:1rem;">
    <Button OnClick="CancelCloseAsync" Disabled="_busy">Cancel</Button>
    <Button Type="@ButtonType.Primary" OnClick="SubmitAsync" Loading="_busy" Disabled="_busy || !ClientValid">
        Create
    </Button>
</div>

@code {
    public sealed class Args
    {
        public Guid DoctorStaffMemberId { get; init; }
        public bool PlatformAdminBypass { get; init; }
    }

    [Inject] private IDoctorAvailabilityApiClient Api { get; set; } = default!;
    [Inject] private IUserNotificationService Notify { get; set; } = default!;

    private string _type = "UnavailableFullDay";
    private DateTime? _date = DateTime.Today;
    private string? _start = "09:00";
    private string? _end = "12:00";
    private string? _reason;
    private bool _busy;
    private string? _error;

    private bool ClientValid
    {
        get
        {
            if (_date is null || string.IsNullOrWhiteSpace(_type))
            {
                return false;
            }

            if (!AvailabilityPresentation.ExceptionRequiresTimes(_type))
            {
                return true;
            }

            return AvailabilityPresentation.IsValidWindow(_start, _end);
        }
    }

    private Task OnTypeChanged(string value)
    {
        _type = value;
        if (!AvailabilityPresentation.ExceptionRequiresTimes(value))
        {
            _start = null;
            _end = null;
        }
        else
        {
            _start ??= "09:00";
            _end ??= "12:00";
        }

        return Task.CompletedTask;
    }

    private Task CancelCloseAsync() => OkCancelRef!.CancelAsync(new ModalClosingEventArgs());

    private Task ConfirmOkAsync() => OkCancelRef!.OkAsync(new ModalClosingEventArgs());

    private async Task SubmitAsync()
    {
        if (!ClientValid || _busy || _date is null)
        {
            _error = "Check exception type, date, and time fields.";
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var requiresTimes = AvailabilityPresentation.ExceptionRequiresTimes(_type);
            await Api.CreateExceptionAsync(
                Options.DoctorStaffMemberId,
                new CreateDoctorAvailabilityExceptionRequest
                {
                    Date = DateOnly.FromDateTime(_date.Value),
                    ExceptionType = _type,
                    StartLocalTime = requiresTimes ? _start?.Trim() : null,
                    EndLocalTime = requiresTimes ? _end?.Trim() : null,
                    Reason = string.IsNullOrWhiteSpace(_reason) ? null : _reason.Trim(),
                },
                Options.PlatformAdminBypass);
            Notify.Success("Exception created.");
            await ConfirmOkAsync();
        }
        catch (ApiProblemException ex)
        {
            _error = AvailabilityProblemMessages.ToUserMessage(ex);
            Notify.Error(_error);
        }
        finally
        {
            _busy = false;
        }
    }
}
