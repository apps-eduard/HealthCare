@namespace HealthCare.Web.Components.Patients
@inherits FeedbackComponent<PatientDetailDialog.Args>
@using HealthCare.Contracts.Patients
@using HealthCare.Web.Patients

@if (_loading)
{
    <PageLoading />
}
else if (_patient is null)
{
    <Alert Type="@AlertType.Error"
           Message="@(_error ?? "Patient was not found or you do not have access.")"
           ShowIcon="true" />
}
else
{
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <Alert Type="@AlertType.Error" Message="@_error" ShowIcon="true" Style="margin-bottom:0.75rem;" />
    }

    <div style="display:flex;flex-direction:column;gap:8px;">
        <div><strong>Local number:</strong> @_patient.LocalPatientNumber</div>
        <div><strong>Name:</strong> @PatientDisplay.FullName(_patient)</div>
        <div><strong>Date of birth:</strong> @(_patient.DateOfBirth?.ToString("yyyy-MM-dd") ?? "—")</div>
        <div><strong>Gender:</strong> @(_patient.Gender ?? "—")</div>
        <div><strong>Mobile:</strong> @(_patient.MobileNumber ?? "—")</div>
        <div><strong>Preferred language:</strong> @(_patient.PreferredLanguage ?? "—")</div>
        <div>
            <strong>Patient status:</strong>
            <StatusBadge Text="@PatientStatusPresentation.PatientActiveLabel(_patient.PatientIsActive)"
                         Tone="@PatientStatusPresentation.PatientActiveTone(_patient.PatientIsActive)" />
        </div>
        <div>
            <strong>Clinic enrollment:</strong>
            <StatusBadge Text="@PatientStatusPresentation.ClinicPatientLabel(_patient.ClinicPatientStatus)"
                         Tone="@PatientStatusPresentation.ClinicPatientTone(_patient.ClinicPatientStatus)" />
        </div>
        <div><strong>Clinic:</strong> @(_clinicLabel ?? _patient.ClinicId.ToString("D"))</div>
        <div><strong>Enrolled:</strong> @_patient.RegisteredAtUtc.UtcDateTime.ToString("yyyy-MM-dd HH:mm") UTC</div>
        <div><strong>Version:</strong> @_patient.Version</div>
        @if (!string.IsNullOrWhiteSpace(_patient.Address))
        {
            <div><strong>Address:</strong> @_patient.Address</div>
        }
        @if (!string.IsNullOrWhiteSpace(_patient.EmergencyContact))
        {
            <div><strong>Emergency contact:</strong> @_patient.EmergencyContact</div>
        }
        <div class="hc-caption">Patient ID: @_patient.PatientId</div>
    </div>

    @if (Permissions.Has(WebPermissions.PatientsUpdateClinicStatus))
    {
        <hr style="margin:1rem 0;border:0;border-top:1px solid var(--hc-border);" />
        <div style="font-weight:600;margin-bottom:0.5rem;">Update clinic enrollment status</div>
        <div>
            <label>ClinicPatient status</label>
            <Select TItemValue="string"
                    TItem="string"
                    @bind-Value="_newStatus"
                    Disabled="_busy"
                    Style="width:100%;">
                <SelectOptions>
                    @foreach (var status in PatientStatusPresentation.ClinicPatientStatuses)
                    {
                        <SelectOption TItemValue="string" TItem="string" Value="@status" Label="@status" />
                    }
                </SelectOptions>
            </Select>
        </div>
    }
}
<div style="display:flex;gap:8px;justify-content:flex-end;margin-top:1rem;">
    <Button OnClick="CloseAsync" Disabled="_busy">Close</Button>
    @if (_patient is not null && Permissions.Has(WebPermissions.PatientsUpdateClinicStatus))
    {
        <Button Type="@ButtonType.Primary"
                Disabled="_busy || string.IsNullOrWhiteSpace(_newStatus) || _newStatus == _patient.ClinicPatientStatus"
                Loading="_busy"
                OnClick="ConfirmUpdateAsync">
            Update status
        </Button>
    }
</div>

@code {
    public sealed class Args
    {
        public Guid PatientId { get; init; }
        public bool PlatformAdminBypass { get; init; }
    }

    [Inject] private IStaffPatientApiClient PatientsApi { get; set; } = default!;
    [Inject] private IPermissionState Permissions { get; set; } = default!;
    [Inject] private IClinicDirectoryApiClient ClinicsApi { get; set; } = default!;
    [Inject] private IClinicDirectoryCache ClinicCache { get; set; } = default!;
    [Inject] private IUiModalService Modals { get; set; } = default!;
    [Inject] private IUserNotificationService Notify { get; set; } = default!;

    private Guid PatientId => Options.PatientId;
    private bool PlatformAdminBypass => Options.PlatformAdminBypass;

    private StaffPatientDetailResponse? _patient;
    private string? _clinicLabel;
    private string? _newStatus;
    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private bool _changed;

    protected override async Task OnInitializedAsync()
    {
        if (!Permissions.Has(WebPermissions.PatientsRead))
        {
            _loading = false;
            _error = "You do not have permission to view patient details.";
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _patient = await PatientsApi.GetByIdAsync(PatientId, PlatformAdminBypass);
            _newStatus = _patient.ClinicPatientStatus;
            await ResolveClinicLabelAsync(_patient.ClinicId);
        }
        catch (ApiProblemException ex) when (PatientProblemMessages.IsNotFound(ex))
        {
            _patient = null;
            _error = PatientProblemMessages.ToUserMessage(ex);
        }
        catch (ApiProblemException ex)
        {
            _patient = null;
            _error = PatientProblemMessages.ToUserMessage(ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ResolveClinicLabelAsync(Guid clinicId)
    {
        try
        {
            if (ClinicCache.TryGet(clinicId, out var cached) && cached is not null)
            {
                _clinicLabel = $"{cached.Name} ({cached.Slug})";
                return;
            }

            var detail = await ClinicsApi.GetByIdAsync(clinicId, PlatformAdminBypass);
            ClinicCache.Set(detail);
            _clinicLabel = $"{detail.Name} ({detail.Slug})";
        }
        catch
        {
            _clinicLabel = null;
        }
    }

    private async Task ConfirmUpdateAsync()
    {
        if (_patient is null || _busy || string.IsNullOrWhiteSpace(_newStatus))
        {
            return;
        }

        var confirmed = await Modals.ConfirmAsync(
            "Update clinic enrollment",
            $"Change clinic enrollment status to '{_newStatus}'?");
        if (!confirmed)
        {
            return;
        }

        await SubmitUpdateAsync();
    }

    private async Task SubmitUpdateAsync()
    {
        if (_patient is null || _busy || string.IsNullOrWhiteSpace(_newStatus))
        {
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            _patient = await PatientsApi.UpdateClinicProfileAsync(
                _patient.PatientId,
                new UpdateClinicPatientRequest
                {
                    ExpectedVersion = _patient.Version,
                    Status = _newStatus,
                },
                PlatformAdminBypass);
            _newStatus = _patient.ClinicPatientStatus;
            _changed = true;
            Notify.Success("Clinic enrollment status updated.");
        }
        catch (ApiProblemException ex) when (PatientProblemMessages.IsConcurrencyConflict(ex))
        {
            var reload = await Modals.ConfirmAsync(
                "Record changed",
                "This clinic patient record was updated elsewhere. Reload the latest version?");
            if (reload)
            {
                await LoadAsync();
            }
            else
            {
                _error = PatientProblemMessages.ToUserMessage(ex);
            }
        }
        catch (ApiProblemException ex)
        {
            _error = PatientProblemMessages.ToUserMessage(ex);
            Notify.Error(_error);
        }
        finally
        {
            _busy = false;
        }
    }

    private Task ConfirmOkAsync() => OkCancelRef!.OkAsync(new ModalClosingEventArgs());

    private Task CancelCloseAsync() => OkCancelRef!.CancelAsync(new ModalClosingEventArgs());

    private Task CloseAsync() => _changed ? ConfirmOkAsync() : CancelCloseAsync();
}
