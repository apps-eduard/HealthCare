@namespace HealthCare.Web.Components.Patients
@inherits FeedbackComponent<PatientDetailDialog.Args>
@using HealthCare.Contracts.Patients
@using HealthCare.Web.Patients

@* Legacy modal wrapper — Patients page uses PatientDetailDrawer. Kept for modal hosts. *@

@if (_loading)
{
    <PageLoading />
}
else if (_patient is null)
{
    <Alert Type="@AlertType.Error"
           Message="@(_error ?? "Patient was not found or you do not have access.")"
           ShowIcon="true" />
}
else
{
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <Alert Type="@AlertType.Error" Message="@_error" ShowIcon="true" Style="margin-bottom:0.75rem;" />
    }

    <div style="display:flex;flex-direction:column;gap:8px;">
        <div><strong>Local number:</strong> @_patient.LocalPatientNumber</div>
        <div><strong>Name:</strong> @PatientDisplay.FullName(_patient)</div>
        <div><strong>Mobile:</strong> @(_patient.MobileNumber ?? "—")</div>
        <div>
            <strong>Patient status:</strong>
            <StatusBadge Text="@PatientStatusPresentation.PatientActiveLabel(_patient.PatientIsActive)"
                         Tone="@PatientStatusPresentation.PatientActiveTone(_patient.PatientIsActive)" />
        </div>
        <div style="font-weight:600;margin-top:0.5rem;">Clinic enrollments</div>
        @foreach (var enrollment in _patient.Enrollments)
        {
            <div class="hc-caption">
                @enrollment.LocalPatientNumber · @enrollment.ClinicId.ToString("D")[..8]…
                · @PatientStatusPresentation.ClinicPatientLabel(enrollment.ClinicPatientStatus)
                · v@enrollment.Version
            </div>
        }
        @if (Permissions.Has(WebPermissions.PatientsUpdateClinicStatus) && _selectedEnrollment is not null)
        {
            <hr style="margin:0.75rem 0;border:0;border-top:1px solid var(--hc-border);" />
            <div>
                <label>Enrollment status (@_selectedEnrollment.LocalPatientNumber)</label>
                <Select TItemValue="string" TItem="string" @bind-Value="_newStatus" Disabled="_busy" Style="width:100%;">
                    <SelectOptions>
                        @foreach (var status in PatientStatusPresentation.ClinicPatientStatuses)
                        {
                            <SelectOption TItemValue="string" TItem="string" Value="@status" Label="@status" />
                        }
                    </SelectOptions>
                </Select>
            </div>
        }
    </div>
}
<div style="display:flex;gap:8px;justify-content:flex-end;margin-top:1rem;">
    <Button OnClick="CloseAsync" Disabled="_busy">Close</Button>
    @if (_patient is not null
         && _selectedEnrollment is not null
         && Permissions.Has(WebPermissions.PatientsUpdateClinicStatus)
         && !string.IsNullOrWhiteSpace(_newStatus)
         && _newStatus != _selectedEnrollment.ClinicPatientStatus)
    {
        <Button Type="@ButtonType.Primary" Disabled="_busy" Loading="_busy" OnClick="ConfirmUpdateAsync">
            Update status
        </Button>
    }
</div>

@code {
    public sealed class Args
    {
        public Guid PatientId { get; init; }
        public Guid? PreferredClinicId { get; init; }
        public bool PlatformAdminBypass { get; init; }
    }

    [Inject] private IStaffPatientApiClient PatientsApi { get; set; } = default!;
    [Inject] private IPermissionState Permissions { get; set; } = default!;
    [Inject] private IUiModalService Modals { get; set; } = default!;
    [Inject] private IUserNotificationService Notify { get; set; } = default!;

    private StaffPatientDetailResponse? _patient;
    private StaffPatientClinicEnrollmentResponse? _selectedEnrollment;
    private string? _newStatus;
    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private bool _changed;

    protected override async Task OnInitializedAsync()
    {
        if (!Permissions.Has(WebPermissions.PatientsRead))
        {
            _loading = false;
            _error = "You do not have permission to view patient details.";
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            Guid? clinicId = Options.PlatformAdminBypass ? Options.PreferredClinicId : null;
            _patient = await PatientsApi.GetByIdAsync(Options.PatientId, clinicId, Options.PlatformAdminBypass);
            _selectedEnrollment = _patient.Enrollments
                .FirstOrDefault(e => Options.PreferredClinicId is Guid pref && e.ClinicId == pref)
                ?? _patient.Enrollments.FirstOrDefault(e => e.ClinicId == _patient.ClinicId)
                ?? _patient.Enrollments.FirstOrDefault();
            _newStatus = _selectedEnrollment?.ClinicPatientStatus;
        }
        catch (ApiProblemException ex)
        {
            _patient = null;
            _error = PatientProblemMessages.ToUserMessage(ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ConfirmUpdateAsync()
    {
        if (_patient is null || _selectedEnrollment is null || string.IsNullOrWhiteSpace(_newStatus))
        {
            return;
        }

        if (!await Modals.ConfirmAsync("Update clinic enrollment", $"Change enrollment status to '{_newStatus}'?"))
        {
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            _patient = await PatientsApi.UpdateClinicProfileAsync(
                _patient.PatientId,
                new UpdateClinicPatientRequest
                {
                    ExpectedVersion = _selectedEnrollment.Version,
                    Status = _newStatus,
                    ClinicId = _selectedEnrollment.ClinicId,
                },
                Options.PlatformAdminBypass);
            _selectedEnrollment = _patient.Enrollments
                .FirstOrDefault(e => e.ClinicId == _selectedEnrollment.ClinicId)
                ?? _patient.Enrollments.FirstOrDefault();
            _newStatus = _selectedEnrollment?.ClinicPatientStatus;
            _changed = true;
            Notify.Success("Clinic enrollment status updated.");
        }
        catch (ApiProblemException ex) when (PatientProblemMessages.IsConcurrencyConflict(ex))
        {
            if (await Modals.ConfirmAsync("Record changed", "Reload the latest version?"))
            {
                await LoadAsync();
            }
            else
            {
                _error = PatientProblemMessages.ToUserMessage(ex);
            }
        }
        catch (ApiProblemException ex)
        {
            _error = PatientProblemMessages.ToUserMessage(ex);
        }
        finally
        {
            _busy = false;
        }
    }

    private Task ConfirmOkAsync() => OkCancelRef!.OkAsync(new ModalClosingEventArgs());

    private Task CancelCloseAsync() => OkCancelRef!.CancelAsync(new ModalClosingEventArgs());

    private Task CloseAsync() => _changed ? ConfirmOkAsync() : CancelCloseAsync();
}
