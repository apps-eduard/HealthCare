@namespace HealthCare.Web.Components.Patients
@implements IDisposable
@using HealthCare.Contracts.Patients
@using HealthCare.Web.Patients
@inject IStaffPatientApiClient PatientsApi
@inject IPermissionState Permissions

@if (!Permissions.Has(WebPermissions.PatientsSearch))
{
    <FluentMessageBar Intent="MessageIntent.Warning" AllowDismiss="false">Patient search permission is required.</FluentMessageBar>
}
else
{
    <div class="hc-picker">
        <FluentTextField Value="@_searchText"
                         ValueChanged="OnSearchTextChanged"
                         Label="@Label"
                         Placeholder="Type to search…"
                         Disabled="@Disabled"
                         Required="@Required"
                         Style="width:100%;" />
        @if (_selected is not null)
        {
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center" Style="margin-top:0.35rem;">
                <span class="hc-caption">Selected: @FormatPatient(_selected)</span>
                @if (!Disabled)
                {
                    <FluentButton Appearance="Appearance.Lightweight" OnClick="ClearAsync">Clear</FluentButton>
                }
            </FluentStack>
        }
        @if (_showResults && !Disabled)
        {
            <div class="hc-picker-results" role="listbox">
                @if (_searching)
                {
                    <div class="hc-caption" style="padding:0.5rem 0.75rem;">Searching…</div>
                }
                else if (_results.Count == 0)
                {
                    <div class="hc-caption" style="padding:0.5rem 0.75rem;">No patients matched.</div>
                }
                else
                {
                    @foreach (var item in _results)
                    {
                        <button type="button" class="hc-picker-item" @onclick="(() => SelectAsync(item))">@FormatPatient(item)</button>
                    }
                }
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(HelperText))
        {
            <div class="hc-caption" style="margin-top:0.35rem;">@HelperText</div>
        }
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false" Style="margin-top:0.35rem;">@_error</FluentMessageBar>
        }
    </div>
}

@code {
    [Parameter] public Guid? Value { get; set; }
    [Parameter] public EventCallback<Guid?> ValueChanged { get; set; }
    [Parameter] public EventCallback<StaffPatientSummaryResponse?> SelectedPatientChanged { get; set; }
    [Parameter] public string Label { get; set; } = "Patient";
    [Parameter] public string? HelperText { get; set; } = "Search by name or local patient number";
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public Guid? ClinicId { get; set; }
    [Parameter] public bool PlatformAdminBypass { get; set; }

    private StaffPatientSummaryResponse? _selected;
    private List<StaffPatientSummaryResponse> _results = [];
    private string _searchText = string.Empty;
    private string? _error;
    private bool _showResults;
    private bool _searching;
    private CancellationTokenSource? _searchCts;
    private int _searchVersion;

    protected override void OnParametersSet()
    {
        if (Value is null)
        {
            _selected = null;
        }
        else if (_selected?.PatientId != Value)
        {
            if (_selected is null || _selected.PatientId != Value)
            {
                _selected = null;
            }
        }
    }

    private async Task OnSearchTextChanged(string? value)
    {
        _searchText = value ?? string.Empty;
        _showResults = true;
        await SearchAsync(_searchText);
    }

    private async Task SearchAsync(string? value)
    {
        _error = null;
        if (!Permissions.Has(WebPermissions.PatientsSearch))
        {
            return;
        }

        _searching = true;
        _searchCts?.Cancel();
        _searchCts?.Dispose();
        _searchCts = new CancellationTokenSource();
        var cts = _searchCts;
        var version = Interlocked.Increment(ref _searchVersion);

        try
        {
            var result = await PatientsApi.SearchAsync(
                new StaffPatientSearchRequest
                {
                    Search = string.IsNullOrWhiteSpace(value) ? null : value.Trim(),
                    ClinicId = ClinicId,
                    ClinicPatientStatus = "Active",
                    PatientIsActive = true,
                    Page = 1,
                    PageSize = 20,
                    SortBy = "lastName",
                    SortDirection = "asc",
                },
                PlatformAdminBypass,
                cts.Token);

            if (version != _searchVersion)
            {
                return;
            }

            _results = result.Items.ToList();
        }
        catch (OperationCanceledException)
        {
        }
        catch (ApiProblemException ex)
        {
            if (version == _searchVersion)
            {
                _error = PatientProblemMessages.ToUserMessage(ex);
                _results = [];
            }
        }
        catch (Exception)
        {
            if (version == _searchVersion)
            {
                _error = "Unable to search patients.";
                _results = [];
            }
        }
        finally
        {
            if (version == _searchVersion)
            {
                _searching = false;
            }
        }
    }

    private async Task SelectAsync(StaffPatientSummaryResponse patient)
    {
        _selected = patient;
        _searchText = FormatPatient(patient);
        _showResults = false;
        await ValueChanged.InvokeAsync(patient.PatientId);
        await SelectedPatientChanged.InvokeAsync(patient);
    }

    private async Task ClearAsync()
    {
        _selected = null;
        _searchText = string.Empty;
        _showResults = false;
        await ValueChanged.InvokeAsync(null);
        await SelectedPatientChanged.InvokeAsync(null);
    }

    private static string FormatPatient(StaffPatientSummaryResponse? p) =>
        p is null ? string.Empty : PatientDisplay.PickerLabel(p);

    public void Dispose()
    {
        _searchCts?.Cancel();
        _searchCts?.Dispose();
    }
}
