@inherits LayoutComponentBase
@implements IDisposable
@inject IPermissionState Permissions
@inject StaffAuthenticationStateProvider AuthState
@inject NavigationManager Navigation
@inject IUserNotificationService Notify

<div class="hc-layout">
    <FluentHeader Class="hc-header">
        <FluentButton Appearance="Appearance.Stealth"
                      IconStart="@(new Icons.Regular.Size20.Navigation())"
                      OnClick="ToggleDrawer"
                      aria-label="Toggle navigation" />
        <div class="hc-brand">
            <span class="hc-brand-title">HealthCare</span>
            <span class="hc-brand-subtitle">Staff console</span>
        </div>
        <div class="hc-spacer"></div>
        @if (Permissions.CurrentUser is { } user)
        {
            <span class="hc-user-email">@user.Email</span>
            <FluentPersona Name="@user.Email"
                           Status="PresenceStatus.Available"
                           ImageSize="32px"
                           Initials="@GetInitials(user.Email)" />
            <FluentButton id="user-menu"
                          Appearance="Appearance.Stealth"
                          IconEnd="@(new Icons.Regular.Size16.ChevronDown())"
                          aria-label="User menu">
                Account
            </FluentButton>
            <FluentMenu Anchor="user-menu">
                <FluentMenuItem OnClick="LogoutAsync">Sign out</FluentMenuItem>
            </FluentMenu>
        }
    </FluentHeader>

    <div class="hc-shell">
        <nav class="hc-nav-rail @(_drawerOpen ? "hc-nav-open" : "hc-nav-collapsed")">
            <FluentNavMenu Class="hc-nav">
                <FluentNavLink Href="/dashboard"
                               Match="NavLinkMatch.All"
                               Icon="@(new Icons.Regular.Size20.Home())">
                    Dashboard
                </FluentNavLink>
                @if (Permissions.Has(WebPermissions.AppointmentsRead))
                {
                    <FluentNavLink Href="/appointments"
                                   Match="NavLinkMatch.All"
                                   Icon="@(new Icons.Regular.Size20.CalendarLtr())">
                        Appointments
                    </FluentNavLink>
                    <FluentNavLink Href="/appointments/calendar"
                                   Match="NavLinkMatch.Prefix"
                                   Icon="@(new Icons.Regular.Size20.CalendarWeekStart())">
                        Appointment Calendar
                    </FluentNavLink>
                }
                @if (Permissions.Has(WebPermissions.PatientsSearch))
                {
                    <FluentNavLink Href="/patients"
                                   Match="NavLinkMatch.Prefix"
                                   Icon="@(new Icons.Regular.Size20.People())">
                        Patients
                    </FluentNavLink>
                }
                @if (AvailabilityPermissionRules.CanManage(Permissions))
                {
                    <FluentNavLink Href="/availability"
                                   Match="NavLinkMatch.Prefix"
                                   Icon="@(new Icons.Regular.Size20.Clock())">
                        Availability
                    </FluentNavLink>
                }
                @if (Permissions.Has(WebPermissions.StaffRead))
                {
                    <FluentNavLink Href="/staff"
                                   Match="NavLinkMatch.Prefix"
                                   Icon="@(new Icons.Regular.Size20.PeopleTeam())">
                        Staff Management
                    </FluentNavLink>
                }
            </FluentNavMenu>
        </nav>

        <main class="hc-main">
            @if (Permissions.IsPatientOnly)
            {
                <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false">
                    Patient accounts cannot use the staff application.
                </FluentMessageBar>
                <FluentButton Appearance="Appearance.Accent" Href="/forbidden">View access details</FluentButton>
            }
            else
            {
                <PlatformTenantBanner />
                @Body
            }
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;

    protected override void OnInitialized()
    {
        Permissions.Changed += OnPermissionsChanged;
    }

    public void Dispose()
    {
        Permissions.Changed -= OnPermissionsChanged;
    }

    private void OnPermissionsChanged() => InvokeAsync(StateHasChanged);

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private static string GetInitials(string? email)
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            return "?";
        }

        var local = email.Split('@')[0];
        return local.Length >= 2 ? local[..2].ToUpperInvariant() : local.ToUpperInvariant();
    }

    private async Task LogoutAsync()
    {
        try
        {
            await AuthState.MarkLoggedOutAsync(callRemoteLogout: true);
        }
        catch
        {
            Notify.Info("Signed out locally.");
        }

        Navigation.NavigateTo("/logout", forceLoad: true);
    }
}
