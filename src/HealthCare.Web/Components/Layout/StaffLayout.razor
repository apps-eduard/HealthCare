@inherits LayoutComponentBase
@implements IDisposable
@inject IPermissionState Permissions
@inject NavigationManager Navigation
@inject IJSRuntime Js

<Layout Class="hc-pro-layout" Style="min-height:100vh">
    <Sider Collapsible
           @bind-Collapsed="_collapsed"
           Breakpoint="@BreakpointType.Lg"
           CollapsedWidth="64"
           Width="240"
           Theme="SiderTheme.Dark"
           Class="hc-pro-sider">
        <div class="hc-pro-logo" @onclick="GoDashboard">
            <span class="hc-pro-logo-mark">HC</span>
            @if (!_collapsed)
            {
                <div class="hc-pro-logo-text">
                    <strong>HealthCare</strong>
                    <span>Staff console</span>
                </div>
            }
        </div>
        <Menu Theme="MenuTheme.Dark"
              Mode="MenuMode.Inline"
              InlineCollapsed="_collapsed"
              SelectedKeys="_selectedKeys"
              Class="hc-pro-menu">
            <MenuItem Key="dashboard" RouterLink="/dashboard" RouterMatch="NavLinkMatch.All">
                <Icon Type="home" Theme="IconThemeType.Outline" />
                <span>Dashboard</span>
            </MenuItem>
            @if (Permissions.Has(WebPermissions.AppointmentsRead))
            {
                <MenuItem Key="appointments" RouterLink="/appointments" RouterMatch="NavLinkMatch.All">
                    <Icon Type="unordered-list" Theme="IconThemeType.Outline" />
                    <span>Appointment Queue</span>
                </MenuItem>
                <MenuItem Key="calendar" RouterLink="/appointments/calendar" RouterMatch="NavLinkMatch.Prefix">
                    <Icon Type="calendar" Theme="IconThemeType.Outline" />
                    <span>Appointment Calendar</span>
                </MenuItem>
            }
            @if (Permissions.Has(WebPermissions.PatientsSearch))
            {
                <MenuItem Key="patients" RouterLink="/patients" RouterMatch="NavLinkMatch.Prefix">
                    <Icon Type="team" Theme="IconThemeType.Outline" />
                    <span>Patients</span>
                </MenuItem>
            }
            @if (AvailabilityPermissionRules.CanView(Permissions))
            {
                <MenuItem Key="availability" RouterLink="/availability" RouterMatch="NavLinkMatch.Prefix">
                    <Icon Type="clock-circle" Theme="IconThemeType.Outline" />
                    <span>Doctor Availability</span>
                </MenuItem>
            }
            @if (Permissions.Has(WebPermissions.ClinicsRead))
            {
                <MenuItem Key="clinics" RouterLink="/clinics" RouterMatch="NavLinkMatch.Prefix">
                    <Icon Type="bank" Theme="IconThemeType.Outline" />
                    <span>Clinics</span>
                </MenuItem>
            }
            @if (Permissions.Has(WebPermissions.StaffRead))
            {
                <MenuItem Key="staff" RouterLink="/staff" RouterMatch="NavLinkMatch.Prefix">
                    <Icon Type="user" Theme="IconThemeType.Outline" />
                    <span>Staff Management</span>
                </MenuItem>
            }
        </Menu>
    </Sider>

    <Layout Class="hc-pro-main-layout">
        <Header Class="hc-pro-header">
            <Button Type="@ButtonType.Text"
                    Class="hc-pro-trigger"
                    OnClick="ToggleCollapsed"
                    AriaLabel="Toggle navigation">
                <Icon Type="@(_collapsed ? "menu-unfold" : "menu-fold")" Theme="IconThemeType.Outline" />
            </Button>
            <div class="hc-pro-header-brand">HealthCare</div>
            <div class="hc-spacer"></div>
            @if (Permissions.CurrentUser is { } user)
            {
                <Dropdown>
                    <Overlay>
                        <Menu>
                            <MenuItem Disabled="true">
                                <span class="hc-caption">@user.Email</span>
                            </MenuItem>
                            <MenuDivider />
                            <MenuItem OnClick="LogoutAsync">Sign out</MenuItem>
                        </Menu>
                    </Overlay>
                    <ChildContent>
                        <a class="hc-pro-account" @onclick:preventDefault>
                            <Avatar Style="background-color:#0F766E" Size="AvatarSize.Small">@GetInitials(user.Email)</Avatar>
                            <span class="hc-pro-account-label">@ShortEmail(user.Email)</span>
                        </a>
                    </ChildContent>
                </Dropdown>
            }
        </Header>
        <Content Class="hc-pro-content hc-main-enter">
            @if (Permissions.IsPatientOnly)
            {
                <Alert Type="@AlertType.Error"
                       Message="Patient accounts cannot use the staff application."
                       ShowIcon="true"
                       Style="margin-bottom:1rem;" />
                <Button Type="@ButtonType.Primary" OnClick='() => Navigation.NavigateTo("/forbidden")'>
                    View access details
                </Button>
            }
            else
            {
                <PlatformTenantBanner />
                <ClinicContextBanner />
                <div class="hc-pro-page">
                    @Body
                </div>
            }
        </Content>
    </Layout>
</Layout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _collapsed;
    private string[] _selectedKeys = ["dashboard"];
    private bool _viewportChecked;

    protected override void OnInitialized()
    {
        Permissions.Changed += OnPermissionsChanged;
        Navigation.LocationChanged += OnLocationChanged;
        UpdateSelectedKeys(Navigation.Uri);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _viewportChecked)
        {
            return;
        }

        _viewportChecked = true;
        try
        {
            var narrow = await Js.InvokeAsync<bool>("healthcareShell.isNarrow", 992);
            if (narrow && !_collapsed)
            {
                _collapsed = true;
                StateHasChanged();
            }
        }
        catch
        {
            // JS helper not ready — keep desktop default open.
        }
    }

    public void Dispose()
    {
        Permissions.Changed -= OnPermissionsChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private void OnPermissionsChanged() => InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) =>
        UpdateSelectedKeys(e.Location);

    private void UpdateSelectedKeys(string location)
    {
        var path = new Uri(location).AbsolutePath.TrimEnd('/').ToLowerInvariant();
        _selectedKeys =
        [
            path switch
            {
                "/dashboard" or "" => "dashboard",
                "/appointments" => "appointments",
                var p when p.StartsWith("/appointments/calendar", StringComparison.Ordinal) => "calendar",
                var p when p.StartsWith("/patients", StringComparison.Ordinal) => "patients",
                var p when p.StartsWith("/availability", StringComparison.Ordinal) => "availability",
                var p when p.StartsWith("/clinics", StringComparison.Ordinal) => "clinics",
                var p when p.StartsWith("/staff", StringComparison.Ordinal) => "staff",
                _ => "dashboard",
            }
        ];
        InvokeAsync(StateHasChanged);
    }

    private void ToggleCollapsed() => _collapsed = !_collapsed;

    private void GoDashboard() => Navigation.NavigateTo("/dashboard");

    private static string GetInitials(string? email)
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            return "?";
        }

        var local = email.Split('@')[0];
        return local.Length >= 2 ? local[..2].ToUpperInvariant() : local.ToUpperInvariant();
    }

    private static string ShortEmail(string? email)
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            return "Account";
        }

        var local = email.Split('@')[0];
        return local.Length > 18 ? local[..18] + "…" : local;
    }

    private Task LogoutAsync()
    {
        Navigation.NavigateTo("/logout", forceLoad: true);
        return Task.CompletedTask;
    }
}
