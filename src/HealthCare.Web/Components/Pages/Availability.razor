@page "/availability"
@attribute [Authorize]
@using HealthCare.Contracts.Appointments
@using HealthCare.Web.Availability
@using HealthCare.Web.Components.Availability
@using HealthCare.Web.Components.Clinics
@implements IDisposable
@inject IDoctorAvailabilityApiClient AvailabilityApi
@inject IPermissionState Permissions
@inject IPlatformTenantContext PlatformTenant
@inject IClinicWorkingContext ClinicContext
@inject IUiModalService Modals
@inject IUserNotificationService Notify
@inject IClinicDirectoryApiClient ClinicsApi
@inject IClinicDirectoryCache ClinicCache

<PageTitle>Doctor Availability</PageTitle>

@if (Permissions.IsPatientOnly)
{
    <Alert Type="@AlertType.Error" Message="Patient accounts cannot manage staff availability." ShowIcon="true" />
}
else if (!AvailabilityPermissionRules.CanView(Permissions))
{
    <PermissionDeniedState Message="You do not have permission to view doctor availability." />
}
else
{
    <HcPageHeader Title="Doctor Availability"
                  Subtitle="@(string.IsNullOrWhiteSpace(_timeZoneId) ? "Weekly windows and exceptions in clinic local time" : $"Clinic timezone: {_timeZoneId}")">
        <Breadcrumb>
            <Breadcrumb>
                <BreadcrumbItem Href="/dashboard">Home</BreadcrumbItem>
                <BreadcrumbItem>Doctor Availability</BreadcrumbItem>
            </Breadcrumb>
        </Breadcrumb>
        <ChildContent>
            <Button OnClick="RefreshAllAsync" Disabled="_loading || _doctorId is null" AriaLabel="Refresh availability">
                <Icon Type="reload" Theme="IconThemeType.Outline" /> Refresh
            </Button>
        </ChildContent>
    </HcPageHeader>

    @if (Permissions.IsPlatformAdmin && !PlatformTenant.HasOrganization)
    {
        <Alert Type="@AlertType.Info"
               Message="Select an organization in the platform banner before managing availability. Global availability load is not allowed."
               ShowIcon="true"
               Style="margin-bottom:1rem;" />
    }
    else if (Permissions.IsPlatformAdmin && !PlatformTenant.HasClinic)
    {
        <Alert Type="@AlertType.Info"
               Message="Select a clinic in the platform banner (or below) before loading availability for the selected organization."
               ShowIcon="true"
               Style="margin-bottom:1rem;" />
    }

    <div class="hc-card">
        <div class="hc-filter-grid">
            @if (Permissions.CanFilterByClinic)
            {
                <ClinicPicker Value="_clinicId" ValueChanged="OnClinicChanged" Label="Clinic" Required="true" AllowClear="false" ActiveOnly="true"
                              PlatformAdminBypass="@(Permissions.IsPlatformAdmin)"
                              PlatformOrganizationId="@(Permissions.IsPlatformAdmin ? PlatformTenant.SelectedOrganizationId : null)"
                              Disabled="@(Permissions.IsPlatformAdmin && !PlatformTenant.HasOrganization)" />
            }
            else if (Permissions.Has(WebPermissions.ClinicsRead) || _clinicId is not null)
            {
                <div>
                    <ClinicPicker Label="Clinic" AllowClear="false" Required="false" Disabled="true" />
                    <div class="hc-caption">@(_clinicName ?? "Your clinic")</div>
                </div>
            }

            @if (_selfOnly)
            {
                <div>
                    <label class="hc-filter-label" for="availability-doctor-self">Doctor</label>
                    <Input Id="availability-doctor-self" Value="@_selfDoctorLabel" Disabled="true" Style="width:100%;" AriaLabel="Selected doctor (self)" />
                </div>
            }
            else
            {
                <div>
                    <label class="hc-filter-label" for="availability-doctor">@FieldLabel.Mark("Doctor")</label>
                    <Select Id="availability-doctor"
                            TItemValue="string"
                            TItem="string"
                            Value="@(_doctorId?.ToString() ?? "")"
                            ValueChanged="OnDoctorStringChanged"
                            Disabled="_doctorsLoading || _clinicId is null"
                            Style="width:100%;"
                            AriaLabel="Select doctor">
                        <SelectOptions>
                            @foreach (var doctor in _doctors)
                            {
                                <SelectOption TItemValue="string" TItem="string" Value="@doctor.StaffMemberId.ToString()"
                                              Label="@(doctor.DisplayName + (string.IsNullOrWhiteSpace(doctor.Specialty) ? "" : $" · {doctor.Specialty}"))" />
                            }
                        </SelectOptions>
                    </Select>
                </div>
            }

            <div>
                <label class="hc-filter-label" for="availability-from">Date range from</label>
                <DatePicker Id="availability-from" TValue="DateTime?" @bind-Value="_rangeFrom" Style="width:100%;" AriaLabel="Effective range start" />
            </div>
            <div>
                <label class="hc-filter-label" for="availability-to">Date range to</label>
                <DatePicker Id="availability-to" TValue="DateTime?" @bind-Value="_rangeTo" Style="width:100%;" AriaLabel="Effective range end" />
            </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(_timeZoneId))
        {
            <div class="hc-caption" style="margin-top:0.5rem;">
                All times are clinic-local (@_timeZoneId). The API interprets windows in this timezone — not your browser clock.
            </div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(_error)) { <ErrorState Message="@_error" /> }

    @if (_doctorId is null)
    {
        <Alert Type="@AlertType.Info" Message="Select a clinic and doctor to view availability." ShowIcon="true" />
    }
    else
    {
        <Tabs>
            <TabPane Tab="Weekly Schedule" Key="windows">
                <div style="padding:1rem 0;">
                    @if (_canManage)
                    {
                        <div style="display:flex;justify-content:flex-end;margin-bottom:0.75rem;">
                            <Button Type="@ButtonType.Primary" OnClick="OpenCreateWindowAsync" Disabled="_loading" AriaLabel="Add weekly availability window">
                                <Icon Type="plus" Theme="IconThemeType.Outline" /> Add window
                            </Button>
                        </div>
                    }
                    @if (_loading) { <PageLoading /> }
                    else if (_windows.Count == 0) { <EmptyState Message="No weekly availability windows." /> }
                    else
                    {
                        @foreach (var (day, list) in AvailabilityPresentation.GroupByDay(_windows))
                        {
                            <h3 style="font-size:1rem;margin:1rem 0 0.5rem;">@day</h3>
                            <div class="hc-table-wrap" style="margin-bottom:0.75rem;">
                                <table class="hc-table" aria-label="@($"Weekly availability for {day}")">
                                    <thead><tr><th>Time</th><th>Slot</th><th>Effective</th><th>Status</th><th>Version</th>@if (_canManage) { <th class="hc-actions">Actions</th> }</tr></thead>
                                    <tbody>
                                    @foreach (var row in list)
                                    {
                                        <tr>
                                            <td>@AvailabilityPresentation.FormatLocalWindow(row.StartLocalTime, row.EndLocalTime)</td>
                                            <td>@row.SlotDurationMinutes min</td>
                                            <td>@AvailabilityPresentation.FormatEffectiveRange(row.EffectiveFrom, row.EffectiveTo)</td>
                                            <td><StatusBadge Text="@AvailabilityPresentation.ActiveLabel(row.IsActive)" Tone="@AvailabilityPresentation.ActiveTone(row.IsActive)" /></td>
                                            <td>@row.Version</td>
                                            @if (_canManage)
                                            {
                                                <td class="hc-actions">
                                                    <Button Type="@ButtonType.Text" OnClick="@(() => OpenEditWindowAsync(row))" AriaLabel="Edit availability window">
                                                        <Icon Type="edit" Theme="IconThemeType.Outline" />
                                                    </Button>
                                                    <Button Type="@ButtonType.Text" OnClick="@(() => DeleteWindowAsync(row))" AriaLabel="Delete availability window">
                                                        <Icon Type="delete" Theme="IconThemeType.Outline" />
                                                    </Button>
                                                </td>
                                            }
                                        </tr>
                                    }
                                    </tbody>
                                </table>
                            </div>
                        }
                    }
                </div>
            </TabPane>
            <TabPane Tab="Exceptions" Key="exceptions">
                <div style="padding:1rem 0;">
                    @if (_canManage)
                    {
                        <div style="display:flex;justify-content:flex-end;margin-bottom:0.75rem;">
                            <Button Type="@ButtonType.Primary" OnClick="OpenCreateExceptionAsync" Disabled="_loading" AriaLabel="Add availability exception">
                                <Icon Type="plus" Theme="IconThemeType.Outline" /> Add exception
                            </Button>
                        </div>
                    }
                    @if (_loading) { <PageLoading /> }
                    else if (_exceptions.Count == 0) { <EmptyState Message="No date-specific exceptions." /> }
                    else
                    {
                        <div class="hc-table-wrap">
                            <table class="hc-table" aria-label="Availability exceptions">
                                <thead><tr><th>Date</th><th>Type</th><th>Time</th><th>Reason</th><th>Version</th>@if (_canManage) { <th class="hc-actions">Actions</th> }</tr></thead>
                                <tbody>
                                @foreach (var row in _exceptions)
                                {
                                    <tr>
                                        <td>@row.Date.ToString("yyyy-MM-dd")</td>
                                        <td>@AvailabilityPresentation.ExceptionTypeLabel(row.ExceptionType)</td>
                                        <td>@(string.IsNullOrWhiteSpace(row.StartLocalTime) ? "Full day" : AvailabilityPresentation.FormatLocalWindow(row.StartLocalTime!, row.EndLocalTime ?? ""))</td>
                                        <td>@(row.Reason ?? "—")</td>
                                        <td>@row.Version</td>
                                        @if (_canManage)
                                        {
                                            <td class="hc-actions">
                                                <Button Type="@ButtonType.Text" OnClick="@(() => DeleteExceptionAsync(row))" AriaLabel="Delete exception">
                                                    <Icon Type="delete" Theme="IconThemeType.Outline" />
                                                </Button>
                                            </td>
                                        }
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </TabPane>
            <TabPane Tab="Effective Availability" Key="effective">
                <div style="padding:1rem 0;">
                    <Alert Type="@AlertType.Info"
                           Message="Client-side composition of weekly windows and exceptions for the selected date range (max 14 days). Booking rules remain enforced by the API."
                           ShowIcon="true"
                           Style="margin-bottom:0.75rem;" />
                    @if (_loading) { <PageLoading /> }
                    else
                    {
                        var days = AvailabilityEffectiveComposer.Build(
                            _windows,
                            _exceptions,
                            DateOnly.FromDateTime(_rangeFrom ?? DateTime.Today),
                            DateOnly.FromDateTime(_rangeTo ?? DateTime.Today.AddDays(6)));
                        @if (days.Count == 0)
                        {
                            <EmptyState Message="No days in the selected range." />
                        }
                        else
                        {
                            @foreach (var day in days)
                            {
                                <div style="margin-bottom:1rem;">
                                    <h3 style="font-size:1rem;margin:0 0 0.35rem;">@day.Date.ToString("yyyy-MM-dd") · @day.DayOfWeek</h3>
                                    @if (day.Windows.Count == 0 && day.Exceptions.Count == 0)
                                    {
                                        <div class="hc-caption">No applicable windows or exceptions.</div>
                                    }
                                    else
                                    {
                                        @if (day.Windows.Count > 0)
                                        {
                                            <div class="hc-caption" style="margin-bottom:0.25rem;">Windows</div>
                                            <Space Wrap>
                                                @foreach (var w in day.Windows)
                                                {
                                                    <StatusBadge Text="@($"{AvailabilityPresentation.FormatLocalWindow(w.StartLocalTime, w.EndLocalTime)} · {w.SlotDurationMinutes}m{(w.IsActive ? "" : " · inactive")}")"
                                                                 Tone="@(w.IsActive ? StatusTone.Success : StatusTone.Default)" />
                                                }
                                            </Space>
                                        }
                                        @if (day.Exceptions.Count > 0)
                                        {
                                            <div class="hc-caption" style="margin:0.5rem 0 0.25rem;">Exceptions</div>
                                            <Space Wrap>
                                                @foreach (var ex in day.Exceptions)
                                                {
                                                    var label = string.IsNullOrWhiteSpace(ex.StartLocalTime)
                                                        ? AvailabilityPresentation.ExceptionTypeLabel(ex.ExceptionType)
                                                        : $"{AvailabilityPresentation.ExceptionTypeLabel(ex.ExceptionType)} · {AvailabilityPresentation.FormatLocalWindow(ex.StartLocalTime!, ex.EndLocalTime ?? "")}";
                                                    <StatusBadge Text="@label" Tone="StatusTone.Warning" />
                                                }
                                            </Space>
                                        }
                                    }
                                </div>
                            }
                        }
                    }
                </div>
            </TabPane>
            <TabPane Tab="Slot Preview" Key="slots">
                <div style="padding:1rem 0;">
                    <div class="hc-filter-grid">
                        <div>
                            <label class="hc-filter-label" for="slot-preview-date">Date</label>
                            <DatePicker Id="slot-preview-date"
                                        TValue="DateTime?"
                                        Value="_previewDate"
                                        OnChange="OnPreviewDatePickerChanged"
                                        Style="width:100%;"
                                        AriaLabel="Slot preview date" />
                        </div>
                        <div>
                            <label class="hc-filter-label" for="slot-preview-duration">Duration (minutes)</label>
                            <AntDesign.InputNumber Id="slot-preview-duration"
                                                    TValue="int"
                                                    @bind-Value="_previewDuration"
                                                    OnChange="OnPreviewDurationChanged"
                                                    Min="10"
                                                    Max="240"
                                                    Style="width:100%;"
                                                    AriaLabel="Slot duration minutes" />
                        </div>
                        <div>
                            <label class="hc-filter-label">&nbsp;</label>
                            <Button Type="@ButtonType.Primary"
                                    OnClick="LoadSlotsAsync"
                                    Disabled="_slotsLoading || string.IsNullOrWhiteSpace(_clinicSlug) || !Permissions.Has(WebPermissions.AvailabilityRead)"
                                    AriaLabel="Preview bookable slots">
                                Preview
                            </Button>
                        </div>
                    </div>
                    @if (_slotsLoading) { <PageLoading /> }
                    else if (_slots.Count == 0) { <EmptyState Message="No available slots for this date." /> }
                    else
                    {
                        <Space Wrap Style="margin-top:0.75rem;">
                            @foreach (var slot in _slots)
                            {
                                <StatusBadge Text="@($"{slot.StartLocal} – {slot.EndLocal}")" Tone="StatusTone.Neutral" />
                            }
                        </Space>
                    }
                </div>
            </TabPane>
        </Tabs>
    }
}

@code {
    private readonly List<ClinicDoctorResponse> _doctors = [];
    private readonly List<DoctorAvailabilityResponse> _windows = [];
    private readonly List<DoctorAvailabilityExceptionResponse> _exceptions = [];
    private readonly List<AvailableSlotResponse> _slots = [];

    private bool _selfOnly;
    private bool _canManage;
    private bool _loading;
    private bool _doctorsLoading;
    private bool _slotsLoading;
    private bool _subscribedPlatform;
    private bool _subscribedClinic;
    private string? _error;
    private Guid? _clinicId;
    private string? _clinicSlug;
    private string? _clinicName;
    private string? _timeZoneId;
    private Guid? _doctorId;
    private string? _selfDoctorLabel;
    private Guid? _boundOrganizationId;
    private DateTime? _previewDate = DateTime.Today;
    private DateTime? _rangeFrom = DateTime.Today;
    private DateTime? _rangeTo = DateTime.Today.AddDays(6);
    private int _previewDuration = 30;

    protected override async Task OnInitializedAsync()
    {
        if (Permissions.IsPatientOnly || !AvailabilityPermissionRules.CanView(Permissions))
        {
            return;
        }

        _selfOnly = AvailabilityPermissionRules.IsSelfOnly(Permissions);
        _canManage = AvailabilityPermissionRules.CanManage(Permissions);

        if (Permissions.IsPlatformAdmin)
        {
            PlatformTenant.Changed += OnPlatformTenantChanged;
            _subscribedPlatform = true;
            SyncFromPlatformTenant();
        }
        else if (Permissions.IsOrganizationAdmin)
        {
            ClinicContext.Changed += OnClinicContextChanged;
            _subscribedClinic = true;
            if (ClinicContext.HasClinic)
            {
                _clinicId = ClinicContext.SelectedClinicId;
            }
        }

        if (Permissions.IsPlatformAdmin
            && (!PlatformTenant.HasOrganization || !PlatformTenant.HasClinic))
        {
            return;
        }

        if (!Permissions.CanFilterByClinic && Permissions.CurrentUser?.ClinicId is Guid clinicId)
        {
            _clinicId = clinicId;
            await ResolveClinicMetaAsync(clinicId);
        }
        else if (_clinicId is Guid selected)
        {
            await ResolveClinicMetaAsync(selected);
        }

        if (_selfOnly)
        {
            if (Permissions.CurrentUser?.StaffMemberId is Guid selfId)
            {
                _doctorId = selfId;
                _selfDoctorLabel = "You (self)";
                await LoadDoctorsAsync();
                await RefreshAllAsync();
            }
            else
            {
                _error = "Your staff membership does not include a doctor id.";
            }
        }
        else if (_clinicId is not null)
        {
            await LoadDoctorsAsync();
        }
    }

    public void Dispose()
    {
        if (_subscribedPlatform)
        {
            PlatformTenant.Changed -= OnPlatformTenantChanged;
        }

        if (_subscribedClinic)
        {
            ClinicContext.Changed -= OnClinicContextChanged;
        }
    }

    private void OnPlatformTenantChanged() => InvokeAsync(async () =>
    {
        var orgChanged = _boundOrganizationId != PlatformTenant.SelectedOrganizationId;
        SyncFromPlatformTenant();
        if (orgChanged)
        {
            ClearDoctorScopedState(clearDoctor: !_selfOnly);
        }

        if (_clinicId is Guid id)
        {
            await ResolveClinicMetaAsync(id);
            await LoadDoctorsAsync();
            if (_doctorId is not null)
            {
                await RefreshAllAsync();
            }
        }
        else
        {
            ClearDoctorScopedState(clearDoctor: !_selfOnly);
            _clinicSlug = null;
            _clinicName = null;
            _timeZoneId = null;
            _doctors.Clear();
        }

        StateHasChanged();
    });

    private void OnClinicContextChanged() => InvokeAsync(async () =>
    {
        _clinicId = ClinicContext.SelectedClinicId;
        if (!_selfOnly)
        {
            _doctorId = null;
        }

        _windows.Clear();
        _exceptions.Clear();
        _slots.Clear();
        _doctors.Clear();
        _clinicSlug = null;
        _clinicName = null;
        _timeZoneId = null;
        _error = null;

        if (_clinicId is Guid id)
        {
            await ResolveClinicMetaAsync(id);
            await LoadDoctorsAsync();
            if (_doctorId is not null)
            {
                await RefreshAllAsync();
            }
        }

        StateHasChanged();
    });

    private void SyncFromPlatformTenant()
    {
        _boundOrganizationId = PlatformTenant.SelectedOrganizationId;
        if (Permissions.IsPlatformAdmin)
        {
            _clinicId = PlatformTenant.SelectedClinicId;
        }
    }

    private void ClearDoctorScopedState(bool clearDoctor)
    {
        if (clearDoctor)
        {
            _doctorId = null;
        }

        _windows.Clear();
        _exceptions.Clear();
        _slots.Clear();
        _doctors.Clear();
        _error = null;
    }

    private async Task OnClinicChanged(Guid? clinicId)
    {
        _clinicId = clinicId;

        if (Permissions.IsPlatformAdmin)
        {
            if (clinicId is Guid id && id != Guid.Empty)
            {
                if (PlatformTenant.SelectedClinicId != id)
                {
                    PlatformTenant.SelectClinic(id);
                }
            }
            else if (PlatformTenant.HasClinic)
            {
                PlatformTenant.ClearClinic();
            }
        }
        else if (Permissions.IsOrganizationAdmin)
        {
            if (clinicId is Guid id && id != Guid.Empty)
            {
                ClinicContext.SelectClinic(id);
            }
            else
            {
                ClinicContext.ClearClinic();
            }

            return;
        }

        if (!_selfOnly)
        {
            _doctorId = null;
        }

        _windows.Clear();
        _exceptions.Clear();
        _slots.Clear();
        _doctors.Clear();
        _clinicSlug = null;
        _clinicName = null;
        _timeZoneId = null;

        if (clinicId is Guid clinic)
        {
            await ResolveClinicMetaAsync(clinic);
            await LoadDoctorsAsync();
        }
    }

    private Task OnPreviewDatePickerChanged(DateTimeChangedEventArgs<DateTime?> args) =>
        OnPreviewDateChanged(args.Date);

    private async Task OnDoctorStringChanged(string? value)
    {
        Guid? doctorId = Guid.TryParse(value, out var id) ? id : null;
        await OnDoctorChanged(doctorId);
    }

    private async Task OnDoctorChanged(Guid? doctorId)
    {
        _doctorId = doctorId;
        _windows.Clear();
        _exceptions.Clear();
        _slots.Clear();
        if (doctorId is not null)
        {
            await RefreshAllAsync();
        }
    }

    private async Task ResolveClinicMetaAsync(Guid clinicId)
    {
        try
        {
            if (ClinicCache.TryGet(clinicId, out var cached) && cached is not null)
            {
                _clinicSlug = cached.Slug;
                _clinicName = cached.Name;
                _timeZoneId = cached.TimeZoneId;
                return;
            }

            var detail = await ClinicsApi.GetByIdAsync(clinicId, Permissions.IsPlatformAdmin);
            ClinicCache.Set(detail);
            _clinicSlug = detail.Slug;
            _clinicName = detail.Name;
            _timeZoneId = detail.TimeZoneId;
        }
        catch (ApiProblemException ex)
        {
            _error = AvailabilityProblemMessages.ToUserMessage(ex);
        }
    }

    private void PreferTimeZoneFromPayload()
    {
        var fromWindow = _windows.FirstOrDefault(w => !string.IsNullOrWhiteSpace(w.ClinicTimeZoneId))?.ClinicTimeZoneId;
        if (!string.IsNullOrWhiteSpace(fromWindow))
        {
            _timeZoneId = fromWindow;
            return;
        }

        var fromDoctor = _doctors.FirstOrDefault(d => d.StaffMemberId == _doctorId)?.ClinicTimeZoneId;
        if (!string.IsNullOrWhiteSpace(fromDoctor))
        {
            _timeZoneId = fromDoctor;
        }
    }

    private async Task LoadDoctorsAsync()
    {
        _doctors.Clear();
        if (_clinicId is not Guid clinicId || clinicId == Guid.Empty)
        {
            return;
        }

        if (Permissions.IsPlatformAdmin
            && (!PlatformTenant.HasOrganization || clinicId == Guid.Empty))
        {
            return;
        }

        _doctorsLoading = true;
        try
        {
            var doctors = await AvailabilityApi.ListClinicDoctorsByIdAsync(clinicId, Permissions.IsPlatformAdmin);
            _doctors.AddRange(doctors.Where(d => d.AcceptsBookings));
            PreferTimeZoneFromPayload();
            if (_selfOnly && _doctorId is Guid selfId)
            {
                var me = _doctors.FirstOrDefault(d => d.StaffMemberId == selfId);
                _selfDoctorLabel = me is null
                    ? "You (self)"
                    : $"{me.DisplayName}{(string.IsNullOrWhiteSpace(me.Specialty) ? "" : $" · {me.Specialty}")}";
            }
        }
        catch (ApiProblemException ex)
        {
            _error = AvailabilityProblemMessages.ToUserMessage(ex);
        }
        finally
        {
            _doctorsLoading = false;
        }
    }

    private async Task RefreshAllAsync()
    {
        if (_doctorId is not Guid doctorId)
        {
            return;
        }

        if (Permissions.IsPlatformAdmin
            && (!PlatformTenant.HasOrganization || _clinicId is null || _clinicId == Guid.Empty))
        {
            _windows.Clear();
            _exceptions.Clear();
            _loading = false;
            return;
        }

        _loading = true;
        _error = null;
        try
        {
            var bypass = Permissions.IsPlatformAdmin;
            var clinicId = _clinicId;
            var windows = await AvailabilityApi.ListAvailabilityAsync(doctorId, clinicId, bypass);
            var exceptions = await AvailabilityApi.ListExceptionsAsync(doctorId, clinicId, bypass);
            _windows.Clear();
            _windows.AddRange(windows);
            _exceptions.Clear();
            _exceptions.AddRange(exceptions.OrderBy(e => e.Date).ThenBy(e => e.StartLocalTime));
            PreferTimeZoneFromPayload();
        }
        catch (ApiProblemException ex)
        {
            _error = AvailabilityProblemMessages.ToUserMessage(ex);
            _windows.Clear();
            _exceptions.Clear();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenCreateWindowAsync()
    {
        if (!_canManage || _doctorId is not Guid doctorId)
        {
            return;
        }

        if (await Modals.ShowAsync<AvailabilityWindowDialog, AvailabilityWindowDialog.Args>(
                "Add availability",
                new AvailabilityWindowDialog.Args
                {
                    DoctorStaffMemberId = doctorId,
                    ClinicId = _clinicId,
                    PlatformAdminBypass = Permissions.IsPlatformAdmin,
                }))
        {
            await RefreshAllAsync();
        }
    }

    private async Task OpenEditWindowAsync(DoctorAvailabilityResponse window)
    {
        if (!_canManage || _doctorId is not Guid doctorId)
        {
            return;
        }

        if (await Modals.ShowAsync<AvailabilityWindowDialog, AvailabilityWindowDialog.Args>(
                "Edit availability",
                new AvailabilityWindowDialog.Args
                {
                    DoctorStaffMemberId = doctorId,
                    ClinicId = _clinicId,
                    PlatformAdminBypass = Permissions.IsPlatformAdmin,
                    Existing = window,
                }))
        {
            await RefreshAllAsync();
        }
    }

    private async Task DeleteWindowAsync(DoctorAvailabilityResponse window)
    {
        if (!_canManage || _doctorId is not Guid doctorId)
        {
            return;
        }

        if (!await Modals.ConfirmAsync(
                "Delete availability",
                $"Delete {window.DayOfWeek} {window.StartLocalTime}–{window.EndLocalTime}?"))
        {
            return;
        }

        try
        {
            await AvailabilityApi.DeleteAvailabilityAsync(
                doctorId,
                window.Id,
                window.Version,
                _clinicId,
                Permissions.IsPlatformAdmin);
            Notify.Success("Availability deleted.");
            await RefreshAllAsync();
        }
        catch (ApiProblemException ex) when (AvailabilityProblemMessages.IsConcurrencyConflict(ex))
        {
            Notify.Warning(AvailabilityProblemMessages.ToUserMessage(ex));
            await RefreshAllAsync();
        }
        catch (ApiProblemException ex)
        {
            Notify.Error(AvailabilityProblemMessages.ToUserMessage(ex));
        }
    }

    private async Task OpenCreateExceptionAsync()
    {
        if (!_canManage || _doctorId is not Guid doctorId)
        {
            return;
        }

        if (await Modals.ShowAsync<AvailabilityExceptionDialog, AvailabilityExceptionDialog.Args>(
                "Add exception",
                new AvailabilityExceptionDialog.Args
                {
                    DoctorStaffMemberId = doctorId,
                    ClinicId = _clinicId,
                    PlatformAdminBypass = Permissions.IsPlatformAdmin,
                }))
        {
            await RefreshAllAsync();
        }
    }

    private async Task DeleteExceptionAsync(DoctorAvailabilityExceptionResponse exception)
    {
        if (!_canManage || _doctorId is not Guid doctorId)
        {
            return;
        }

        if (!await Modals.ConfirmAsync(
                "Delete exception",
                $"Delete exception on {exception.Date:yyyy-MM-dd}?"))
        {
            return;
        }

        try
        {
            await AvailabilityApi.DeleteExceptionAsync(
                doctorId,
                exception.Id,
                exception.Version,
                _clinicId,
                Permissions.IsPlatformAdmin);
            Notify.Success("Exception deleted.");
            await RefreshAllAsync();
        }
        catch (ApiProblemException ex) when (AvailabilityProblemMessages.IsConcurrencyConflict(ex))
        {
            Notify.Warning(AvailabilityProblemMessages.ToUserMessage(ex));
            await RefreshAllAsync();
        }
        catch (ApiProblemException ex)
        {
            Notify.Error(AvailabilityProblemMessages.ToUserMessage(ex));
        }
    }

    private async Task OnPreviewDateChanged(DateTime? date)
    {
        _previewDate = date;
        await LoadSlotsAsync();
    }

    private async Task OnPreviewDurationChanged(int duration)
    {
        _previewDuration = duration;
        await LoadSlotsAsync();
    }

    private async Task LoadSlotsAsync()
    {
        _slots.Clear();
        if (_doctorId is not Guid doctorId
            || string.IsNullOrWhiteSpace(_clinicSlug)
            || _previewDate is not DateTime date
            || !Permissions.Has(WebPermissions.AvailabilityRead))
        {
            return;
        }

        if (Permissions.IsPlatformAdmin
            && (!PlatformTenant.HasOrganization || _clinicId is null || _clinicId == Guid.Empty))
        {
            return;
        }

        _slotsLoading = true;
        try
        {
            var slots = await AvailabilityApi.GetAvailableSlotsAsync(
                _clinicSlug,
                doctorId,
                DateOnly.FromDateTime(date),
                _previewDuration);
            _slots.AddRange(slots);
            var tz = slots.FirstOrDefault(s => !string.IsNullOrWhiteSpace(s.TimeZoneId))?.TimeZoneId;
            if (!string.IsNullOrWhiteSpace(tz))
            {
                _timeZoneId = tz;
            }
        }
        catch (ApiProblemException ex)
        {
            Notify.Error(AvailabilityProblemMessages.ToUserMessage(ex));
        }
        finally
        {
            _slotsLoading = false;
        }
    }
}
