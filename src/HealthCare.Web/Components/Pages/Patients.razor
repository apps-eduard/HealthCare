@page "/patients"
@page "/patients/{PatientId:guid}"
@attribute [Authorize]
@using HealthCare.Contracts.Patients
@using HealthCare.Web.Patients
@using HealthCare.Web.Components.Patients
@using HealthCare.Web.Components.Clinics
@implements IDisposable
@inject IStaffPatientApiClient PatientsApi
@inject IPermissionState Permissions
@inject IPlatformTenantContext PlatformTenant
@inject IDialogService DialogService
@inject IUserNotificationService Notify
@inject IClinicDirectoryCache ClinicCache
@inject IClinicDirectoryApiClient ClinicsApi
@inject NavigationManager Navigation

<PageTitle>Patients</PageTitle>

@if (Permissions.IsPatientOnly)
{
    <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false">Patient accounts cannot use the staff patient directory.</FluentMessageBar>
}
else if (!Permissions.Has(WebPermissions.PatientsSearch))
{
    <PermissionDeniedState Message="You do not have permission to search patients." />
}
else
{
    <PageHeader Title="Patient directory">
        <FluentButton Appearance="Appearance.Outline" OnClick="ResetFiltersAsync" Disabled="_loading">Clear filters</FluentButton>
        <FluentButton Appearance="Appearance.Outline" IconStart="@(new Icons.Regular.Size20.ArrowClockwise())" OnClick="RefreshClicked" Disabled="_loading">Refresh</FluentButton>
    </PageHeader>

    @if (Permissions.IsPlatformAdmin && !PlatformTenant.HasOrganization)
    {
        <FluentMessageBar Intent="MessageIntent.Info" AllowDismiss="false" Style="margin-bottom:1rem;">
            Select an organization in the platform banner before searching patients. Global patient search is not allowed.
        </FluentMessageBar>
    }
    else if (Permissions.IsPlatformAdmin && !PlatformTenant.HasClinic)
    {
        <FluentMessageBar Intent="MessageIntent.Info" AllowDismiss="false" Style="margin-bottom:1rem;">
            Select a clinic in the platform banner (or below) before loading patients for the selected organization.
        </FluentMessageBar>
    }

    <div class="hc-card">
        <div class="hc-filter-grid">
            <FluentTextField Value="@_search" ValueChanged="OnSearchChanged" Label="Search" Disabled="_loading" Style="width:100%;" />
            <FluentTextField Value="@_localNumber" ValueChanged="OnLocalNumberChanged" Label="Local patient number" Disabled="_loading" Style="width:100%;" />
            <FluentSelect TOption="string" Value="_clinicPatientStatus" ValueChanged="OnClinicStatusChanged" Label="Enrollment status" Style="width:100%;">
                <FluentOption Value="">Any</FluentOption>
                @foreach (var status in PatientStatusPresentation.ClinicPatientStatuses)
                {
                    <FluentOption Value="@status">@status</FluentOption>
                }
            </FluentSelect>
            <FluentSelect TOption="string" Value="_patientActiveFilter" ValueChanged="OnPatientActiveChanged" Label="Patient status" Style="width:100%;">
                <FluentOption Value="">Any</FluentOption>
                <FluentOption Value="active">Active</FluentOption>
                <FluentOption Value="inactive">Inactive</FluentOption>
            </FluentSelect>
            @if (Permissions.CanFilterByClinic)
            {
                <ClinicPicker Value="_clinicId" ValueChanged="OnClinicFilterChanged" Label="Clinic filter"
                              HelperText="@(Permissions.IsPlatformAdmin ? "Required for PLATFORM_ADMIN" : "Leave empty for all clinics in your organization")"
                              AllowClear="@(!Permissions.IsPlatformAdmin)" Required="@(Permissions.IsPlatformAdmin)" ActiveOnly="null"
                              PlatformAdminBypass="@(Permissions.IsPlatformAdmin)"
                              PlatformOrganizationId="@(Permissions.IsPlatformAdmin ? PlatformTenant.SelectedOrganizationId : null)"
                              Disabled="@(Permissions.IsPlatformAdmin && !PlatformTenant.HasOrganization)" />
            }
            else if (Permissions.Has(WebPermissions.ClinicsRead))
            {
                <ClinicPicker Label="Clinic" AllowClear="false" Required="false" Disabled="true" />
            }
            <FluentSelect TOption="string" @bind-Value="_sortBy" Label="Sort by" Style="width:100%;">
                <FluentOption Value="registeredAtUtc">Enrollment date</FluentOption>
                <FluentOption Value="localPatientNumber">Local number</FluentOption>
                <FluentOption Value="lastName">Last name</FluentOption>
                <FluentOption Value="firstName">First name</FluentOption>
                <FluentOption Value="clinicPatientStatus">Enrollment status</FluentOption>
                <FluentOption Value="patientIsActive">Patient status</FluentOption>
            </FluentSelect>
            <FluentSelect TOption="string" @bind-Value="_sortDirection" Label="Direction" Style="width:100%;">
                <FluentOption Value="desc">Descending</FluentOption>
                <FluentOption Value="asc">Ascending</FluentOption>
            </FluentSelect>
            <FluentSelect TOption="string" Value="@_pageSize.ToString()" ValueChanged="OnPageSizeChanged" Label="Page size" Style="width:100%;">
                <FluentOption Value="10">10</FluentOption>
                <FluentOption Value="20">20</FluentOption>
                <FluentOption Value="50">50</FluentOption>
            </FluentSelect>
            <FluentButton Appearance="Appearance.Accent" OnClick="ApplyFiltersAsync"
                          Disabled="@(Permissions.IsPlatformAdmin && (!PlatformTenant.HasOrganization || !_clinicId.HasValue))">Apply</FluentButton>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error)) { <ErrorState Message="@_error" /> }
    @if (_loading) { <PageLoading /> }
    else if (_items.Count == 0) { <EmptyState Message="No patients match the current filters." /> }
    else
    {
        <div class="hc-table-wrap">
            <table class="hc-table">
                <thead>
                    <tr>
                        <th>Local #</th><th>Name</th><th>Gender</th><th>DOB</th><th>Mobile</th>
                        <th>Enrollment</th><th>Patient</th><th>Clinic</th><th>Enrolled</th><th class="hc-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in _items)
                {
                    <tr>
                        <td>@row.LocalPatientNumber</td>
                        <td>@PatientDisplay.FullName(row)</td>
                        <td>@(row.Gender ?? "—")</td>
                        <td>@(row.DateOfBirth?.ToString("yyyy-MM-dd") ?? "—")</td>
                        <td>@PatientDisplay.MaskMobile(row.MobileNumber)</td>
                        <td><StatusBadge Text="@PatientStatusPresentation.ClinicPatientLabel(row.ClinicPatientStatus)" Tone="@PatientStatusPresentation.ClinicPatientTone(row.ClinicPatientStatus)" /></td>
                        <td><StatusBadge Text="@PatientStatusPresentation.PatientActiveLabel(row.PatientIsActive)" Tone="@PatientStatusPresentation.PatientActiveTone(row.PatientIsActive)" /></td>
                        <td>@ClinicLabel(row.ClinicId)</td>
                        <td>@row.RegisteredAtUtc.UtcDateTime.ToString("yyyy-MM-dd")</td>
                        <td class="hc-actions">
                            @if (Permissions.Has(WebPermissions.PatientsRead))
                            {
                                <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size16.Eye())" OnClick="@(() => OpenDetailAsync(row.PatientId))" aria-label="Details" />
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            <div class="hc-pager">
                <span class="hc-caption">Total: @_totalCount</span>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="4">
                    <FluentButton Appearance="Appearance.Outline" Disabled="@(_page <= 1 || _loading)" OnClick="@(() => OnPageChanged(_page - 1))">Prev</FluentButton>
                    <span class="hc-caption">Page @_page / @_pageCount</span>
                    <FluentButton Appearance="Appearance.Outline" Disabled="@(_page >= _pageCount || _loading)" OnClick="@(() => OnPageChanged(_page + 1))">Next</FluentButton>
                </FluentStack>
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public Guid? PatientId { get; set; }

    private readonly List<StaffPatientSummaryResponse> _items = [];
    private readonly Dictionary<Guid, string> _clinicLabels = new();
    private CancellationTokenSource? _loadCts;
    private int _loadVersion;
    private bool _loading;
    private string? _error;
    private string? _search;
    private string? _localNumber;
    private string? _clinicPatientStatus;
    private string? _patientActiveFilter;
    private Guid? _clinicId;
    private string _sortBy = "registeredAtUtc";
    private string _sortDirection = "desc";
    private int _page = 1;
    private int _pageSize = 20;
    private int _totalCount;
    private int _pageCount = 1;
    private Guid? _boundOrganizationId;
    private bool _disposed;

    protected override async Task OnInitializedAsync()
    {
        PlatformTenant.Changed += OnPlatformTenantChanged;

        if (Permissions.IsPatientOnly || !Permissions.Has(WebPermissions.PatientsSearch))
        {
            return;
        }

        SyncFromPlatformTenant();
        await LoadAsync();

        if (PatientId is Guid id && Permissions.Has(WebPermissions.PatientsRead))
        {
            await OpenDetailAsync(id);
        }
    }

    public void Dispose()
    {
        _disposed = true;
        PlatformTenant.Changed -= OnPlatformTenantChanged;
        _loadCts?.Cancel();
        _loadCts?.Dispose();
        _items.Clear();
        _clinicLabels.Clear();
    }

    private void OnPlatformTenantChanged() => InvokeAsync(async () =>
    {
        var orgChanged = _boundOrganizationId != PlatformTenant.SelectedOrganizationId;
        SyncFromPlatformTenant();
        if (orgChanged)
        {
            _items.Clear();
            _clinicLabels.Clear();
            _error = null;
            _search = null;
            _localNumber = null;
        }

        _loadCts?.Cancel();
        await LoadAsync();
        StateHasChanged();
    });

    private void SyncFromPlatformTenant()
    {
        _boundOrganizationId = PlatformTenant.SelectedOrganizationId;
        if (Permissions.IsPlatformAdmin)
        {
            _clinicId = PlatformTenant.SelectedClinicId;
        }
    }

    private CancellationTokenSource? _debounceCts;

    private async Task OnSearchChanged(string? value)
    {
        _search = value;
        await DebouncedReloadAsync();
    }

    private async Task OnLocalNumberChanged(string? value)
    {
        _localNumber = value;
        await DebouncedReloadAsync();
    }

    private async Task DebouncedReloadAsync()
    {
        _debounceCts?.Cancel();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;
        try
        {
            await Task.Delay(400, token);
            _page = 1;
            await LoadAsync();
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task OnSearchDebounced(string _)
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task OnClinicStatusChanged(string? value)
    {
        _clinicPatientStatus = value;
        _page = 1;
        await LoadAsync();
    }

    private async Task OnPatientActiveChanged(string? value)
    {
        _patientActiveFilter = value;
        _page = 1;
        await LoadAsync();
    }

    private async Task OnClinicFilterChanged(Guid? clinicId)
    {
        _clinicId = clinicId;
        if (Permissions.IsPlatformAdmin)
        {
            if (clinicId is Guid id && id != Guid.Empty)
            {
                if (PlatformTenant.SelectedClinicId != id)
                {
                    PlatformTenant.SelectClinic(id);
                }
            }
            else if (PlatformTenant.HasClinic)
            {
                PlatformTenant.ClearClinic();
            }
        }

        _page = 1;
        await LoadAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _search = null;
        _localNumber = null;
        _clinicPatientStatus = null;
        _patientActiveFilter = null;
        if (Permissions.CanFilterByClinic)
        {
            if (Permissions.IsPlatformAdmin)
            {
                _clinicId = PlatformTenant.SelectedClinicId;
            }
            else
            {
                _clinicId = null;
            }
        }

        _sortBy = "registeredAtUtc";
        _sortDirection = "desc";
        _page = 1;
        _pageSize = 20;
        await LoadAsync();
    }

    private async Task RefreshClicked() => await LoadAsync();

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (_disposed || !Permissions.Has(WebPermissions.PatientsSearch))
        {
            return;
        }

        if (Permissions.IsPlatformAdmin
            && (!PlatformTenant.HasOrganization || _clinicId is null || _clinicId == Guid.Empty))
        {
            _items.Clear();
            _totalCount = 0;
            _pageCount = 1;
            _loading = false;
            return;
        }

        _loadCts?.Cancel();
        _loadCts?.Dispose();
        _loadCts = new CancellationTokenSource();
        var cts = _loadCts;
        var version = Interlocked.Increment(ref _loadVersion);

        _loading = true;
        _error = null;

        try
        {
            bool? patientActive = _patientActiveFilter switch
            {
                "active" => true,
                "inactive" => false,
                _ => null,
            };

            var clinicId = Permissions.CanFilterByClinic ? _clinicId : null;
            var bypass = Permissions.IsPlatformAdmin && clinicId is not null;

            var query = StaffPatientSearchQueryBuilder.Build(
                _search,
                _localNumber,
                patientActive,
                _clinicPatientStatus,
                clinicId,
                _page,
                _pageSize,
                _sortBy,
                _sortDirection);

            var result = await PatientsApi.SearchAsync(query, bypass, cts.Token);
            if (version != _loadVersion || _disposed)
            {
                return;
            }

            _items.Clear();
            _items.AddRange(result.Items);
            _totalCount = result.TotalCount;
            _pageCount = Math.Max(1, (int)Math.Ceiling(_totalCount / (double)_pageSize));
            await PrefetchClinicLabelsAsync(_items.Select(i => i.ClinicId).Distinct(), cts.Token);
        }
        catch (OperationCanceledException)
        {
            // stale
        }
        catch (ApiProblemException ex)
        {
            if (version == _loadVersion && !_disposed)
            {
                _error = PatientProblemMessages.ToUserMessage(ex);
                _items.Clear();
            }
        }
        finally
        {
            if (version == _loadVersion)
            {
                _loading = false;
            }
        }
    }

    private async Task PrefetchClinicLabelsAsync(IEnumerable<Guid> clinicIds, CancellationToken token)
    {
        foreach (var clinicId in clinicIds)
        {
            if (_clinicLabels.ContainsKey(clinicId))
            {
                continue;
            }

            try
            {
                if (ClinicCache.TryGet(clinicId, out var cached) && cached is not null)
                {
                    _clinicLabels[clinicId] = cached.Name;
                    continue;
                }

                var detail = await ClinicsApi.GetByIdAsync(clinicId, Permissions.IsPlatformAdmin, token);
                ClinicCache.Set(detail);
                _clinicLabels[clinicId] = detail.Name;
            }
            catch
            {
                _clinicLabels[clinicId] = clinicId.ToString("D")[..8] + "…";
            }
        }
    }

    private string ClinicLabel(Guid clinicId) =>
        _clinicLabels.TryGetValue(clinicId, out var name) ? name : "—";

        private Task OnPageSizeChanged(string? value)
    {
        if (int.TryParse(value, out var size) && size > 0)
        {
            _pageSize = size;
        }
        return Task.CompletedTask;
    }

    private async Task OpenDetailAsync(Guid patientId)
    {
        if (!Permissions.Has(WebPermissions.PatientsRead))
        {
            Notify.Warning("You do not have permission to view patient details.");
            return;
        }

        var dialog = await DialogService.ShowDialogAsync<PatientDetailDialog>(
            new PatientDetailDialog.Args
            {
                PatientId = patientId,
                PlatformAdminBypass = Permissions.IsPlatformAdmin,
            },
            FluentDialogDefaults.ContentOnly("Patient", "560px"));
        var result = await dialog.Result;
        if (!result.Cancelled)
        {
            await LoadAsync();
        }

        if (PatientId is not null)
        {
            Navigation.NavigateTo("/patients", replace: true);
        }
    }
}
