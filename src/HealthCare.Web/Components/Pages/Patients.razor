@page "/patients"
@page "/patients/{PatientId:guid}"
@attribute [Authorize]
@using HealthCare.Contracts.Patients
@using HealthCare.Web.Patients
@using HealthCare.Web.Components.Patients
@using HealthCare.Web.Components.Clinics
@implements IDisposable
@inject IStaffPatientApiClient PatientsApi
@inject IPermissionState Permissions
@inject IPlatformTenantContext PlatformTenant
@inject IClinicWorkingContext ClinicContext
@inject IUiModalService Modals
@inject IUserNotificationService Notify
@inject IClinicDirectoryCache ClinicCache
@inject IClinicDirectoryApiClient ClinicsApi
@inject NavigationManager Navigation

<PageTitle>Patient Directory</PageTitle>

@if (Permissions.IsPatientOnly)
{
    <Alert Type="@AlertType.Error" Message="Patient accounts cannot use the staff patient directory." ShowIcon="true" />
}
else if (!Permissions.Has(WebPermissions.PatientsSearch))
{
    <PermissionDeniedState Message="You do not have permission to search patients." />
}
else
{
    <HcPageHeader Title="Patient Directory"
                  Subtitle="Organization patient search and clinic enrollment">
        <Breadcrumb>
            <Breadcrumb>
                <BreadcrumbItem Href="/dashboard">Home</BreadcrumbItem>
                <BreadcrumbItem>Patients</BreadcrumbItem>
            </Breadcrumb>
        </Breadcrumb>
        <ChildContent>
            <Space>
                <Button OnClick="ResetFiltersAsync" Disabled="_loading" AriaLabel="Reset patient filters">Reset</Button>
                <Button OnClick="RefreshClicked" Disabled="_loading" AriaLabel="Refresh patient list">
                    <Icon Type="reload" Theme="IconThemeType.Outline" /> Refresh
                </Button>
            </Space>
        </ChildContent>
    </HcPageHeader>

    @if (Permissions.IsPlatformAdmin && !PlatformTenant.HasOrganization)
    {
        <Alert Type="@AlertType.Info"
               Message="Select an organization in the platform banner before searching patients. Global patient search is not allowed."
               ShowIcon="true"
               Style="margin-bottom:1rem;" />
    }
    else if (Permissions.IsPlatformAdmin && !PlatformTenant.HasClinic)
    {
        <Alert Type="@AlertType.Info"
               Message="Select a clinic in the platform banner (or below) before loading patients for the selected organization."
               ShowIcon="true"
               Style="margin-bottom:1rem;" />
    }

    <div class="hc-card">
        <div class="hc-filter-grid">
            <div>
                <label class="hc-filter-label" for="patients-search">Search</label>
                <Input Id="patients-search" @bind-Value="_search" @bind-Value:after="DebouncedReloadAsync" Disabled="_loading" Style="width:100%;" />
            </div>
            <div>
                <label class="hc-filter-label" for="patients-local">Local patient number</label>
                <Input Id="patients-local" @bind-Value="_localNumber" @bind-Value:after="DebouncedReloadAsync" Disabled="_loading" Style="width:100%;" />
            </div>
            <div>
                <label class="hc-filter-label" for="patients-enrollment">Enrollment status</label>
                <Select Id="patients-enrollment" TItemValue="string" TItem="string" Value="_clinicPatientStatus" ValueChanged="OnClinicStatusChanged" Style="width:100%;" AllowClear>
                    <SelectOptions>
                        @foreach (var status in PatientStatusPresentation.ClinicPatientStatuses)
                        {
                            <SelectOption TItemValue="string" TItem="string" Value="@status" Label="@status" />
                        }
                    </SelectOptions>
                </Select>
            </div>
            <div>
                <label class="hc-filter-label" for="patients-active">Patient status</label>
                <Select Id="patients-active" TItemValue="string" TItem="string" Value="_patientActiveFilter" ValueChanged="OnPatientActiveChanged" Style="width:100%;" AllowClear>
                    <SelectOptions>
                        <SelectOption TItemValue="string" TItem="string" Value="@("active")" Label="Active" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("inactive")" Label="Inactive" />
                    </SelectOptions>
                </Select>
            </div>
            @if (Permissions.CanFilterByClinic)
            {
                <ClinicPicker Value="_clinicId" ValueChanged="OnClinicFilterChanged" Label="Clinic filter"
                              HelperText="@(Permissions.IsPlatformAdmin ? "Required for PLATFORM_ADMIN" : "Leave empty for all clinics in your organization")"
                              AllowClear="@(!Permissions.IsPlatformAdmin)" Required="@(Permissions.IsPlatformAdmin)" ActiveOnly="null"
                              PlatformAdminBypass="@(Permissions.IsPlatformAdmin)"
                              PlatformOrganizationId="@(Permissions.IsPlatformAdmin ? PlatformTenant.SelectedOrganizationId : null)"
                              Disabled="@(Permissions.IsPlatformAdmin && !PlatformTenant.HasOrganization)" />
            }
            else if (Permissions.Has(WebPermissions.ClinicsRead))
            {
                <ClinicPicker Label="Clinic" AllowClear="false" Required="false" Disabled="true" />
            }
            <div>
                <label class="hc-filter-label" for="patients-sort">Sort by</label>
                <Select Id="patients-sort" TItemValue="string" TItem="string" @bind-Value="_sortBy" Style="width:100%;">
                    <SelectOptions>
                        <SelectOption TItemValue="string" TItem="string" Value="@("registeredAtUtc")" Label="Enrollment date" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("localPatientNumber")" Label="Local number" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("lastName")" Label="Last name" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("firstName")" Label="First name" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("clinicPatientStatus")" Label="Enrollment status" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("patientIsActive")" Label="Patient status" />
                    </SelectOptions>
                </Select>
            </div>
            <div>
                <label class="hc-filter-label" for="patients-dir">Direction</label>
                <Select Id="patients-dir" TItemValue="string" TItem="string" @bind-Value="_sortDirection" Style="width:100%;">
                    <SelectOptions>
                        <SelectOption TItemValue="string" TItem="string" Value="@("desc")" Label="Descending" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("asc")" Label="Ascending" />
                    </SelectOptions>
                </Select>
            </div>
            <div style="display:flex;gap:8px;align-items:flex-end;">
                <Button Type="@ButtonType.Primary" OnClick="ApplyFiltersAsync"
                        Disabled="@(Permissions.IsPlatformAdmin && (!PlatformTenant.HasOrganization || !_clinicId.HasValue))"
                        AriaLabel="Search patients">
                    Search
                </Button>
                <Button OnClick="ResetFiltersAsync" Disabled="_loading" AriaLabel="Reset filters">Reset</Button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error)) { <ErrorState Message="@_error" /> }
    @if (_loading) { <PageLoading /> }
    else if (_items.Count == 0) { <EmptyState Title="No patients found" Message="No patients match the current filters." /> }
    else
    {
        <div class="hc-table-wrap">
            <table class="hc-table">
                <thead>
                    <tr>
                        <th>Patient No.</th>
                        <th>Name</th>
                        <th>Contact</th>
                        <th>Clinic</th>
                        <th>Status</th>
                        <th>Updated</th>
                        <th class="hc-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in _items)
                {
                    <tr>
                        <td>@row.LocalPatientNumber</td>
                        <td>@PatientDisplay.FullName(row)</td>
                        <td>@PatientDisplay.MaskMobile(row.MobileNumber)</td>
                        <td>@ClinicLabel(row.ClinicId)</td>
                        <td>
                            <StatusBadge Text="@PatientStatusPresentation.ClinicPatientLabel(row.ClinicPatientStatus)"
                                         Tone="@PatientStatusPresentation.ClinicPatientTone(row.ClinicPatientStatus)" />
                            @if (!row.PatientIsActive)
                            {
                                <div class="hc-caption">Patient inactive</div>
                            }
                        </td>
                        <td><span class="hc-caption">@row.RegisteredAtUtc.ToString("u")</span></td>
                        <td class="hc-actions">
                            <div class="hc-table-actions">
                                <Space Wrap>
                                    @if (Permissions.Has(WebPermissions.PatientsRead))
                                    {
                                        <Button Type="@ButtonType.Link"
                                                OnClick="@(() => OpenDetailAsync(row))"
                                                AriaLabel="@($"Details for {PatientDisplay.FullName(row)}")">
                                            Details
                                        </Button>
                                    }
                                    @if (Permissions.Has(WebPermissions.PatientsUpdateClinicStatus)
                                         && (Permissions.IsOrganizationAdmin || Permissions.IsPlatformAdmin))
                                    {
                                        <Button Type="@ButtonType.Link"
                                                Class="hc-action-wide"
                                                OnClick="@(() => OpenEnrollFromRowAsync(row))"
                                                AriaLabel="@($"Enroll {PatientDisplay.FullName(row)}")">
                                            Enroll
                                        </Button>
                                    }
                                </Space>
                                <Dropdown Class="hc-action-narrow">
                                    <Overlay>
                                        <Menu>
                                            @if (Permissions.Has(WebPermissions.PatientsRead))
                                            {
                                                <MenuItem OnClick="@(() => OpenDetailAsync(row))">Details</MenuItem>
                                            }
                                            @if (Permissions.Has(WebPermissions.PatientsUpdateClinicStatus)
                                                 && (Permissions.IsOrganizationAdmin || Permissions.IsPlatformAdmin))
                                            {
                                                <MenuItem OnClick="@(() => OpenEnrollFromRowAsync(row))">Enroll in clinic</MenuItem>
                                            }
                                        </Menu>
                                    </Overlay>
                                    <ChildContent>
                                        <Button Type="@ButtonType.Link" AriaLabel="@($"More actions for {PatientDisplay.FullName(row)}")">More</Button>
                                    </ChildContent>
                                </Dropdown>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            <div class="hc-pager">
                <span class="hc-caption">Total: @_totalCount</span>
                <Space>
                    <Button Disabled="@(_page <= 1 || _loading)" OnClick="@(() => OnPageChanged(_page - 1))" AriaLabel="Previous page">Prev</Button>
                    <span class="hc-caption">Page @_page / @_pageCount</span>
                    <Button Disabled="@(_page >= _pageCount || _loading)" OnClick="@(() => OnPageChanged(_page + 1))" AriaLabel="Next page">Next</Button>
                </Space>
            </div>
        </div>
    }

    <PatientDetailDrawer @ref="_detailDrawer" OnChanged="OnDetailChangedAsync" />
}

@code {
    [Parameter]
    public Guid? PatientId { get; set; }

    private readonly List<StaffPatientSummaryResponse> _items = [];
    private readonly Dictionary<Guid, string> _clinicLabels = new();
    private CancellationTokenSource? _loadCts;
    private int _loadVersion;
    private bool _loading;
    private string? _error;
    private string? _search;
    private string? _localNumber;
    private string? _clinicPatientStatus;
    private string? _patientActiveFilter;
    private Guid? _clinicId;
    private string _sortBy = "registeredAtUtc";
    private string _sortDirection = "desc";
    private int _page = 1;
    private int _pageSize = 20;
    private int _totalCount;
    private int _pageCount = 1;
    private Guid? _boundOrganizationId;
    private bool _disposed;
    private bool _subscribedPlatform;
    private bool _subscribedClinic;
    private PatientDetailDrawer? _detailDrawer;
    private CancellationTokenSource? _debounceCts;

    protected override async Task OnInitializedAsync()
    {
        if (Permissions.IsPatientOnly || !Permissions.Has(WebPermissions.PatientsSearch))
        {
            return;
        }

        if (Permissions.IsPlatformAdmin)
        {
            PlatformTenant.Changed += OnPlatformTenantChanged;
            _subscribedPlatform = true;
            SyncFromPlatformTenant();
        }
        else if (Permissions.IsOrganizationAdmin)
        {
            ClinicContext.Changed += OnClinicContextChanged;
            _subscribedClinic = true;
            if (ClinicContext.HasClinic)
            {
                _clinicId = ClinicContext.SelectedClinicId;
            }
        }

        await LoadAsync();

        if (PatientId is Guid id && Permissions.Has(WebPermissions.PatientsRead))
        {
            await OpenDetailByIdAsync(id, preferredClinicId: _clinicId);
        }
    }

    public void Dispose()
    {
        _disposed = true;
        if (_subscribedPlatform)
        {
            PlatformTenant.Changed -= OnPlatformTenantChanged;
        }

        if (_subscribedClinic)
        {
            ClinicContext.Changed -= OnClinicContextChanged;
        }

        _loadCts?.Cancel();
        _loadCts?.Dispose();
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _items.Clear();
        _clinicLabels.Clear();
    }

    private void OnPlatformTenantChanged() => InvokeAsync(async () =>
    {
        var orgChanged = _boundOrganizationId != PlatformTenant.SelectedOrganizationId;
        SyncFromPlatformTenant();
        if (orgChanged)
        {
            _items.Clear();
            _clinicLabels.Clear();
            _error = null;
            _search = null;
            _localNumber = null;
        }

        _loadCts?.Cancel();
        await LoadAsync();
        StateHasChanged();
    });

    private void OnClinicContextChanged() => InvokeAsync(async () =>
    {
        _clinicId = ClinicContext.SelectedClinicId;
        await LoadAsync();
        StateHasChanged();
    });

    private void SyncFromPlatformTenant()
    {
        _boundOrganizationId = PlatformTenant.SelectedOrganizationId;
        if (Permissions.IsPlatformAdmin)
        {
            _clinicId = PlatformTenant.SelectedClinicId;
        }
    }

    private async Task DebouncedReloadAsync()
    {
        _debounceCts?.Cancel();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;
        try
        {
            await Task.Delay(400, token);
            _page = 1;
            await LoadAsync();
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task OnClinicStatusChanged(string? value)
    {
        _clinicPatientStatus = value;
        _page = 1;
        await LoadAsync();
    }

    private async Task OnPatientActiveChanged(string? value)
    {
        _patientActiveFilter = value;
        _page = 1;
        await LoadAsync();
    }

    private async Task OnClinicFilterChanged(Guid? clinicId)
    {
        _clinicId = clinicId;

        if (Permissions.IsPlatformAdmin)
        {
            if (clinicId is Guid id && id != Guid.Empty)
            {
                if (PlatformTenant.SelectedClinicId != id)
                {
                    PlatformTenant.SelectClinic(id);
                }
            }
            else if (PlatformTenant.HasClinic)
            {
                PlatformTenant.ClearClinic();
            }

            _page = 1;
            await LoadAsync();
            return;
        }

        if (Permissions.IsOrganizationAdmin)
        {
            if (clinicId is Guid id && id != Guid.Empty)
            {
                ClinicContext.SelectClinic(id);
            }
            else
            {
                ClinicContext.ClearClinic();
            }

            return;
        }

        _page = 1;
        await LoadAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task ResetFiltersAsync()
    {
        _search = null;
        _localNumber = null;
        _clinicPatientStatus = null;
        _patientActiveFilter = null;
        if (Permissions.CanFilterByClinic)
        {
            if (Permissions.IsPlatformAdmin)
            {
                _clinicId = PlatformTenant.SelectedClinicId;
            }
            else if (_subscribedClinic && ClinicContext.HasClinic)
            {
                ClinicContext.ClearClinic();
                _sortBy = "registeredAtUtc";
                _sortDirection = "desc";
                _page = 1;
                _pageSize = 20;
                return;
            }
            else
            {
                _clinicId = null;
            }
        }

        _sortBy = "registeredAtUtc";
        _sortDirection = "desc";
        _page = 1;
        _pageSize = 20;
        await LoadAsync();
    }

    private async Task RefreshClicked() => await LoadAsync();

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (_disposed || !Permissions.Has(WebPermissions.PatientsSearch))
        {
            return;
        }

        if (Permissions.IsPlatformAdmin
            && (!PlatformTenant.HasOrganization || _clinicId is null || _clinicId == Guid.Empty))
        {
            _items.Clear();
            _totalCount = 0;
            _pageCount = 1;
            _loading = false;
            return;
        }

        _loadCts?.Cancel();
        _loadCts?.Dispose();
        _loadCts = new CancellationTokenSource();
        var cts = _loadCts;
        var version = Interlocked.Increment(ref _loadVersion);

        _loading = true;
        _error = null;

        try
        {
            bool? patientActive = _patientActiveFilter switch
            {
                "active" => true,
                "inactive" => false,
                _ => null,
            };

            var clinicId = Permissions.CanFilterByClinic ? _clinicId : null;
            var bypass = Permissions.IsPlatformAdmin && clinicId is not null;

            var query = StaffPatientSearchQueryBuilder.Build(
                _search,
                _localNumber,
                patientActive,
                _clinicPatientStatus,
                clinicId,
                _page,
                _pageSize,
                _sortBy,
                _sortDirection);

            var result = await PatientsApi.SearchAsync(query, bypass, cts.Token);
            if (version != _loadVersion || _disposed)
            {
                return;
            }

            _items.Clear();
            _items.AddRange(result.Items);
            _totalCount = result.TotalCount;
            _pageCount = Math.Max(1, (int)Math.Ceiling(_totalCount / (double)_pageSize));
            await PrefetchClinicLabelsAsync(_items.Select(i => i.ClinicId).Distinct(), cts.Token);
        }
        catch (OperationCanceledException)
        {
            // stale
        }
        catch (ApiProblemException ex)
        {
            if (version == _loadVersion && !_disposed)
            {
                _error = PatientProblemMessages.ToUserMessage(ex);
                _items.Clear();
            }
        }
        finally
        {
            if (version == _loadVersion)
            {
                _loading = false;
            }
        }
    }

    private async Task PrefetchClinicLabelsAsync(IEnumerable<Guid> clinicIds, CancellationToken token)
    {
        foreach (var clinicId in clinicIds)
        {
            if (_clinicLabels.ContainsKey(clinicId))
            {
                continue;
            }

            try
            {
                if (ClinicCache.TryGet(clinicId, out var cached) && cached is not null)
                {
                    _clinicLabels[clinicId] = cached.Name;
                    continue;
                }

                var detail = await ClinicsApi.GetByIdAsync(clinicId, Permissions.IsPlatformAdmin, token);
                ClinicCache.Set(detail);
                _clinicLabels[clinicId] = detail.Name;
            }
            catch
            {
                _clinicLabels[clinicId] = clinicId.ToString("D")[..8] + "…";
            }
        }
    }

    private string ClinicLabel(Guid clinicId) =>
        _clinicLabels.TryGetValue(clinicId, out var name) ? name : "—";

    private Task OnDetailChangedAsync() => LoadAsync();

    private async Task OpenDetailAsync(StaffPatientSummaryResponse row) =>
        await OpenDetailByIdAsync(row.PatientId, row.ClinicId);

    private async Task OpenDetailByIdAsync(Guid patientId, Guid? preferredClinicId)
    {
        if (!Permissions.Has(WebPermissions.PatientsRead))
        {
            Notify.Warning("You do not have permission to view patient details.");
            return;
        }

        if (_detailDrawer is not null)
        {
            await _detailDrawer.OpenAsync(
                patientId,
                preferredClinicId,
                platformAdminBypass: Permissions.IsPlatformAdmin);
        }

        if (PatientId is not null)
        {
            Navigation.NavigateTo("/patients", replace: true);
        }
    }

    private async Task OpenEnrollFromRowAsync(StaffPatientSummaryResponse row)
    {
        if (!Permissions.Has(WebPermissions.PatientsUpdateClinicStatus))
        {
            Notify.Warning("You do not have permission to enroll patients.");
            return;
        }

        HashSet<Guid> enrolled;
        try
        {
            Guid? detailClinicId = Permissions.IsPlatformAdmin ? row.ClinicId : null;
            var detail = await PatientsApi.GetByIdAsync(
                row.PatientId,
                clinicId: detailClinicId,
                platformAdminBypass: Permissions.IsPlatformAdmin);
            enrolled = detail.Enrollments.Select(e => e.ClinicId).ToHashSet();
            if (enrolled.Count == 0)
            {
                enrolled.Add(row.ClinicId);
            }
        }
        catch (ApiProblemException ex)
        {
            Notify.Error(PatientProblemMessages.ToUserMessage(ex));
            return;
        }

        if (await Modals.ShowAsync<EnrollPatientDialog, EnrollPatientDialog.Args>(
                "Enroll in clinic",
                new EnrollPatientDialog.Args
                {
                    PatientId = row.PatientId,
                    PatientDisplayName = PatientDisplay.FullName(row),
                    AlreadyEnrolledClinicIds = enrolled,
                    PlatformAdminBypass = Permissions.IsPlatformAdmin,
                }))
        {
            Notify.Success("Patient enrolled in clinic.");
            await LoadAsync();
        }
    }
}
