@page "/logout"
@layout EmptyLayout
@attribute [AllowAnonymous]

<PageTitle>Signing out</PageTitle>

<div class="hc-auth-shell">
    <div class="hc-auth-container">
        <div class="hc-auth-card">
            <h1 class="hc-auth-brand" style="font-size:18px">Signing out…</h1>
            <p class="hc-auth-sub">Please wait while we end your session securely.</p>
            <form id="bff-logout-form" method="post" action="/bff/auth/logout" data-enhance="false">
                <AntiforgeryToken />
                <noscript>
                    <Button Type="@ButtonType.Primary" HtmlType="submit" Class="hc-auth-submit" Block>
                        Confirm sign out
                    </Button>
                </noscript>
            </form>
        </div>
    </div>
</div>

<script>
    (function () {
        var form = document.getElementById('bff-logout-form');
        if (form) { form.submit(); }
    })();
</script>
