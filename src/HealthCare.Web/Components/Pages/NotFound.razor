@page "/not-found"
@layout EmptyLayout

<PageTitle>Not found</PageTitle>

<div class="hc-auth-shell">
    <div class="hc-auth-container">
        <div class="hc-auth-card" style="text-align:center;">
            <Empty Description="@("Page not found")">
                <Button Type="@ButtonType.Primary" OnClick="GoDashboard">
                    Go to dashboard
                </Button>
            </Empty>
        </div>
    </div>
</div>

@code {
    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private void GoDashboard() => Navigation.NavigateTo("/dashboard");
}
