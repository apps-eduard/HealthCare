@page "/not-found"
@layout EmptyLayout

<PageTitle>Not found</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Class="pa-6" Elevation="0">
        <MudText Typo="Typo.h4" GutterBottom="true">Page not found</MudText>
        <MudText Class="mb-4">The page you requested does not exist.</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/dashboard">Go to dashboard</MudButton>
    </MudPaper>
</MudContainer>
