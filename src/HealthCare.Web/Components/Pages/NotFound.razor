@page "/not-found"
@layout EmptyLayout

<PageTitle>Not found</PageTitle>

<div class="hc-auth-shell">
    <div class="hc-auth-container">
        <div class="hc-auth-card">
            <h1 class="hc-auth-brand" style="font-size:1.5rem">Page not found</h1>
            <p class="hc-auth-sub">The page you requested does not exist.</p>
            <FluentButton Appearance="Appearance.Accent" Href="/dashboard" Class="hc-auth-submit">Go to dashboard</FluentButton>
        </div>
    </div>
</div>
