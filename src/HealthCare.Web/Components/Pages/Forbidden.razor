@page "/forbidden"
@attribute [Authorize]

<PageTitle>Access denied</PageTitle>

<HcPageHeader Title="Access denied" Subtitle="You do not have permission to view this page." />

@if (Permissions.IsPatientOnly)
{
    <Alert Type="@AlertType.Error"
           Message="Patient accounts cannot use the staff console. Sign out and use the patient experience instead."
           ShowIcon="true"
           Style="margin-bottom:16px;" />
}
else
{
    <Alert Type="@AlertType.Warning"
           Message="Your account is signed in, but this page requires additional staff permissions."
           ShowIcon="true"
           Style="margin-bottom:16px;" />
}

<Space>
    <Button Type="@ButtonType.Primary" OnClick='() => Navigation.NavigateTo("/dashboard")'>Dashboard</Button>
    <Button OnClick="SignOutAsync">Sign out</Button>
</Space>

@code {
    [Inject]
    private IPermissionState Permissions { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private Task SignOutAsync()
    {
        Navigation.NavigateTo("/logout", forceLoad: true);
        return Task.CompletedTask;
    }
}
