@page "/forbidden"
@attribute [Authorize]

<PageTitle>Access denied</PageTitle>

<FluentCard Class="hc-card" Style="margin:1rem;padding:2rem;">
    <h1 class="hc-page-title">Access denied</h1>
    <p class="hc-page-subtitle" style="margin-bottom:1rem;">
        You do not have permission to view this page.
    </p>
    @if (Permissions.IsPatientOnly)
    {
        <FluentMessageBar Intent="MessageIntent.Warning" AllowDismiss="false" Class="mb-4">
            Patient accounts cannot use the staff application.
        </FluentMessageBar>
        <FluentButton Appearance="Appearance.Accent" OnClick="SignOutAsync">Sign out</FluentButton>
    }
    else
    {
        <FluentButton Appearance="Appearance.Accent" Href="/dashboard">Back to dashboard</FluentButton>
    }
</FluentCard>

@code {
    [Inject]
    private IPermissionState Permissions { get; set; } = default!;

    [Inject]
    private StaffAuthenticationStateProvider AuthState { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private async Task SignOutAsync()
    {
        await AuthState.MarkLoggedOutAsync(callRemoteLogout: true);
        Navigation.NavigateTo("/logout", forceLoad: true);
    }
}
