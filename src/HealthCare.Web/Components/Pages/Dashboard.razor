@page "/"
@page "/dashboard"
@attribute [Authorize]
@inject IPermissionState Permissions
@inject NavigationManager Navigation

<PageTitle>Dashboard</PageTitle>

@if (Permissions.IsPatientOnly)
{
    <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false">
        Patient accounts cannot use the staff application.
    </FluentMessageBar>
}
else if (!Permissions.IsStaffUser)
{
    <FluentMessageBar Intent="MessageIntent.Warning" AllowDismiss="false">
        An active staff membership is required.
    </FluentMessageBar>
}
else
{
    <PageHeader Title="Dashboard"
                Subtitle="@($"Welcome{(string.IsNullOrWhiteSpace(Permissions.CurrentUser?.Email) ? "" : $", {Permissions.CurrentUser!.Email}")}.")" />

    <FluentCard Class="hc-card">
        <h2 class="hc-caption" style="margin-top:0;font-weight:600;text-transform:uppercase;letter-spacing:0.04em;">Session context</h2>
        <p>Organization: @(Permissions.CurrentUser?.OrganizationId?.ToString("D") ?? "—")</p>
        <p>Clinic: @(Permissions.CurrentUser?.ClinicId?.ToString("D") ?? "—")</p>
        <p>Roles: @string.Join(", ", Permissions.CurrentUser?.Roles ?? [])</p>
        <p>Staff membership: @(Permissions.CurrentUser?.HasActiveStaffMembership == true ? "Active" : "None")</p>
    </FluentCard>

    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Wrap="true">
        @if (Permissions.Has(WebPermissions.AppointmentsRead))
        {
            <FluentButton Appearance="Appearance.Accent" Href="/appointments" IconStart="@(new Icons.Regular.Size20.CalendarLtr())">
                Appointments
            </FluentButton>
        }
        @if (Permissions.Has(WebPermissions.PatientsSearch))
        {
            <FluentButton Appearance="Appearance.Accent" Href="/patients" IconStart="@(new Icons.Regular.Size20.People())">
                Patients
            </FluentButton>
        }
        @if (AvailabilityPermissionRules.CanManage(Permissions))
        {
            <FluentButton Appearance="Appearance.Accent" Href="/availability" IconStart="@(new Icons.Regular.Size20.Clock())">
                Availability
            </FluentButton>
        }
        @if (Permissions.Has(WebPermissions.StaffRead))
        {
            <FluentButton Appearance="Appearance.Accent" Href="/staff" IconStart="@(new Icons.Regular.Size20.PeopleTeam())">
                Staff Management
            </FluentButton>
        }
    </FluentStack>
}

@code {
    protected override void OnInitialized()
    {
        if (Permissions.IsPatientOnly)
        {
            return;
        }

        if (!Permissions.IsStaffUser)
        {
            Navigation.NavigateTo("/forbidden");
        }
    }
}
