@page "/"
@page "/dashboard"
@attribute [Authorize]
@inject IPermissionState Permissions
@inject NavigationManager Navigation

<PageTitle>Dashboard</PageTitle>

@if (Permissions.IsPatientOnly)
{
    <Alert Type="@AlertType.Error"
           Message="Patient accounts cannot use the staff application."
           ShowIcon="true" />
}
else if (!Permissions.IsStaffUser)
{
    <Alert Type="@AlertType.Warning"
           Message="An active staff membership is required."
           ShowIcon="true" />
}
else
{
    <HcPageHeader Title="Dashboard"
                Subtitle="@($"Welcome{(string.IsNullOrWhiteSpace(Permissions.CurrentUser?.Email) ? "" : $", {Permissions.CurrentUser!.Email}")}.")">
        <Breadcrumb>
            <Breadcrumb>
                <BreadcrumbItem>Home</BreadcrumbItem>
                <BreadcrumbItem>Dashboard</BreadcrumbItem>
            </Breadcrumb>
        </Breadcrumb>
    </HcPageHeader>

    <div class="hc-card">
        <div class="hc-caption" style="margin-bottom:8px;font-weight:600;text-transform:uppercase;letter-spacing:0.04em;">Session context</div>
        <p>Organization: @(Permissions.CurrentUser?.OrganizationId?.ToString("D") ?? "—")</p>
        <p>Clinic: @(Permissions.CurrentUser?.ClinicId?.ToString("D") ?? "—")</p>
        <p>Roles: @string.Join(", ", Permissions.CurrentUser?.Roles ?? [])</p>
        <p>Staff membership: @(Permissions.CurrentUser?.HasActiveStaffMembership == true ? "Active" : "None")</p>
    </div>

    <Space Wrap>
        @if (Permissions.Has(WebPermissions.AppointmentsRead))
        {
            <Button Type="@ButtonType.Primary" OnClick='() => Navigation.NavigateTo("/appointments")'>
                <Icon Type="calendar" Theme="IconThemeType.Outline" /> Appointments
            </Button>
        }
        @if (Permissions.Has(WebPermissions.PatientsSearch))
        {
            <Button Type="@ButtonType.Primary" OnClick='() => Navigation.NavigateTo("/patients")'>
                <Icon Type="team" Theme="IconThemeType.Outline" /> Patients
            </Button>
        }
        @if (AvailabilityPermissionRules.CanManage(Permissions))
        {
            <Button Type="@ButtonType.Primary" OnClick='() => Navigation.NavigateTo("/availability")'>
                <Icon Type="clock-circle" Theme="IconThemeType.Outline" /> Availability
            </Button>
        }
        @if (Permissions.Has(WebPermissions.StaffRead))
        {
            <Button Type="@ButtonType.Primary" OnClick='() => Navigation.NavigateTo("/staff")'>
                <Icon Type="user" Theme="IconThemeType.Outline" /> Staff Management
            </Button>
        }
    </Space>
}

@code {
    protected override void OnInitialized()
    {
        if (Permissions.IsPatientOnly)
        {
            return;
        }

        if (!Permissions.IsStaffUser)
        {
            Navigation.NavigateTo("/forbidden");
        }
    }
}
