@page "/staff"
@page "/staff/clinic-admins"
@attribute [Authorize]
@implements IDisposable
@inject IStaffManagementApiClient StaffApi
@inject IPermissionState Permissions
@inject IPlatformTenantContext PlatformTenant
@inject IUiModalService Modals
@inject IUserNotificationService Notify
@inject NavigationManager Navigation
@inject StaffAuthenticationStateProvider AuthState

<PageTitle>Staff Management</PageTitle>

@if (!Permissions.Has(WebPermissions.StaffRead))
{
    <PermissionDeniedState Message="You do not have permission to view staff." />
}
else
{
    <HcPageHeader Title="Staff Management"
                  Subtitle="Manage organization staff, Clinic Admins, and clinical roles">
        <Button OnClick="RefreshClicked" Disabled="_loading">
            <Icon Type="reload" Theme="IconThemeType.Outline" /> Refresh
        </Button>
        @if (Permissions.Has(WebPermissions.StaffManage))
        {
            <Button Type="@ButtonType.Primary"
                    OnClick="OpenCreateAsync"
                    Disabled="@(Permissions.IsPlatformAdmin && (!PlatformTenant.HasOrganization || !PlatformTenant.HasClinic))">
                <Icon Type="user-add" Theme="IconThemeType.Outline" /> Create Staff
            </Button>
        }
    </HcPageHeader>

    @if (Permissions.IsPlatformAdmin && !PlatformTenant.HasOrganization)
    {
        <Alert Type="@AlertType.Info"
               Message="Select an organization in the platform banner before searching staff. Global staff search is not allowed."
               ShowIcon="true"
               Style="margin-bottom:1rem;" />
    }
    else if (Permissions.IsPlatformAdmin && !PlatformTenant.HasClinic)
    {
        <Alert Type="@AlertType.Info"
               Message="Select a clinic in the platform banner (or below) before loading staff for the selected organization."
               ShowIcon="true"
               Style="margin-bottom:1rem;" />
    }

    <Tabs ActiveKey="@_activeTab" OnChange="OnTabChanged">
        <TabPane Tab="All Staff" Key="all" />
        <TabPane Tab="Clinic Admins" Key="clinic-admins" />
        <TabPane Tab="Doctors" Key="doctors" />
        <TabPane Tab="Nurses" Key="nurses" />
        <TabPane Tab="Receptionists" Key="receptionists" />
    </Tabs>

    <div class="hc-card" style="margin-top:0.75rem;">
        <div class="hc-filter-grid">
            <div>
                <span class="hc-filter-label">Search</span>
                <Input @bind-Value="_search" Disabled="_loading" Style="width:100%;" @onkeyup="OnSearchKeyUp" />
            </div>
            @if (_activeTab == "all")
            {
                <div>
                    <span class="hc-filter-label">Role</span>
                    <Select TItemValue="string" TItem="string" @bind-Value="_role" Style="width:100%;" AllowClear>
                        <SelectOptions>
                            @foreach (var role in _roleOptions)
                            {
                                <SelectOption TItemValue="string" TItem="string" Value="@role" Label="@role" />
                            }
                        </SelectOptions>
                    </Select>
                </div>
            }
            <div>
                <span class="hc-filter-label">Status</span>
                <Select TItemValue="string" TItem="string" @bind-Value="_activeFilter" Style="width:100%;" AllowClear>
                    <SelectOptions>
                        <SelectOption TItemValue="string" TItem="string" Value="@("active")" Label="Active" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("inactive")" Label="Inactive" />
                    </SelectOptions>
                </Select>
            </div>
            @if (Permissions.CanFilterByClinic)
            {
                <ClinicPicker Value="_clinicId"
                              ValueChanged="OnClinicFilterChanged"
                              Label="Clinic filter"
                              HelperText="@(Permissions.IsPlatformAdmin ? "Required for PLATFORM_ADMIN" : "Leave empty for all clinics in your organization")"
                              AllowClear="@(!Permissions.IsPlatformAdmin)"
                              Required="@(Permissions.IsPlatformAdmin)"
                              ActiveOnly="null"
                              PlatformAdminBypass="@(Permissions.IsPlatformAdmin)"
                              PlatformOrganizationId="@(Permissions.IsPlatformAdmin ? PlatformTenant.SelectedOrganizationId : null)"
                              Disabled="@(Permissions.IsPlatformAdmin && !PlatformTenant.HasOrganization)" />
            }
            else if (Permissions.Has(WebPermissions.ClinicsRead))
            {
                <ClinicPicker Label="Clinic" AllowClear="false" Required="false" />
            }
            <div style="display:flex;gap:8px;align-items:flex-end;">
                <Button Type="@ButtonType.Primary" OnClick="RefreshClicked"
                        Disabled="@(Permissions.IsPlatformAdmin && (!PlatformTenant.HasOrganization || !_clinicId.HasValue))">
                    Search
                </Button>
                <Button OnClick="ResetFiltersAsync" Disabled="_loading">Reset</Button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <ErrorState Message="@_error" />
    }

    @if (_loading)
    {
        <PageLoading />
    }
    else if (_items.Count == 0)
    {
        <EmptyState Message="No staff members matched your filters." />
    }
    else
    {
        <div class="hc-table-wrap">
            <table class="hc-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Clinic</th>
                        <th>Role</th>
                        <th>Job Title</th>
                        <th>Status</th>
                        <th>Last Updated</th>
                        <th class="hc-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _items)
                    {
                        <tr>
                            <td>@DisplayName(row)</td>
                            <td>@row.Email</td>
                            <td>@(row.ClinicName ?? row.ClinicId.ToString())</td>
                            <td><StatusBadge Text="@row.Role" Tone="StatusTone.Neutral" /></td>
                            <td>@(row.JobTitle ?? "—")</td>
                            <td>
                                <StatusBadge Text="@(row.MembershipIsActive ? "Active" : "Inactive")"
                                             Tone="@(row.MembershipIsActive ? StatusTone.Success : StatusTone.Default)" />
                            </td>
                            <td><span class="hc-caption">@row.UpdatedAtUtc.ToString("u")</span></td>
                            <td class="hc-actions">
                                <Button Type="@ButtonType.Text" OnClick="@(() => OpenDetailAsync(row))" AriaLabel="Details">
                                    <Icon Type="eye" Theme="IconThemeType.Outline" />
                                </Button>
                                @if (Permissions.Has(WebPermissions.StaffManage))
                                {
                                    <Button Type="@ButtonType.Text" OnClick="@(() => OpenEditAsync(row))" AriaLabel="Edit">
                                        <Icon Type="edit" Theme="IconThemeType.Outline" />
                                    </Button>
                                    @if (row.MembershipIsActive)
                                    {
                                        <Button Type="@ButtonType.Text" OnClick="@(() => OpenActivationAsync(row, activate: false))" AriaLabel="Deactivate">
                                            <Icon Type="stop" Theme="IconThemeType.Outline" />
                                        </Button>
                                    }
                                    else
                                    {
                                        <Button Type="@ButtonType.Text" OnClick="@(() => OpenActivationAsync(row, activate: true))" AriaLabel="Activate">
                                            <Icon Type="check" Theme="IconThemeType.Outline" />
                                        </Button>
                                    }
                                    @if (CanChangeClinic(row))
                                    {
                                        <Button Type="@ButtonType.Text" OnClick="@(() => OpenChangeClinicAsync(row))" AriaLabel="Change clinic">
                                            <Icon Type="swap" Theme="IconThemeType.Outline" />
                                        </Button>
                                    }
                                }
                                @if (Permissions.Has(WebPermissions.RolesAssign))
                                {
                                    <Button Type="@ButtonType.Text" OnClick="@(() => OpenRolesAsync(row))" AriaLabel="Roles">
                                        <Icon Type="safety" Theme="IconThemeType.Outline" />
                                    </Button>
                                }
                                @if (Permissions.Has(WebPermissions.StaffPasswordReset))
                                {
                                    <Button Type="@ButtonType.Text" OnClick="@(() => OpenPasswordResetAsync(row))" AriaLabel="Password reset">
                                        <Icon Type="key" Theme="IconThemeType.Outline" />
                                    </Button>
                                }
                                @if (Permissions.Has(WebPermissions.SecuritySessionsRevoke))
                                {
                                    <Button Type="@ButtonType.Text" OnClick="@(() => OpenRevokeSessionsAsync(row))" AriaLabel="Revoke sessions">
                                        <Icon Type="logout" Theme="IconThemeType.Outline" />
                                    </Button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="hc-pager">
                <span class="hc-caption">Total: @_totalCount</span>
                <Space>
                    <Button Disabled="@(_page <= 1 || _loading)" OnClick="@(() => OnPageChanged(_page - 1))">Prev</Button>
                    <span class="hc-caption">Page @_page / @_totalPages</span>
                    <Button Disabled="@(_page >= _totalPages || _loading)" OnClick="@(() => OnPageChanged(_page + 1))">Next</Button>
                </Space>
            </div>
        </div>
    }
}

@code {
    private readonly List<string> _roleOptions =
    [
        "CLINIC_ADMIN", "ORGANIZATION_ADMIN", "DOCTOR", "NURSE", "RECEPTIONIST", "PLATFORM_ADMIN"
    ];

    private List<StaffSummaryResponse> _items = [];
    private bool _loading;
    private string? _error;
    private string? _search;
    private string? _role;
    private string? _activeFilter;
    private Guid? _clinicId;
    private int _page = 1;
    private int _pageSize = 20;
    private int _totalCount;
    private int _totalPages = 1;
    private Guid? _boundOrganizationId;
    private string _activeTab = "all";

    protected override async Task OnInitializedAsync()
    {
        PlatformTenant.Changed += OnPlatformTenantChanged;
        ApplyRouteTab();

        if (!Permissions.IsStaffUser || Permissions.IsPatientOnly)
        {
            Navigation.NavigateTo("/forbidden");
            return;
        }

        if (!Permissions.Has(WebPermissions.StaffRead))
        {
            Navigation.NavigateTo("/forbidden");
            return;
        }

        SyncFromPlatformTenant();
        await ReloadAsync();
    }

    public void Dispose() => PlatformTenant.Changed -= OnPlatformTenantChanged;

    private void ApplyRouteTab()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri);
        if (path.StartsWith("staff/clinic-admins", StringComparison.OrdinalIgnoreCase))
        {
            _activeTab = "clinic-admins";
            _role = "CLINIC_ADMIN";
        }
    }

    private async Task OnTabChanged(string key)
    {
        _activeTab = key;
        _role = key switch
        {
            "clinic-admins" => "CLINIC_ADMIN",
            "doctors" => "DOCTOR",
            "nurses" => "NURSE",
            "receptionists" => "RECEPTIONIST",
            _ => null,
        };

        if (key == "clinic-admins"
            && !Navigation.ToBaseRelativePath(Navigation.Uri).StartsWith("staff/clinic-admins", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/staff/clinic-admins");
        }
        else if (key != "clinic-admins"
                 && Navigation.ToBaseRelativePath(Navigation.Uri).StartsWith("staff/clinic-admins", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/staff");
        }

        await ReloadAsync(resetPage: true);
    }

    private void OnPlatformTenantChanged() => InvokeAsync(async () =>
    {
        var orgChanged = _boundOrganizationId != PlatformTenant.SelectedOrganizationId;
        SyncFromPlatformTenant();
        if (orgChanged)
        {
            _items = [];
            _error = null;
            _search = null;
        }

        await ReloadAsync(resetPage: true);
        StateHasChanged();
    });

    private void SyncFromPlatformTenant()
    {
        _boundOrganizationId = PlatformTenant.SelectedOrganizationId;
        if (Permissions.IsPlatformAdmin)
        {
            _clinicId = PlatformTenant.SelectedClinicId;
        }
    }

    private Task RefreshClicked() => ReloadAsync(resetPage: true);

    private async Task ResetFiltersAsync()
    {
        _search = null;
        _activeFilter = null;
        if (_activeTab == "all")
        {
            _role = null;
        }

        if (!Permissions.IsPlatformAdmin)
        {
            _clinicId = null;
        }

        await ReloadAsync(resetPage: true);
    }

    private async Task OnClinicFilterChanged(Guid? clinicId)
    {
        _clinicId = clinicId;
        if (Permissions.IsPlatformAdmin)
        {
            if (clinicId is Guid id && id != Guid.Empty)
            {
                if (PlatformTenant.SelectedClinicId != id)
                {
                    PlatformTenant.SelectClinic(id);
                }
            }
            else if (PlatformTenant.HasClinic)
            {
                PlatformTenant.ClearClinic();
            }
        }

        await ReloadAsync(resetPage: true);
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await ReloadAsync();
        }
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await ReloadAsync(resetPage: false);
    }

    private async Task ReloadAsync(bool resetPage = true)
    {
        if (resetPage)
        {
            _page = 1;
        }

        if (Permissions.IsPlatformAdmin
            && (!PlatformTenant.HasOrganization || _clinicId is null || _clinicId == Guid.Empty))
        {
            _items = [];
            _totalCount = 0;
            _totalPages = 1;
            _loading = false;
            return;
        }

        _loading = true;
        _error = null;
        try
        {
            Guid? clinicId = Permissions.CanFilterByClinic ? _clinicId : null;

            bool? isActive = _activeFilter switch
            {
                "active" => true,
                "inactive" => false,
                _ => null,
            };

            var roleFilter = _activeTab switch
            {
                "clinic-admins" => "CLINIC_ADMIN",
                "doctors" => "DOCTOR",
                "nurses" => "NURSE",
                "receptionists" => "RECEPTIONIST",
                _ => string.IsNullOrWhiteSpace(_role) ? null : _role,
            };

            var bypass = Permissions.IsPlatformAdmin && clinicId is not null;

            var result = await StaffApi.SearchAsync(new StaffSearchRequest
            {
                Search = string.IsNullOrWhiteSpace(_search) ? null : _search.Trim(),
                Role = roleFilter,
                IsActive = isActive,
                ClinicId = clinicId,
                Page = _page,
                PageSize = _pageSize,
                SortBy = "lastname",
                SortDirection = "asc",
            }, platformAdminBypass: bypass);

            _items = result.Items.ToList();
            _totalCount = result.TotalCount;
            _totalPages = Math.Max(1, result.TotalPages);
            _page = result.Page < 1 ? 1 : result.Page;
        }
        catch (ApiProblemException ex) when (ex.StatusCode == 401)
        {
            await AuthState.MarkLoggedOutAsync(callRemoteLogout: false);
            Navigation.NavigateTo("/login");
        }
        catch (ApiProblemException ex)
        {
            _error = ex.ToUserMessage();
            _items = [];
        }
        catch (HttpRequestException)
        {
            _error = "Unable to reach the API.";
            _items = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenCreateAsync()
    {
        if (Permissions.IsPlatformAdmin
            && (!PlatformTenant.HasOrganization || !PlatformTenant.HasClinic))
        {
            Notify.Warning("Select organization and clinic in the platform banner first.");
            return;
        }

        var preferred = _activeTab switch
        {
            "clinic-admins" => "CLINIC_ADMIN",
            "doctors" => "DOCTOR",
            "nurses" => "NURSE",
            "receptionists" => "RECEPTIONIST",
            _ => null,
        };

        if (await Modals.ShowAsync<CreateStaffDialog, CreateStaffDialog.Args>(
                "Create staff",
                new CreateStaffDialog.Args { PreferredRole = preferred }))
        {
            Notify.Success("Staff member created.");
            await ReloadAsync();
        }
    }

    private async Task OpenDetailAsync(StaffSummaryResponse row)
    {
        await Modals.ShowAsync<StaffDetailDialog, StaffDetailDialog.Args>(
            "Staff details",
            new StaffDetailDialog.Args { StaffMemberId = row.StaffMemberId });
    }

    private async Task OpenEditAsync(StaffSummaryResponse row)
    {
        if (await Modals.ShowAsync<EditStaffDialog, EditStaffDialog.Args>(
                "Edit staff",
                new EditStaffDialog.Args
                {
                    StaffMemberId = row.StaffMemberId,
                    ExpectedVersion = row.Version,
                    FirstName = row.FirstName,
                    LastName = row.LastName,
                    DisplayName = row.DisplayName,
                    JobTitle = row.JobTitle,
                }))
        {
            Notify.Success("Staff updated.");
            await ReloadAsync(resetPage: false);
        }
    }

    private async Task OpenActivationAsync(StaffSummaryResponse row, bool activate)
    {
        if (await Modals.ShowAsync<StaffActivationDialog, StaffActivationDialog.Args>(
                activate ? "Activate staff" : "Deactivate staff",
                new StaffActivationDialog.Args
                {
                    StaffMemberId = row.StaffMemberId,
                    ExpectedVersion = row.Version,
                    Activate = activate,
                    DisplayName = DisplayName(row),
                }))
        {
            Notify.Success(activate ? "Staff activated." : "Staff deactivated.");
            await ReloadAsync(resetPage: false);
        }
    }

    private async Task OpenChangeClinicAsync(StaffSummaryResponse row)
    {
        if (await Modals.ShowAsync<ChangeStaffClinicDialog, ChangeStaffClinicDialog.Args>(
                "Change clinic",
                new ChangeStaffClinicDialog.Args
                {
                    StaffMemberId = row.StaffMemberId,
                    ExpectedVersion = row.Version,
                    CurrentClinicId = row.ClinicId,
                    DisplayName = DisplayName(row),
                    Role = row.Role,
                }))
        {
            Notify.Success("Clinic assignment updated. Sessions were revoked.");
            await ReloadAsync(resetPage: false);
        }
    }

    private async Task OpenRolesAsync(StaffSummaryResponse row)
    {
        if (await Modals.ShowAsync<StaffRolesDialog, StaffRolesDialog.Args>(
                "Assign role",
                new StaffRolesDialog.Args
                {
                    StaffMemberId = row.StaffMemberId,
                    CurrentRole = row.Role,
                    DisplayName = DisplayName(row),
                    TargetUserId = row.UserId,
                }))
        {
            Notify.Success("Role updated.");
            if (Permissions.CurrentUser?.UserId == row.UserId)
            {
                await AuthState.RefreshProfileAsync();
            }

            await ReloadAsync(resetPage: false);
        }
    }

    private async Task OpenPasswordResetAsync(StaffSummaryResponse row)
    {
        if (await Modals.ShowAsync<StaffPasswordResetDialog, StaffPasswordResetDialog.Args>(
                "Password reset",
                new StaffPasswordResetDialog.Args
                {
                    StaffMemberId = row.StaffMemberId,
                    DisplayName = DisplayName(row),
                }))
        {
            Notify.Success("Password reset initiated.");
        }
    }

    private async Task OpenRevokeSessionsAsync(StaffSummaryResponse row)
    {
        if (await Modals.ShowAsync<StaffRevokeSessionsDialog, StaffRevokeSessionsDialog.Args>(
                "Revoke sessions",
                new StaffRevokeSessionsDialog.Args
                {
                    StaffMemberId = row.StaffMemberId,
                    DisplayName = DisplayName(row),
                }))
        {
            Notify.Success("Sessions revoked.");
        }
    }

    private bool CanChangeClinic(StaffSummaryResponse row) =>
        Permissions.Has(WebPermissions.StaffManage)
        && (Permissions.IsOrganizationAdmin || Permissions.IsPlatformAdmin)
        && row.Role is not ("ORGANIZATION_ADMIN" or "PLATFORM_ADMIN");

    private static string DisplayName(StaffSummaryResponse row) =>
        string.IsNullOrWhiteSpace(row.DisplayName)
            ? $"{row.FirstName} {row.LastName}".Trim()
            : row.DisplayName!;
}
