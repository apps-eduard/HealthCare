@page "/staff"
@attribute [Authorize]
@inject IStaffManagementApiClient StaffApi
@inject IPermissionState Permissions
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject StaffAuthenticationStateProvider AuthState

<PageTitle>Staff</PageTitle>

@if (!Permissions.Has(WebPermissions.StaffRead))
{
    <MudAlert Severity="Severity.Error">You do not have permission to view staff.</MudAlert>
}
else
{
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h4">Staff</MudText>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Refresh" OnClick="RefreshClicked" Disabled="_loading">Refresh</MudButton>
            @if (Permissions.Has(WebPermissions.StaffManage))
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="OpenCreateAsync">Create staff</MudButton>
            }
        </MudStack>
    </MudStack>

    <MudPaper Class="pa-4 mb-4" Outlined="true">
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudTextField @bind-Value="_search"
                              Label="Search"
                              Immediate="true"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              OnAdornmentClick="RefreshClicked"
                              OnKeyUp="OnSearchKeyUp" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="string" @bind-Value="_role" Label="Role" Clearable="true">
                    @foreach (var role in _roleOptions)
                    {
                        <MudSelectItem Value="@role">@role</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="string" @bind-Value="_activeFilter" Label="Status" Clearable="true">
                    <MudSelectItem Value="@("active")">Active</MudSelectItem>
                    <MudSelectItem Value="@("inactive")">Inactive</MudSelectItem>
                </MudSelect>
            </MudItem>
            @if (Permissions.CanFilterByClinic)
            {
                <MudItem xs="12" md="3">
                    <MudTextField @bind-Value="_clinicIdText" Label="Clinic ID (optional)" />
                </MudItem>
            }
            <MudItem xs="12" md="1" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RefreshClicked" FullWidth="true">Apply</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
    }

    <MudTable Items="_items"
              Hover="true"
              Loading="_loading"
              LoadingProgressColor="Color.Primary"
              Breakpoint="Breakpoint.Sm"
              Dense="true">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Role</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Clinic</MudTh>
            <MudTh Style="text-align:right">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@DisplayName(context)</MudTd>
            <MudTd DataLabel="Email">@context.Email</MudTd>
            <MudTd DataLabel="Role"><MudChip T="string" Size="Size.Small">@context.Role</MudChip></MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@(context.MembershipIsActive ? Color.Success : Color.Default)">
                    @(context.MembershipIsActive ? "Active" : "Inactive")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Clinic"><MudText Typo="Typo.caption">@context.ClinicId</MudText></MudTd>
            <MudTd DataLabel="Actions" Style="text-align:right">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" aria-label="Details" OnClick="@(() => OpenDetailAsync(context))" />
                @if (Permissions.Has(WebPermissions.StaffManage))
                {
                    @if (context.MembershipIsActive)
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.PersonOff" aria-label="Deactivate" Color="Color.Warning" OnClick="@(() => OpenActivationAsync(context, activate: false))" />
                    }
                    else
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.Person" aria-label="Activate" Color="Color.Success" OnClick="@(() => OpenActivationAsync(context, activate: true))" />
                    }
                }
                @if (Permissions.Has(WebPermissions.RolesAssign))
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Badge" aria-label="Roles" OnClick="@(() => OpenRolesAsync(context))" />
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>No staff members matched your filters.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="pa-2">
                <MudText Typo="Typo.caption">Total: @_totalCount</MudText>
                <MudPagination Count="@Math.Max(1, _totalPages)" Selected="_page" SelectedChanged="OnPageChanged" />
            </MudStack>
        </PagerContent>
    </MudTable>
}

@code {
    private readonly List<string> _roleOptions =
    [
        "CLINIC_ADMIN", "ORGANIZATION_ADMIN", "DOCTOR", "NURSE", "RECEPTIONIST", "PLATFORM_ADMIN"
    ];

    private List<StaffSummaryResponse> _items = [];
    private bool _loading;
    private string? _error;
    private string? _search;
    private string? _role;
    private string? _activeFilter;
    private string? _clinicIdText;
    private int _page = 1;
    private int _pageSize = 20;
    private int _totalCount;
    private int _totalPages = 1;

    protected override async Task OnInitializedAsync()
    {
        if (!Permissions.IsStaffUser || Permissions.IsPatientOnly)
        {
            Navigation.NavigateTo("/forbidden");
            return;
        }

        if (!Permissions.Has(WebPermissions.StaffRead))
        {
            Navigation.NavigateTo("/forbidden");
            return;
        }

        await ReloadAsync();
    }

    private Task RefreshClicked() => ReloadAsync(resetPage: true);

    private async Task OnSearchKeyUp(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await ReloadAsync();
        }
    }

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await ReloadAsync(resetPage: false);
    }

    private async Task ReloadAsync(bool resetPage = true)
    {
        if (resetPage)
        {
            _page = 1;
        }

        _loading = true;
        _error = null;
        try
        {
            Guid? clinicId = null;
            if (Permissions.CanFilterByClinic
                && Guid.TryParse(_clinicIdText, out var parsed)
                && parsed != Guid.Empty)
            {
                clinicId = parsed;
            }

            bool? isActive = _activeFilter switch
            {
                "active" => true,
                "inactive" => false,
                _ => null,
            };

            var bypass = Permissions.CurrentUser?.Roles.Contains(WebRoles.PlatformAdmin, StringComparer.Ordinal) == true
                         && clinicId is not null;

            var result = await StaffApi.SearchAsync(new StaffSearchRequest
            {
                Search = string.IsNullOrWhiteSpace(_search) ? null : _search.Trim(),
                Role = string.IsNullOrWhiteSpace(_role) ? null : _role,
                IsActive = isActive,
                ClinicId = clinicId,
                Page = _page,
                PageSize = _pageSize,
                SortBy = "lastname",
                SortDirection = "asc",
            }, platformAdminBypass: bypass);

            _items = result.Items.ToList();
            _totalCount = result.TotalCount;
            _totalPages = Math.Max(1, result.TotalPages);
            _page = result.Page < 1 ? 1 : result.Page;
        }
        catch (ApiProblemException ex) when (ex.StatusCode == 401)
        {
            await AuthState.MarkLoggedOutAsync(callRemoteLogout: false);
            Navigation.NavigateTo("/login");
        }
        catch (ApiProblemException ex)
        {
            _error = ex.ToUserMessage();
            _items = [];
        }
        catch (HttpRequestException)
        {
            _error = "Unable to reach the API.";
            _items = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<CreateStaffDialog>("Create staff");
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            Snackbar.Add("Staff member created.", Severity.Success);
            await ReloadAsync();
        }
    }

    private async Task OpenDetailAsync(StaffSummaryResponse row)
    {
        var parameters = new DialogParameters<StaffDetailDialog>
        {
            { x => x.StaffMemberId, row.StaffMemberId },
        };
        await DialogService.ShowAsync<StaffDetailDialog>("Staff details", parameters);
    }

    private async Task OpenActivationAsync(StaffSummaryResponse row, bool activate)
    {
        var parameters = new DialogParameters<StaffActivationDialog>
        {
            { x => x.StaffMemberId, row.StaffMemberId },
            { x => x.ExpectedVersion, row.Version },
            { x => x.Activate, activate },
            { x => x.DisplayName, DisplayName(row) },
        };
        var dialog = await DialogService.ShowAsync<StaffActivationDialog>(
            activate ? "Activate staff" : "Deactivate staff",
            parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            Snackbar.Add(activate ? "Staff activated." : "Staff deactivated.", Severity.Success);
            await ReloadAsync(resetPage: false);
        }
    }

    private async Task OpenRolesAsync(StaffSummaryResponse row)
    {
        var parameters = new DialogParameters<StaffRolesDialog>
        {
            { x => x.StaffMemberId, row.StaffMemberId },
            { x => x.CurrentRole, row.Role },
            { x => x.DisplayName, DisplayName(row) },
            { x => x.TargetUserId, row.UserId },
        };
        var dialog = await DialogService.ShowAsync<StaffRolesDialog>("Assign role", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            Snackbar.Add("Role updated.", Severity.Success);
            if (Permissions.CurrentUser?.UserId == row.UserId)
            {
                await AuthState.RefreshProfileAsync();
            }

            await ReloadAsync(resetPage: false);
        }
    }

    private static string DisplayName(StaffSummaryResponse row) =>
        string.IsNullOrWhiteSpace(row.DisplayName)
            ? $"{row.FirstName} {row.LastName}".Trim()
            : row.DisplayName!;
}
