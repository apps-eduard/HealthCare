@page "/appointments"
@attribute [Authorize]
@using HealthCare.Contracts.Appointments
@using HealthCare.Web.Appointments
@using HealthCare.Web.Components.Appointments
@using HealthCare.Web.Components.Clinics
@implements IDisposable
@inject IAppointmentApiClient AppointmentsApi
@inject IPermissionState Permissions
@inject IPlatformTenantContext PlatformTenant
@inject IUiModalService Modals
@inject IUserNotificationService Notify
@inject NavigationManager Navigation
@inject IClinicDirectoryCache ClinicCache
@inject IClinicDirectoryApiClient ClinicsApi

<PageTitle>Appointments</PageTitle>

@if (Permissions.IsPatientOnly)
{
    <Alert Type="@AlertType.Error" Message="Patient accounts cannot use staff appointments." ShowIcon="true" />
}
else if (!Permissions.Has(WebPermissions.AppointmentsRead))
{
    <PermissionDeniedState Message="You do not have permission to view appointments." />
}
else
{
    <HcPageHeader Title="Appointments" Subtitle="@(string.IsNullOrWhiteSpace(_timezoneLabel) ? null : $"Times shown in {_timezoneLabel}")">
        <Button OnClick='() => Navigation.NavigateTo("/appointments/calendar")'>
            <Icon Type="calendar" Theme="IconThemeType.Outline" /> Calendar
        </Button>
        <Button OnClick="RefreshClicked" Disabled="_loading">
            <Icon Type="reload" Theme="IconThemeType.Outline" /> Refresh
        </Button>
        @if (Permissions.Has(WebPermissions.AppointmentsCreate))
        {
            <Button Type="@ButtonType.Primary" OnClick="OpenCreateAsync"
                    Disabled="@(Permissions.IsPlatformAdmin && (!PlatformTenant.HasOrganization || !PlatformTenant.HasClinic))">
                <Icon Type="plus" Theme="IconThemeType.Outline" /> Create
            </Button>
        }
    </HcPageHeader>

    @if (Permissions.IsPlatformAdmin && !PlatformTenant.HasOrganization)
    {
        <Alert Type="@AlertType.Info"
               Message="Select an organization in the platform banner before loading appointments. Global appointment search is not allowed."
               ShowIcon="true"
               Style="margin-bottom:1rem;" />
    }
    else if (Permissions.IsPlatformAdmin && !PlatformTenant.HasClinic)
    {
        <Alert Type="@AlertType.Info"
               Message="Select a clinic in the platform banner (or below) before loading appointments for the selected organization."
               ShowIcon="true"
               Style="margin-bottom:1rem;" />
    }

    <div class="hc-card">
        <div class="hc-filter-grid">
            <div>
                <span class="hc-filter-label">From</span>
                <DatePicker TValue="DateTime?" @bind-Value="_fromDate" Style="width:100%;" />
            </div>
            <div>
                <span class="hc-filter-label">To</span>
                <DatePicker TValue="DateTime?" @bind-Value="_toDate" Style="width:100%;" />
            </div>
            <div>
                <span class="hc-filter-label">Status</span>
                <Select TItemValue="string" TItem="string" @bind-Value="_status" Style="width:100%;" AllowClear>
                    <SelectOptions>
                        <SelectOption TItemValue="string" TItem="string" Value="@("")" Label="Any" />
                        @foreach (var status in AppointmentStatusPresentation.AllStatuses)
                        {
                            <SelectOption TItemValue="string" TItem="string" Value="@status" Label="@status" />
                        }
                    </SelectOptions>
                </Select>
            </div>
            <div>
                <span class="hc-filter-label">Doctor</span>
                <Select TItemValue="string" TItem="string" Value="@(_doctorId?.ToString() ?? "")" ValueChanged="OnDoctorFilterChanged" Style="width:100%;" AllowClear>
                    <SelectOptions>
                        <SelectOption TItemValue="string" TItem="string" Value="@("")" Label="Any" />
                        @foreach (var doctor in _doctors)
                        {
                            <SelectOption TItemValue="string" TItem="string" Value="@doctor.StaffMemberId.ToString()" Label="@doctor.DisplayName" />
                        }
                    </SelectOptions>
                </Select>
            </div>
            @if (Permissions.CanFilterByClinic)
            {
                <ClinicPicker Value="_clinicId" ValueChanged="OnClinicFilterChanged" Label="Clinic filter"
                              HelperText="@(Permissions.IsPlatformAdmin ? "Required for PLATFORM_ADMIN" : "Leave empty for all clinics in your organization")"
                              AllowClear="@(!Permissions.IsPlatformAdmin)" Required="@(Permissions.IsPlatformAdmin)" ActiveOnly="null"
                              PlatformAdminBypass="@(Permissions.IsPlatformAdmin)"
                              PlatformOrganizationId="@(Permissions.IsPlatformAdmin ? PlatformTenant.SelectedOrganizationId : null)"
                              Disabled="@(Permissions.IsPlatformAdmin && !PlatformTenant.HasOrganization)" />
            }
            <div>
                <span class="hc-filter-label">Sort by</span>
                <Select TItemValue="string" TItem="string" @bind-Value="_sortBy" Style="width:100%;">
                    <SelectOptions>
                        <SelectOption TItemValue="string" TItem="string" Value="@("appointmentDateUtc")" Label="Appointment time" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("createdAtUtc")" Label="Created" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("status")" Label="Status" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("durationMinutes")" Label="Duration" />
                    </SelectOptions>
                </Select>
            </div>
            <div>
                <span class="hc-filter-label">Direction</span>
                <Select TItemValue="string" TItem="string" @bind-Value="_sortDirection" Style="width:100%;">
                    <SelectOptions>
                        <SelectOption TItemValue="string" TItem="string" Value="@("asc")" Label="Ascending" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("desc")" Label="Descending" />
                    </SelectOptions>
                </Select>
            </div>
            <div>
                <span class="hc-filter-label">Page size</span>
                <Select TItemValue="string" TItem="string" Value="@_pageSize.ToString()" ValueChanged="OnPageSizeChanged" Style="width:100%;">
                    <SelectOptions>
                        <SelectOption TItemValue="string" TItem="string" Value="@("10")" Label="10" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("20")" Label="20" />
                        <SelectOption TItemValue="string" TItem="string" Value="@("50")" Label="50" />
                    </SelectOptions>
                </Select>
            </div>
            <div>
                <span class="hc-filter-label">&nbsp;</span>
                <Button Type="@ButtonType.Primary" OnClick="ApplyFiltersAsync"
                        Disabled="@(Permissions.IsPlatformAdmin && (!PlatformTenant.HasOrganization || !_clinicId.HasValue))">Apply</Button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error)) { <ErrorState Message="@_error" /> }
    @if (_loading) { <PageLoading /> }
    else if (_items.Count == 0) { <EmptyState Message="No appointments match the current filters." /> }
    else
    {
        <div class="hc-table-wrap">
            <table class="hc-table">
                <thead>
                    <tr>
                        <th>Time</th><th>Patient</th><th>Doctor</th><th>Clinic</th><th>Status</th>
                        <th>Source</th><th>Duration</th><th>Updated</th><th class="hc-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in _items)
                {
                    <tr style="cursor:pointer" @onclick="(() => OpenDetailAsync(row.Id))">
                        <td>@ClinicTimeDisplay.FormatLocal(row.AppointmentDateUtc, row.ClinicTimeZoneId ?? _timezoneLabel)</td>
                        <td>
                            @(row.PatientDisplayName ?? "—")
                            @if (!string.IsNullOrWhiteSpace(row.LocalPatientNumber))
                            {
                                <div class="hc-caption">@row.LocalPatientNumber</div>
                            }
                        </td>
                        <td>@(row.DoctorDisplayName ?? "—")</td>
                        <td>@(row.ClinicName ?? "—")</td>
                        <td><StatusBadge Text="@AppointmentStatusPresentation.DisplayLabel(row.Status)" Tone="@AppointmentStatusPresentation.ChipTone(row.Status)" /></td>
                        <td>@row.Source</td>
                        <td>@row.DurationMinutes min</td>
                        <td>@ClinicTimeDisplay.FormatLocal(row.UpdatedAtUtc, row.ClinicTimeZoneId ?? _timezoneLabel)</td>
                        <td class="hc-actions" @onclick:stopPropagation="true">
                            <Button Type="@ButtonType.Text" OnClick="@(() => OpenDetailAsync(row.Id))" AriaLabel="Details">
                                <Icon Type="eye" Theme="IconThemeType.Outline" />
                            </Button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
            <div class="hc-pager">
                <span class="hc-caption">Total: @_totalCount</span>
                <Space>
                    <Button Disabled="@(_page <= 1 || _loading)" OnClick="@(() => OnPageChanged(_page - 1))">Prev</Button>
                    <span class="hc-caption">Page @_page / @_pageCount</span>
                    <Button Disabled="@(_page >= _pageCount || _loading)" OnClick="@(() => OnPageChanged(_page + 1))">Next</Button>
                </Space>
            </div>
        </div>
    }
}

@code {
    private readonly List<AppointmentResponse> _items = [];
    private List<ClinicDoctorResponse> _doctors = [];
    private bool _loading;
    private string? _error;
    private DateTime? _fromDate = DateTime.Today;
    private DateTime? _toDate = DateTime.Today.AddDays(7);
    private string? _status;
    private Guid? _doctorId;
    private Guid? _clinicId;
    private string _sortBy = "appointmentDateUtc";
    private string _sortDirection = "asc";
    private int _page = 1;
    private int _pageSize = 20;
    private int _totalCount;
    private int _pageCount = 1;
    private string? _timezoneLabel;
    private Guid? _boundOrganizationId;
    private PeriodicTimer? _pollTimer;
    private CancellationTokenSource? _pollCts;
    private bool _dialogOpen;
    private bool _loadInFlight;

    protected override async Task OnInitializedAsync()
    {
        PlatformTenant.Changed += OnPlatformTenantChanged;

        if (Permissions.IsPatientOnly || !Permissions.Has(WebPermissions.AppointmentsRead))
        {
            return;
        }

        SyncFromPlatformTenant();

        if (!Permissions.CanFilterByClinic && Permissions.CurrentUser?.ClinicId is Guid clinicId)
        {
            _clinicId = clinicId;
            await ResolveTimezoneAsync(clinicId);
        }

        await LoadDoctorsForFilterAsync();
        await LoadAsync();
        StartPolling();
    }

    private void OnPlatformTenantChanged() => InvokeAsync(async () =>
    {
        var orgChanged = _boundOrganizationId != PlatformTenant.SelectedOrganizationId;
        SyncFromPlatformTenant();
        if (orgChanged)
        {
            _items.Clear();
            _doctors = [];
            _doctorId = null;
            _error = null;
            _timezoneLabel = null;
        }

        await ResolveTimezoneAsync(_clinicId);
        await LoadDoctorsForFilterAsync();
        await LoadAsync();
        StateHasChanged();
    });

    private void SyncFromPlatformTenant()
    {
        _boundOrganizationId = PlatformTenant.SelectedOrganizationId;
        if (Permissions.IsPlatformAdmin)
        {
            _clinicId = PlatformTenant.SelectedClinicId;
        }
    }

    private void StartPolling()
    {
        _pollCts = new CancellationTokenSource();
        _ = PollLoopAsync(_pollCts.Token);
    }

    private async Task PollLoopAsync(CancellationToken token)
    {
        _pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(45));
        try
        {
            while (await _pollTimer.WaitForNextTickAsync(token))
            {
                if (_dialogOpen || _loadInFlight || _loading)
                {
                    continue;
                }

                await InvokeAsync(async () => await LoadAsync(silent: true));
            }
        }
        catch (OperationCanceledException)
        {
            // disposed
        }
    }

    public void Dispose()
    {
        PlatformTenant.Changed -= OnPlatformTenantChanged;
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollTimer?.Dispose();
    }

    private async Task ApplyFiltersAsync()
    {
        _page = 1;
        await LoadAsync();
    }

    private async Task RefreshClicked() => await LoadAsync();

    private async Task OnPageChanged(int page)
    {
        _page = page;
        await LoadAsync();
    }

    private async Task OnClinicFilterChanged(Guid? clinicId)
    {
        _clinicId = clinicId;
        if (Permissions.IsPlatformAdmin)
        {
            if (clinicId is Guid id && id != Guid.Empty)
            {
                if (PlatformTenant.SelectedClinicId != id)
                {
                    PlatformTenant.SelectClinic(id);
                }
            }
            else if (PlatformTenant.HasClinic)
            {
                PlatformTenant.ClearClinic();
            }
        }

        _doctorId = null;
        await ResolveTimezoneAsync(clinicId);
        await LoadDoctorsForFilterAsync();
        await LoadAsync();
    }

    private async Task ResolveTimezoneAsync(Guid? clinicId)
    {
        _timezoneLabel = null;
        if (clinicId is not Guid id)
        {
            return;
        }

        try
        {
            if (ClinicCache.TryGet(id, out var cached) && cached is not null)
            {
                _timezoneLabel = cached.TimeZoneId;
                return;
            }

            var detail = await ClinicsApi.GetByIdAsync(id, Permissions.IsPlatformAdmin);
            ClinicCache.Set(detail);
            _timezoneLabel = detail.TimeZoneId;
        }
        catch
        {
            // keep UTC fallback via ClinicTimeDisplay
        }
    }

    private async Task LoadDoctorsForFilterAsync()
    {
        _doctors = [];
        if (!Permissions.Has(WebPermissions.AvailabilityRead))
        {
            return;
        }

        if (Permissions.IsPlatformAdmin
            && (!PlatformTenant.HasOrganization || _clinicId is null || _clinicId == Guid.Empty))
        {
            return;
        }

        string? slug = null;
        var clinicId = _clinicId ?? Permissions.CurrentUser?.ClinicId;
        if (clinicId is Guid id)
        {
            try
            {
                if (ClinicCache.TryGet(id, out var cached) && cached is not null)
                {
                    slug = cached.Slug;
                }
                else
                {
                    var detail = await ClinicsApi.GetByIdAsync(id, Permissions.IsPlatformAdmin);
                    ClinicCache.Set(detail);
                    slug = detail.Slug;
                    _timezoneLabel ??= detail.TimeZoneId;
                }
            }
            catch
            {
                return;
            }
        }

        if (string.IsNullOrWhiteSpace(slug))
        {
            return;
        }

        try
        {
            _doctors = (await AppointmentsApi.ListClinicDoctorsAsync(slug)).ToList();
        }
        catch
        {
            _doctors = [];
        }
    }

    private async Task LoadAsync(bool silent = false)
    {
        if (_loadInFlight)
        {
            return;
        }

        if (Permissions.IsPlatformAdmin
            && (!PlatformTenant.HasOrganization || _clinicId is null || _clinicId == Guid.Empty))
        {
            _items.Clear();
            _totalCount = 0;
            _pageCount = 1;
            _loading = false;
            return;
        }

        _loadInFlight = true;
        if (!silent)
        {
            _loading = true;
            _error = null;
        }

        try
        {
            var clinicId = Permissions.CanFilterByClinic ? _clinicId : null;
            var bypass = Permissions.IsPlatformAdmin && clinicId is not null;

            var query = AppointmentListQueryBuilder.Build(
                _fromDate,
                _toDate,
                _status,
                _doctorId,
                clinicId,
                _page,
                _pageSize,
                _sortBy,
                _sortDirection,
                _timezoneLabel);

            var result = await AppointmentsApi.ListStaffAsync(query, bypass);
            _items.Clear();
            _items.AddRange(result.Items);
            _totalCount = result.TotalCount;
            _pageCount = Math.Max(1, (int)Math.Ceiling(_totalCount / (double)_pageSize));
            if (_items.Count > 0 && string.IsNullOrWhiteSpace(_timezoneLabel))
            {
                _timezoneLabel = _items[0].ClinicTimeZoneId;
            }
        }
        catch (ApiProblemException ex)
        {
            if (!silent)
            {
                _error = AppointmentProblemMessages.ToUserMessage(ex);
                _items.Clear();
            }
        }
        finally
        {
            _loading = false;
            _loadInFlight = false;
        }
    }

    private Task OnPageSizeChanged(string? value)
    {
        if (int.TryParse(value, out var size) && size > 0)
        {
            _pageSize = size;
        }

        return Task.CompletedTask;
    }

    private Task OnDoctorFilterChanged(string? value)
    {
        _doctorId = Guid.TryParse(value, out var id) ? id : null;
        return Task.CompletedTask;
    }

    private async Task OpenDetailAsync(Guid appointmentId)
    {
        _dialogOpen = true;
        try
        {
            if (await Modals.ShowAsync<AppointmentDetailDialog, AppointmentDetailDialog.Args>(
                    "Appointment",
                    new AppointmentDetailDialog.Args
                    {
                        AppointmentId = appointmentId,
                        PlatformAdminBypass = Permissions.IsPlatformAdmin,
                    },
                    "640px"))
            {
                await LoadAsync();
            }
        }
        finally
        {
            _dialogOpen = false;
        }
    }

    private async Task OpenCreateAsync()
    {
        if (Permissions.IsPlatformAdmin
            && (!PlatformTenant.HasOrganization || !PlatformTenant.HasClinic))
        {
            Notify.Warning("Select organization and clinic in the platform banner first.");
            return;
        }

        _dialogOpen = true;
        try
        {
            if (await Modals.ShowAsync<CreateAppointmentDialog, CreateAppointmentDialog.Args>(
                    "Create appointment",
                    new CreateAppointmentDialog.Args
                    {
                        InitialClinicId = _clinicId ?? Permissions.CurrentUser?.ClinicId ?? PlatformTenant.SelectedClinicId,
                        PlatformAdminBypass = Permissions.IsPlatformAdmin,
                    },
                    "560px"))
            {
                await LoadAsync();
            }
        }
        finally
        {
            _dialogOpen = false;
        }
    }
}
