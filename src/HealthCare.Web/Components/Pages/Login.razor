@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@inject IPermissionState Permissions
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Staff sign in</PageTitle>

<div class="hc-auth-shell">
    <div class="hc-auth-container">
        <div class="hc-auth-card">
            <div class="hc-auth-eyebrow">Staff console</div>
            <h1 class="hc-auth-brand">HealthCare</h1>
            <p class="hc-auth-sub">Sign in with your staff account</p>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false" Class="mb-4">@_error</FluentMessageBar>
            }

            @* Full browser POST to BFF — Set-Cookie must happen on an HTTP response, not the SignalR circuit. *@
            <form id="bff-login-form"
                  method="post"
                  action="/bff/auth/login"
                  data-enhance="false"
                  onsubmit="return window.__hcLoginSubmit ? window.__hcLoginSubmit(this) : true;">
                <AntiforgeryToken />
                <input type="hidden" name="returnUrl" value="@SafeReturnUrl.Resolve(ReturnUrl)" />

                <div class="hc-auth-field">
                    <label for="bff-email">Email</label>
                    <input id="bff-email"
                           name="email"
                           type="email"
                           required
                           autocomplete="username"
                           class="hc-auth-input" />
                </div>
                <div class="hc-auth-field">
                    <label for="bff-password">Password</label>
                    <input id="bff-password"
                           name="password"
                           type="password"
                           required
                           autocomplete="current-password"
                           class="hc-auth-input" />
                </div>

                <FluentButton Type="ButtonType.Submit"
                              Appearance="Appearance.Accent"
                              Class="hc-auth-submit"
                              id="bff-login-submit">
                    Sign in
                </FluentButton>
            </form>
            <script>
                window.__hcLoginSubmit = function (form) {
                    if (form.dataset.submitting === '1') { return false; }
                    form.dataset.submitting = '1';
                    var btn = document.getElementById('bff-login-submit');
                    if (btn) { btn.setAttribute('disabled', 'disabled'); }
                    return true;
                };
            </script>
        </div>
    </div>
</div>

@code {
    private string? _error;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _error = MapQueryError(Error);

        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated != true)
        {
            return;
        }

        if (Permissions.IsPatientOnly)
        {
            Navigation.NavigateTo("/forbidden", forceLoad: true);
            return;
        }

        if (Permissions.IsStaffUser)
        {
            Navigation.NavigateTo(SafeReturnUrl.Resolve(ReturnUrl), forceLoad: true);
        }
    }

    private static string? MapQueryError(string? code) =>
        code switch
        {
            null or "" => null,
            "invalid_credentials" => "Invalid email or password.",
            "account_disabled" => "This account is disabled.",
            "account_locked" => "This account is temporarily locked.",
            "email_not_confirmed" => "Email confirmation is required before signing in.",
            "organization_inactive" => "The organization for this account is inactive.",
            "clinic_inactive" => "The clinic for this account is inactive.",
            "antiforgery" => "The sign-in form expired. Please try again.",
            "session" => "Your sign-in session expired. Please try again.",
            _ => "Unable to sign in. Please try again.",
        };
}
