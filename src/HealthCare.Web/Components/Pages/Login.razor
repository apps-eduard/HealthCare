@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@inject IPermissionState Permissions
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Staff sign in</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h4" GutterBottom="true">HealthCare Staff</MudText>
        <MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">Sign in with your staff account</MudText>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">@_error</MudAlert>
        }

        @* Full browser POST to BFF — Set-Cookie must happen on an HTTP response, not the SignalR circuit. *@
        <form method="post" action="/bff/auth/login" data-enhance="false">
            <AntiforgeryToken />
            <input type="hidden" name="returnUrl" value="@SafeReturnUrl.Resolve(ReturnUrl)" />

            <div class="mb-3">
                <label class="mud-input-label mud-input-label-inputbased mud-input-label-text" for="bff-email">Email</label>
                <input id="bff-email"
                       name="email"
                       type="email"
                       required
                       autocomplete="username"
                       class="mud-input-slot mud-input-root mud-input-root-outlined mud-input-root-margin-dense pa-2"
                       style="width:100%;border:1px solid var(--mud-palette-lines-inputs);border-radius:4px;background:transparent;color:inherit;" />
            </div>
            <div class="mb-3">
                <label class="mud-input-label mud-input-label-inputbased mud-input-label-text" for="bff-password">Password</label>
                <input id="bff-password"
                       name="password"
                       type="password"
                       required
                       autocomplete="current-password"
                       class="mud-input-slot mud-input-root mud-input-root-outlined mud-input-root-margin-dense pa-2"
                       style="width:100%;border:1px solid var(--mud-palette-lines-inputs);border-radius:4px;background:transparent;color:inherit;" />
            </div>

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Class="mt-2">
                Sign in
            </MudButton>
        </form>
    </MudPaper>
</MudContainer>

@code {
    private string? _error;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _error = MapQueryError(Error);

        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated != true)
        {
            return;
        }

        if (Permissions.IsPatientOnly)
        {
            Navigation.NavigateTo("/forbidden", forceLoad: true);
            return;
        }

        if (Permissions.IsStaffUser)
        {
            Navigation.NavigateTo(SafeReturnUrl.Resolve(ReturnUrl), forceLoad: true);
        }
    }

    private static string? MapQueryError(string? code) =>
        code switch
        {
            null or "" => null,
            "invalid_credentials" => "Invalid email or password.",
            "account_disabled" => "This account is disabled.",
            "account_locked" => "This account is temporarily locked.",
            "email_not_confirmed" => "Email confirmation is required before signing in.",
            "organization_inactive" => "The organization for this account is inactive.",
            "clinic_inactive" => "The clinic for this account is inactive.",
            "antiforgery" => "The sign-in form expired. Please try again.",
            "session" => "Your sign-in session expired. Please try again.",
            _ => "Unable to sign in. Please try again.",
        };
}
