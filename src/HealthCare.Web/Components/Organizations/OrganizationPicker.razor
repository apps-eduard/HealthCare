@namespace HealthCare.Web.Components.Organizations
@inject IOrganizationDirectoryApiClient OrganizationsApi
@inject IPermissionState Permissions
@inject IPlatformTenantContext PlatformTenant

@if (!Permissions.IsPlatformAdmin || !Permissions.Has(WebPermissions.OrganizationsRead))
{
    @* Hidden for non-platform users — do not call the directory API. *@
}
else
{
    <div class="hc-picker">
        <FluentTextField Value="@_searchText"
                         ValueChanged="OnSearchTextChanged"
                         Label="@Label"
                         Placeholder="Type to search…"
                         Disabled="@Disabled"
                         Required="@Required"
                         Style="width:100%;" />
        @if (_selected is not null)
        {
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center" Style="margin-top:0.35rem;">
                <span class="hc-caption">Selected: @FormatOrganization(_selected)</span>
                @if (AllowClear && !Disabled)
                {
                    <FluentButton Appearance="Appearance.Lightweight" OnClick="ClearAsync">Clear</FluentButton>
                }
            </FluentStack>
        }
        @if (_showResults)
        {
            <div class="hc-picker-results" role="listbox">
                @if (_searching)
                {
                    <div class="hc-caption" style="padding:0.5rem 0.75rem;">Searching…</div>
                }
                else if (_results.Count == 0)
                {
                    <div class="hc-caption" style="padding:0.5rem 0.75rem;">No organizations matched your search.</div>
                }
                else
                {
                    @foreach (var item in _results)
                    {
                        <button type="button" class="hc-picker-item" @onclick="(() => SelectAsync(item))">@FormatOrganization(item)</button>
                    }
                }
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(HelperText))
        {
            <div class="hc-caption" style="margin-top:0.35rem;">@HelperText</div>
        }
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false" Style="margin-top:0.35rem;">@_error</FluentMessageBar>
        }
    </div>
}

@code {
    [Parameter] public Guid? Value { get; set; }
    [Parameter] public EventCallback<Guid?> ValueChanged { get; set; }
    [Parameter] public string Label { get; set; } = "Organization";
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool AllowClear { get; set; } = true;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool? ActiveOnly { get; set; } = true;
    [Parameter] public bool SyncPlatformContext { get; set; } = true;

    private OrganizationDirectoryItemResponse? _selected;
    private List<OrganizationDirectoryItemResponse> _results = [];
    private string _searchText = string.Empty;
    private string? _error;
    private bool _showResults;
    private bool _searching;
    private CancellationTokenSource? _searchCts;
    private int _searchVersion;

    protected override async Task OnParametersSetAsync()
    {
        if (!Permissions.IsPlatformAdmin || !Permissions.Has(WebPermissions.OrganizationsRead))
        {
            return;
        }

        if (Value is Guid id && id != Guid.Empty)
        {
            if (_selected?.OrganizationId == id)
            {
                return;
            }

            await EnsureSelectedAsync(id);
            _searchText = FormatOrganization(_selected);
        }
        else if (Value is null)
        {
            _selected = null;
            if (string.IsNullOrWhiteSpace(_searchText))
            {
                _searchText = string.Empty;
            }
        }
    }

    private async Task EnsureSelectedAsync(Guid organizationId)
    {
        try
        {
            var detail = await OrganizationsApi.GetOrganizationAsync(organizationId);
            _selected = new OrganizationDirectoryItemResponse
            {
                OrganizationId = detail.OrganizationId,
                Name = detail.Name,
                Slug = detail.Slug,
                IsActive = detail.IsActive,
                ClinicCount = detail.ClinicCount,
                CreatedAtUtc = detail.CreatedAtUtc,
            };
        }
        catch (ApiProblemException)
        {
            _selected = null;
        }
    }

    private async Task OnSearchTextChanged(string? value)
    {
        _searchText = value ?? string.Empty;
        _showResults = true;
        await SearchAsync(_searchText);
    }

    private async Task SearchAsync(string? value)
    {
        _error = null;
        _searching = true;
        _searchCts?.Cancel();
        _searchCts?.Dispose();
        _searchCts = new CancellationTokenSource();
        var cts = _searchCts;
        var version = Interlocked.Increment(ref _searchVersion);

        try
        {
            await Task.Delay(300, cts.Token);
            if (version != _searchVersion)
            {
                return;
            }

            var page = await OrganizationsApi.SearchOrganizationsAsync(
                new OrganizationSearchRequest
                {
                    Search = string.IsNullOrWhiteSpace(value) ? null : value.Trim(),
                    IsActive = ActiveOnly,
                    Page = 1,
                    PageSize = 20,
                    SortBy = "name",
                    SortDirection = "asc",
                },
                cts.Token);

            if (version != _searchVersion)
            {
                return;
            }

            _results = page.Items.ToList();
        }
        catch (OperationCanceledException)
        {
        }
        catch (ApiProblemException ex)
        {
            if (version == _searchVersion)
            {
                _error = ex.ToUserMessage();
                _results = [];
            }
        }
        catch (HttpRequestException)
        {
            if (version == _searchVersion)
            {
                _error = "Unable to reach the API.";
                _results = [];
            }
        }
        finally
        {
            if (version == _searchVersion)
            {
                _searching = false;
            }
        }
    }

    private async Task SelectAsync(OrganizationDirectoryItemResponse item)
    {
        _selected = item;
        _searchText = FormatOrganization(item);
        _showResults = false;
        if (SyncPlatformContext)
        {
            PlatformTenant.SelectOrganization(item.OrganizationId, item.Name, item.Slug);
        }

        await ValueChanged.InvokeAsync(item.OrganizationId);
    }

    private async Task ClearAsync()
    {
        _selected = null;
        _searchText = string.Empty;
        _showResults = false;
        if (SyncPlatformContext)
        {
            PlatformTenant.Clear();
        }

        await ValueChanged.InvokeAsync(null);
    }

    private static string FormatOrganization(OrganizationDirectoryItemResponse? org) =>
        org is null
            ? string.Empty
            : string.IsNullOrWhiteSpace(org.Slug)
                ? org.Name
                : $"{org.Name} ({org.Slug})";
}
