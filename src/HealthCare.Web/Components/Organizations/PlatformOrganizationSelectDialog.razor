@namespace HealthCare.Web.Components.Organizations
@inherits FeedbackComponent<object?>
@inject IPlatformTenantContext PlatformTenant

<p class="hc-muted" style="margin-top:0">
    Search and choose an organization. This does not grant clinic or resource access by itself.
</p>
<OrganizationPicker Value="_organizationId"
                    ValueChanged="OnOrganizationChanged"
                    Label="Organization"
                    Required="true"
                    AllowClear="false"
                    SyncPlatformContext="true"
                    HelperText="Server-side search by name or slug" />
<div style="display:flex;gap:8px;justify-content:flex-end;margin-top:1rem;">
    <Button OnClick="CancelCloseAsync">Close</Button>
</div>

@code {
    private Guid? _organizationId;

    protected override void OnInitialized()
    {
        _organizationId = PlatformTenant.SelectedOrganizationId;
    }

    private async Task OnOrganizationChanged(Guid? organizationId)
    {
        _organizationId = organizationId;
        if (organizationId is not null)
        {
            await ConfirmOkAsync();
        }
    }

    private Task CancelCloseAsync() => OkCancelRef!.CancelAsync(new ModalClosingEventArgs());

    private Task ConfirmOkAsync() => OkCancelRef!.OkAsync(new ModalClosingEventArgs());
}
