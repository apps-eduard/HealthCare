@namespace HealthCare.Web.Components.Organizations
@implements IDisposable
@inject IPermissionState Permissions
@inject IPlatformTenantContext PlatformTenant
@inject IDialogService DialogService

@if (Permissions.IsPlatformAdmin)
{
    <div class="hc-banner">
        <div class="hc-banner-row">
            <strong>
                Platform context:
                @(PlatformTenant.HasOrganization
                    ? $"{PlatformTenant.SelectedOrganizationName}{(PlatformTenant.HasClinic ? $" / {PlatformTenant.SelectedClinicName ?? PlatformTenant.SelectedClinicId.ToString()}" : string.Empty)}"
                    : "(none selected)")
            </strong>
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="4" Wrap="true">
                <FluentButton Appearance="Appearance.Outline" OnClick="OpenSelectOrganizationAsync">
                    @(PlatformTenant.HasOrganization ? "Change organization" : "Select organization")
                </FluentButton>
                @if (PlatformTenant.HasOrganization)
                {
                    <FluentButton Appearance="Appearance.Outline" OnClick="OpenSelectClinicAsync">
                        @(PlatformTenant.HasClinic ? "Change clinic" : "Select clinic")
                    </FluentButton>
                    @if (PlatformTenant.HasClinic)
                    {
                        <FluentButton Appearance="Appearance.Lightweight" OnClick="ClearClinic">Clear clinic</FluentButton>
                    }
                    <FluentButton Appearance="Appearance.Lightweight" OnClick="ClearOrganization">Clear organization</FluentButton>
                }
            </FluentStack>
        </div>
        <p class="hc-caption" style="margin:0.5rem 0 0;">
            Elevated platform access. Selection is a usability aid only — API authorization and explicit bypass remain required.
            Medical notes stay denied for PLATFORM_ADMIN.
        </p>
        @if (!PlatformTenant.HasOrganization)
        {
            <p class="hc-caption" style="margin:0.35rem 0 0;">Select an organization before using staff, appointments, patients, or availability pages.</p>
        }
    </div>
}

@code {
    protected override void OnInitialized()
    {
        PlatformTenant.Changed += OnChanged;
        Permissions.Changed += OnChanged;
    }

    public void Dispose()
    {
        PlatformTenant.Changed -= OnChanged;
        Permissions.Changed -= OnChanged;
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private void ClearOrganization() => PlatformTenant.Clear();

    private void ClearClinic() => PlatformTenant.ClearClinic();

    private async Task OpenSelectOrganizationAsync()
    {
        await DialogService.ShowDialogAsync<PlatformOrganizationSelectDialog>(new DialogParameters
        {
            Title = "Select organization",
            Width = "480px",
            PrimaryAction = null,
            SecondaryAction = null,
        });
    }

    private async Task OpenSelectClinicAsync()
    {
        if (!PlatformTenant.HasOrganization)
        {
            return;
        }

        await DialogService.ShowDialogAsync<PlatformClinicSelectDialog>(new DialogParameters
        {
            Title = "Select clinic",
            Width = "480px",
            PrimaryAction = null,
            SecondaryAction = null,
        });
    }
}
