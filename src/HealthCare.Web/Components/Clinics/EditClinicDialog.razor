@inherits FeedbackComponent<EditClinicDialog.Args>
@using HealthCare.Contracts.Clinics
@using HealthCare.Web.Clinics
@inject IClinicManagementApiClient ClinicsApi
@inject IPermissionState Permissions
@inject IPlatformTenantContext PlatformTenant
@inject IClinicDirectoryCache ClinicCache

@if (_loading)
{
    <PageLoading />
}
else
{
    <div style="display:flex;flex-direction:column;gap:12px;max-height:70vh;overflow:auto;">
        <Alert Type="@AlertType.Warning"
               Message="Changing the slug updates the public patient registration URL. Changing the timezone affects scheduling interpretation."
               ShowIcon="true" />
        @if (_concurrencyConflict)
        {
            <Alert Type="@AlertType.Error"
                   Message="Another change was saved first. Reload the latest clinic before saving again."
                   ShowIcon="true" />
            <Button OnClick="ReloadAsync" Disabled="_busy" Style="margin-bottom:8px;">Reload latest</Button>
        }
        <div>
            <label for="edit-clinic-name">@FieldLabel.Mark("Name")</label>
            <Input Id="edit-clinic-name" @bind-Value="_name" Disabled="_busy" Style="width:100%;" />
        </div>
        <div>
            <label for="edit-clinic-slug">@FieldLabel.Mark("Slug")</label>
            <Input Id="edit-clinic-slug"
                   @bind-Value="_slug"
                   @bind-Value:after="OnSlugAfter"
                   Disabled="_busy"
                   Style="width:100%;" />
        </div>
        <div>
            <label for="edit-clinic-specialty">Specialty</label>
            <Input Id="edit-clinic-specialty" @bind-Value="_specialty" Disabled="_busy" Style="width:100%;" />
        </div>
        <div>
            <label for="edit-clinic-tz">@FieldLabel.Mark("Timezone")</label>
            <Select @bind-Value="_timeZoneId"
                    Id="edit-clinic-tz"
                    Disabled="@(_busy || _timeZonesLoading)"
                    Style="width:100%;"
                    TItemValue="string"
                    TItem="string"
                    AllowClear="false">
                <SelectOptions>
                    @foreach (var tz in _timeZones)
                    {
                        <SelectOption TItemValue="string" TItem="string" Value="@tz.TimeZoneId" Label="@($"{tz.DisplayName} ({tz.TimeZoneId})")" />
                    }
                </SelectOptions>
            </Select>
        </div>
        <div>
            <label for="edit-clinic-phone">Phone</label>
            <Input Id="edit-clinic-phone" @bind-Value="_phone" Disabled="_busy" Style="width:100%;" />
        </div>
        <div>
            <label for="edit-clinic-email">Email</label>
            <Input Id="edit-clinic-email" @bind-Value="_email" Disabled="_busy" Style="width:100%;" />
        </div>
        <div>
            <label for="edit-clinic-a1">Address line 1</label>
            <Input Id="edit-clinic-a1" @bind-Value="_address1" Disabled="_busy" Style="width:100%;" />
        </div>
        <div>
            <label for="edit-clinic-a2">Address line 2</label>
            <Input Id="edit-clinic-a2" @bind-Value="_address2" Disabled="_busy" Style="width:100%;" />
        </div>
        <div>
            <label for="edit-clinic-city">City</label>
            <Input Id="edit-clinic-city" @bind-Value="_city" Disabled="_busy" Style="width:100%;" />
        </div>
        <div>
            <label for="edit-clinic-region">Region / Province</label>
            <Input Id="edit-clinic-region" @bind-Value="_region" Disabled="_busy" Style="width:100%;" />
        </div>
        <div>
            <label for="edit-clinic-postal">Postal code</label>
            <Input Id="edit-clinic-postal" @bind-Value="_postal" Disabled="_busy" Style="width:100%;" />
        </div>
        <div>
            <label for="edit-clinic-country">Country</label>
            <Input Id="edit-clinic-country" @bind-Value="_country" Disabled="_busy" Style="width:100%;" />
        </div>
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <Alert Type="@AlertType.Error" Message="@_error" ShowIcon="true" role="alert" />
        }
    </div>
    <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:1rem;">
        <Button OnClick="CancelCloseAsync" Disabled="_busy">Cancel</Button>
        <Button Type="@ButtonType.Primary" OnClick="SubmitAsync" Loading="_busy" Disabled="@(_busy || _concurrencyConflict)">Save</Button>
    </div>
}

@code {
    public sealed record Args(Guid ClinicId);

    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private bool _concurrencyConflict;
    private int _version;
    private string _name = string.Empty;
    private string _slug = string.Empty;
    private string? _specialty;
    private string _timeZoneId = "Asia/Riyadh";
    private string? _phone;
    private string? _email;
    private string? _address1;
    private string? _address2;
    private string? _city;
    private string? _region;
    private string? _postal;
    private string? _country;
    private bool _timeZonesLoading = true;
    private List<TimeZoneInfoResponse> _timeZones = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _timeZones = (await ClinicsApi.ListTimeZonesAsync()).ToList();
            await LoadDetailAsync();
        }
        catch (ApiProblemException ex)
        {
            _error = ClinicProblemMessages.From(ex);
        }
        finally
        {
            _timeZonesLoading = false;
            _loading = false;
        }
    }

    private async Task LoadDetailAsync()
    {
        var detail = await ClinicsApi.GetByIdAsync(
            Options.ClinicId,
            platformAdminBypass: Permissions.IsPlatformAdmin && PlatformTenant.ExplicitBypassEnabled);
        ApplyDetail(detail);
        _concurrencyConflict = false;
        _error = null;
    }

    private void ApplyDetail(OrganizationClinicDetailResponse detail)
    {
        _version = detail.Version;
        _name = detail.Name;
        _slug = detail.Slug;
        _specialty = detail.Specialty;
        _timeZoneId = detail.TimeZoneId;
        _phone = detail.PhoneNumber;
        _email = detail.Email;
        _address1 = detail.AddressLine1;
        _address2 = detail.AddressLine2;
        _city = detail.City;
        _region = detail.Region;
        _postal = detail.PostalCode;
        _country = detail.Country;
    }

    private async Task ReloadAsync()
    {
        _busy = true;
        try
        {
            await LoadDetailAsync();
        }
        catch (ApiProblemException ex)
        {
            _error = ClinicProblemMessages.From(ex);
        }
        finally
        {
            _busy = false;
        }
    }

    private void OnSlugAfter() =>
        _slug = (_slug ?? string.Empty).Trim().ToLowerInvariant();

    private Task CancelCloseAsync() => OkCancelRef!.CancelAsync(new ModalClosingEventArgs());

    private Task ConfirmOkAsync() => OkCancelRef!.OkAsync(new ModalClosingEventArgs());

    private async Task SubmitAsync()
    {
        if (_busy || _concurrencyConflict)
        {
            return;
        }

        _error = null;
        if (string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_slug) || string.IsNullOrWhiteSpace(_timeZoneId))
        {
            _error = "Name, slug, and timezone are required.";
            return;
        }

        if (!ClinicSlugHelper.LooksValid(_slug))
        {
            _error = "Slug format is invalid.";
            return;
        }

        _busy = true;
        try
        {
            await ClinicsApi.UpdateAsync(
                Options.ClinicId,
                new UpdateOrganizationClinicRequest
                {
                    Name = _name.Trim(),
                    Slug = _slug.Trim(),
                    Specialty = _specialty,
                    PhoneNumber = _phone,
                    Email = _email,
                    AddressLine1 = _address1,
                    AddressLine2 = _address2,
                    City = _city,
                    Region = _region,
                    PostalCode = _postal,
                    Country = _country,
                    TimeZoneId = _timeZoneId,
                    ExpectedVersion = _version,
                },
                platformAdminBypass: Permissions.IsPlatformAdmin && PlatformTenant.ExplicitBypassEnabled);

            ClinicCache.Clear();
            await ConfirmOkAsync();
        }
        catch (ApiProblemException ex)
        {
            if (ex.ErrorCode == ClinicManagementErrorCodes.ConcurrencyConflict)
            {
                _concurrencyConflict = true;
                _error = ClinicProblemMessages.From(ex);
            }
            else
            {
                _error = ClinicProblemMessages.From(ex);
            }
        }
        catch
        {
            _error = "Unable to update clinic.";
        }
        finally
        {
            _busy = false;
        }
    }
}
