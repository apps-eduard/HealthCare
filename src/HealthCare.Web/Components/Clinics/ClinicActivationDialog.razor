@inherits FeedbackComponent<ClinicActivationDialog.Args>
@using HealthCare.Contracts.Clinics
@using HealthCare.Web.Clinics
@inject IClinicManagementApiClient ClinicsApi
@inject IPermissionState Permissions
@inject IPlatformTenantContext PlatformTenant
@inject IClinicDirectoryCache ClinicCache
@inject IClinicWorkingContext ClinicContext

<p style="margin-top:0">
    @(Options.Activate ? "Activate" : "Deactivate") <b>@Options.ClinicName</b>?
</p>
<p class="hc-caption">
    Current status: <Tag Color="@(Options.Activate ? "default" : "success")">@(Options.Activate ? "Inactive" : "Active")</Tag>
</p>
@if (Options.Activate)
{
    <Alert Type="@AlertType.Info"
           Message="Activation restores clinic operations for booking and staff access when membership rules allow."
           ShowIcon="true"
           Style="margin-bottom:12px;" />
}
else
{
    <Alert Type="@AlertType.Warning"
           Message="Historical records are retained. New appointments and new operational flows for this clinic are blocked. Staff access for this clinic may be affected. The last active clinic in the organization cannot be deactivated."
           ShowIcon="true"
           Style="margin-bottom:12px;" />
}
<div>
    <label for="clinic-activation-reason">Administrative reason (optional)</label>
    <Input Id="clinic-activation-reason" @bind-Value="_reason" Disabled="_busy" Style="width:100%;" />
</div>
@if (!string.IsNullOrWhiteSpace(_error))
{
    <Alert Type="@AlertType.Error" Message="@_error" ShowIcon="true" Style="margin-top:0.75rem;" role="alert" />
}
<div style="display:flex;gap:8px;justify-content:flex-end;margin-top:1rem;">
    <Button OnClick="CancelCloseAsync" Disabled="_busy">Cancel</Button>
    <Button Type="@ButtonType.Primary"
            Danger="@(!Options.Activate)"
            OnClick="SubmitAsync"
            Loading="_busy"
            Disabled="_busy">
        @(Options.Activate ? "Activate" : "Deactivate")
    </Button>
</div>

@code {
    public sealed record Args(Guid ClinicId, string ClinicName, int ExpectedVersion, bool Activate);

    private string? _reason;
    private string? _error;
    private bool _busy;

    private Task CancelCloseAsync() => OkCancelRef!.CancelAsync(new ModalClosingEventArgs());

    private Task ConfirmOkAsync() => OkCancelRef!.OkAsync(new ModalClosingEventArgs());

    private async Task SubmitAsync()
    {
        if (_busy)
        {
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var request = new ClinicActivationRequest
            {
                ExpectedVersion = Options.ExpectedVersion,
                Reason = string.IsNullOrWhiteSpace(_reason) ? null : _reason.Trim(),
            };

            var bypass = Permissions.IsPlatformAdmin && PlatformTenant.ExplicitBypassEnabled;
            OrganizationClinicDetailResponse result;
            if (Options.Activate)
            {
                result = await ClinicsApi.ActivateAsync(Options.ClinicId, request, bypass);
            }
            else
            {
                result = await ClinicsApi.DeactivateAsync(Options.ClinicId, request, bypass);
            }

            ClinicCache.Clear();
            if (ClinicContext.SelectedClinicId == result.ClinicId)
            {
                ClinicContext.SelectClinic(result.ClinicId, result.Name, result.IsActive);
            }

            await ConfirmOkAsync();
        }
        catch (ApiProblemException ex)
        {
            _error = ClinicProblemMessages.From(ex);
        }
        finally
        {
            _busy = false;
        }
    }
}
