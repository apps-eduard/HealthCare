@namespace HealthCare.Web.Components.Clinics
@inject IClinicDirectoryApiClient ClinicsApi
@inject IPermissionState Permissions
@inject IClinicDirectoryCache Cache

@if (!Permissions.Has(WebPermissions.ClinicsRead))
{
    @* Hidden when permission missing — do not call the directory API. *@
}
else if (_readOnlyClinic is not null)
{
    <MudTextField Value="@($"{_readOnlyClinic.Name} ({_readOnlyClinic.Slug})")"
                  Label="@Label"
                  Disabled="true"
                  HelperText="Assigned clinic from your staff membership"
                  Variant="Variant.Outlined" />
}
else
{
    <MudAutocomplete T="ClinicDirectoryItemResponse"
                     Label="@Label"
                     Value="_selected"
                     ValueChanged="OnValueChanged"
                     SearchFunc="SearchClinicsAsync"
                     ToStringFunc="FormatClinic"
                     Dense="true"
                     Clearable="@AllowClear"
                     Disabled="@EffectiveDisabled"
                     Required="@Required"
                     RequiredError="Clinic is required"
                     HelperText="@(IsPlatformScopeMissing ? "Select an organization in the platform banner first." : HelperText)"
                     MaxItems="20"
                     ShowProgressIndicator="true"
                     Variant="Variant.Outlined" />

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Dense="true" Class="mt-1">@_error</MudAlert>
    }
    else if (_emptyHint)
    {
        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">No clinics matched your search.</MudText>
    }
}

@code {
    [Parameter]
    public Guid? Value { get; set; }

    [Parameter]
    public EventCallback<Guid?> ValueChanged { get; set; }

    [Parameter]
    public string Label { get; set; } = "Clinic";

    [Parameter]
    public string? HelperText { get; set; }

    [Parameter]
    public bool Required { get; set; }

    [Parameter]
    public bool AllowClear { get; set; } = true;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool? ActiveOnly { get; set; } = true;

    [Parameter]
    public Guid? PlatformOrganizationId { get; set; }

    [Parameter]
    public bool PlatformAdminBypass { get; set; }

    private ClinicDirectoryItemResponse? _selected;
    private ClinicDirectoryItemResponse? _readOnlyClinic;
    private string? _error;
    private bool _emptyHint;
    private CancellationTokenSource? _searchCts;
    private int _searchVersion;
    private Guid? _lastPlatformOrganizationId;

    private bool IsPlatformScopeMissing =>
        PlatformAdminBypass
        && (PlatformOrganizationId is null || PlatformOrganizationId == Guid.Empty);

    private bool EffectiveDisabled => Disabled || IsPlatformScopeMissing;

    protected override async Task OnParametersSetAsync()
    {
        if (!Permissions.Has(WebPermissions.ClinicsRead))
        {
            return;
        }

        if (PlatformOrganizationId != _lastPlatformOrganizationId)
        {
            _lastPlatformOrganizationId = PlatformOrganizationId;
            if (_selected is not null
                && (PlatformOrganizationId is null
                    || _selected.OrganizationId != PlatformOrganizationId))
            {
                _selected = null;
                if (Value is not null)
                {
                    await ValueChanged.InvokeAsync(null);
                }
            }
        }

        if (!Permissions.CanFilterByClinic
            && Permissions.CurrentUser?.ClinicId is Guid assigned
            && assigned != Guid.Empty)
        {
            await EnsureReadOnlyClinicAsync(assigned);
            return;
        }

        _readOnlyClinic = null;

        if (Value is Guid id && id != Guid.Empty)
        {
            if (_selected?.ClinicId == id)
            {
                return;
            }

            await EnsureSelectedAsync(id);
        }
        else if (Value is null)
        {
            _selected = null;
        }
    }

    private async Task EnsureReadOnlyClinicAsync(Guid clinicId)
    {
        if (_readOnlyClinic?.ClinicId == clinicId)
        {
            return;
        }

        try
        {
            if (Cache.TryGet(clinicId, out var cached) && cached is not null)
            {
                _readOnlyClinic = ToItem(cached);
            }
            else
            {
                var detail = await ClinicsApi.GetByIdAsync(clinicId);
                Cache.Set(detail);
                _readOnlyClinic = ToItem(detail);
            }

            if (Value != clinicId)
            {
                await ValueChanged.InvokeAsync(clinicId);
            }
        }
        catch (ApiProblemException ex)
        {
            _error = ex.ToUserMessage();
        }
    }

    private async Task EnsureSelectedAsync(Guid clinicId)
    {
        try
        {
            if (Cache.TryGet(clinicId, out var cached) && cached is not null)
            {
                _selected = ToItem(cached);
                return;
            }

            var detail = await ClinicsApi.GetByIdAsync(clinicId, PlatformAdminBypass);
            Cache.Set(detail);
            _selected = ToItem(detail);
        }
        catch (ApiProblemException)
        {
            _selected = null;
        }
    }

    private async Task<IEnumerable<ClinicDirectoryItemResponse>> SearchClinicsAsync(
        string? value,
        CancellationToken token)
    {
        _error = null;
        _emptyHint = false;

        _searchCts?.Cancel();
        _searchCts?.Dispose();
        _searchCts = CancellationTokenSource.CreateLinkedTokenSource(token);
        var cts = _searchCts;
        var version = Interlocked.Increment(ref _searchVersion);

        try
        {
            await Task.Delay(300, cts.Token);
            if (version != _searchVersion)
            {
                return Array.Empty<ClinicDirectoryItemResponse>();
            }

            if (PlatformAdminBypass
                && (PlatformOrganizationId is null || PlatformOrganizationId == Guid.Empty))
            {
                _error = "Organization scope is required before searching clinics.";
                return Array.Empty<ClinicDirectoryItemResponse>();
            }

            var page = await ClinicsApi.SearchAsync(
                new ClinicSearchRequest
                {
                    Search = string.IsNullOrWhiteSpace(value) ? null : value.Trim(),
                    IsActive = ActiveOnly,
                    OrganizationId = PlatformAdminBypass ? PlatformOrganizationId : null,
                    Page = 1,
                    PageSize = 20,
                    SortBy = "name",
                    SortDirection = "asc",
                },
                platformAdminBypass: PlatformAdminBypass,
                cancellationToken: cts.Token);

            if (version != _searchVersion)
            {
                return Array.Empty<ClinicDirectoryItemResponse>();
            }

            _emptyHint = page.Items.Count == 0;
            return page.Items;
        }
        catch (OperationCanceledException)
        {
            return Array.Empty<ClinicDirectoryItemResponse>();
        }
        catch (ApiProblemException ex)
        {
            if (version == _searchVersion)
            {
                _error = ex.ToUserMessage();
            }

            return Array.Empty<ClinicDirectoryItemResponse>();
        }
        catch (HttpRequestException)
        {
            if (version == _searchVersion)
            {
                _error = "Unable to reach the API.";
            }

            return Array.Empty<ClinicDirectoryItemResponse>();
        }
    }

    private async Task OnValueChanged(ClinicDirectoryItemResponse? item)
    {
        _selected = item;
        await ValueChanged.InvokeAsync(item?.ClinicId);
    }

    private static string FormatClinic(ClinicDirectoryItemResponse? clinic) =>
        clinic is null ? string.Empty : $"{clinic.Name} ({clinic.Slug})";

    private static ClinicDirectoryItemResponse ToItem(ClinicDetailResponse detail) =>
        new()
        {
            ClinicId = detail.ClinicId,
            OrganizationId = detail.OrganizationId,
            Name = detail.Name,
            Slug = detail.Slug,
            IsActive = detail.IsActive,
            TimeZoneId = detail.TimeZoneId,
            City = detail.City,
        };
}
