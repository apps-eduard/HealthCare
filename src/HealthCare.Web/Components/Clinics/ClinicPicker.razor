@namespace HealthCare.Web.Components.Clinics
@inject IClinicDirectoryApiClient ClinicsApi
@inject IPermissionState Permissions
@inject IClinicDirectoryCache Cache

@if (!Permissions.Has(WebPermissions.ClinicsRead))
{
    @* Hidden when permission missing — do not call the directory API. *@
}
else if (_readOnlyClinic is not null)
{
    <FluentTextField Value="@($"{_readOnlyClinic.Name} ({_readOnlyClinic.Slug})")"
                     Label="@Label"
                     Disabled="true"
                     Style="width:100%;" />
    <div class="hc-caption">Assigned clinic from your staff membership</div>
}
else
{
    <div class="hc-picker">
        <FluentTextField Value="@_searchText"
                         ValueChanged="OnSearchTextChanged"
                         Label="@Label"
                         Placeholder="Type to search…"
                         Disabled="@EffectiveDisabled"
                         Required="@Required"
                         Style="width:100%;" />
        @if (_selected is not null)
        {
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center" Style="margin-top:0.35rem;">
                <span class="hc-caption">Selected: @FormatClinic(_selected)</span>
                @if (AllowClear && !EffectiveDisabled)
                {
                    <FluentButton Appearance="Appearance.Lightweight" OnClick="ClearAsync">Clear</FluentButton>
                }
            </FluentStack>
        }
        @if (_showResults && !EffectiveDisabled)
        {
            <div class="hc-picker-results" role="listbox">
                @if (_searching)
                {
                    <div class="hc-caption" style="padding:0.5rem 0.75rem;">Searching…</div>
                }
                else if (_results.Count == 0)
                {
                    <div class="hc-caption" style="padding:0.5rem 0.75rem;">No clinics matched your search.</div>
                }
                else
                {
                    @foreach (var item in _results)
                    {
                        <button type="button" class="hc-picker-item" @onclick="(() => SelectAsync(item))">@FormatClinic(item)</button>
                    }
                }
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(EffectiveHelper))
        {
            <div class="hc-caption" style="margin-top:0.35rem;">@EffectiveHelper</div>
        }
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false" Style="margin-top:0.35rem;">@_error</FluentMessageBar>
        }
    </div>
}

@code {
    [Parameter] public Guid? Value { get; set; }
    [Parameter] public EventCallback<Guid?> ValueChanged { get; set; }
    [Parameter] public string Label { get; set; } = "Clinic";
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool AllowClear { get; set; } = true;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool? ActiveOnly { get; set; } = true;
    [Parameter] public Guid? PlatformOrganizationId { get; set; }
    [Parameter] public bool PlatformAdminBypass { get; set; }

    private ClinicDirectoryItemResponse? _selected;
    private ClinicDirectoryItemResponse? _readOnlyClinic;
    private List<ClinicDirectoryItemResponse> _results = [];
    private string _searchText = string.Empty;
    private string? _error;
    private bool _showResults;
    private bool _searching;
    private CancellationTokenSource? _searchCts;
    private int _searchVersion;
    private Guid? _lastPlatformOrganizationId;

    private bool IsPlatformScopeMissing =>
        PlatformAdminBypass
        && (PlatformOrganizationId is null || PlatformOrganizationId == Guid.Empty);

    private bool EffectiveDisabled => Disabled || IsPlatformScopeMissing;

    private string? EffectiveHelper =>
        IsPlatformScopeMissing ? "Select an organization in the platform banner first." : HelperText;

    protected override async Task OnParametersSetAsync()
    {
        if (!Permissions.Has(WebPermissions.ClinicsRead))
        {
            return;
        }

        if (PlatformOrganizationId != _lastPlatformOrganizationId)
        {
            _lastPlatformOrganizationId = PlatformOrganizationId;
            if (_selected is not null
                && (PlatformOrganizationId is null
                    || _selected.OrganizationId != PlatformOrganizationId))
            {
                _selected = null;
                _searchText = string.Empty;
                if (Value is not null)
                {
                    await ValueChanged.InvokeAsync(null);
                }
            }
        }

        if (!Permissions.CanFilterByClinic
            && Permissions.CurrentUser?.ClinicId is Guid assigned
            && assigned != Guid.Empty)
        {
            await EnsureReadOnlyClinicAsync(assigned);
            return;
        }

        _readOnlyClinic = null;

        if (Value is Guid id && id != Guid.Empty)
        {
            if (_selected?.ClinicId == id)
            {
                return;
            }

            await EnsureSelectedAsync(id);
            _searchText = FormatClinic(_selected);
        }
        else if (Value is null)
        {
            _selected = null;
        }
    }

    private async Task EnsureReadOnlyClinicAsync(Guid clinicId)
    {
        if (_readOnlyClinic?.ClinicId == clinicId)
        {
            return;
        }

        try
        {
            if (Cache.TryGet(clinicId, out var cached) && cached is not null)
            {
                _readOnlyClinic = ToItem(cached);
            }
            else
            {
                var detail = await ClinicsApi.GetByIdAsync(clinicId);
                Cache.Set(detail);
                _readOnlyClinic = ToItem(detail);
            }

            if (Value != clinicId)
            {
                await ValueChanged.InvokeAsync(clinicId);
            }
        }
        catch (ApiProblemException ex)
        {
            _error = ex.ToUserMessage();
        }
    }

    private async Task EnsureSelectedAsync(Guid clinicId)
    {
        try
        {
            if (Cache.TryGet(clinicId, out var cached) && cached is not null)
            {
                _selected = ToItem(cached);
                return;
            }

            var detail = await ClinicsApi.GetByIdAsync(clinicId, PlatformAdminBypass);
            Cache.Set(detail);
            _selected = ToItem(detail);
        }
        catch (ApiProblemException)
        {
            _selected = null;
        }
    }

    private async Task OnSearchTextChanged(string? value)
    {
        _searchText = value ?? string.Empty;
        _showResults = true;
        await SearchAsync(_searchText);
    }

    private async Task SearchAsync(string? value)
    {
        _error = null;
        _searching = true;
        _searchCts?.Cancel();
        _searchCts?.Dispose();
        _searchCts = new CancellationTokenSource();
        var cts = _searchCts;
        var version = Interlocked.Increment(ref _searchVersion);

        try
        {
            await Task.Delay(300, cts.Token);
            if (version != _searchVersion)
            {
                return;
            }

            if (PlatformAdminBypass
                && (PlatformOrganizationId is null || PlatformOrganizationId == Guid.Empty))
            {
                _error = "Organization scope is required before searching clinics.";
                _results = [];
                return;
            }

            var page = await ClinicsApi.SearchAsync(
                new ClinicSearchRequest
                {
                    Search = string.IsNullOrWhiteSpace(value) ? null : value.Trim(),
                    IsActive = ActiveOnly,
                    OrganizationId = PlatformAdminBypass ? PlatformOrganizationId : null,
                    Page = 1,
                    PageSize = 20,
                    SortBy = "name",
                    SortDirection = "asc",
                },
                platformAdminBypass: PlatformAdminBypass,
                cancellationToken: cts.Token);

            if (version != _searchVersion)
            {
                return;
            }

            _results = page.Items.ToList();
        }
        catch (OperationCanceledException)
        {
        }
        catch (ApiProblemException ex)
        {
            if (version == _searchVersion)
            {
                _error = ex.ToUserMessage();
                _results = [];
            }
        }
        catch (HttpRequestException)
        {
            if (version == _searchVersion)
            {
                _error = "Unable to reach the API.";
                _results = [];
            }
        }
        finally
        {
            if (version == _searchVersion)
            {
                _searching = false;
            }
        }
    }

    private async Task SelectAsync(ClinicDirectoryItemResponse item)
    {
        _selected = item;
        _searchText = FormatClinic(item);
        _showResults = false;
        await ValueChanged.InvokeAsync(item.ClinicId);
    }

    private async Task ClearAsync()
    {
        _selected = null;
        _searchText = string.Empty;
        _showResults = false;
        await ValueChanged.InvokeAsync(null);
    }

    private static string FormatClinic(ClinicDirectoryItemResponse? clinic) =>
        clinic is null ? string.Empty : $"{clinic.Name} ({clinic.Slug})";

    private static ClinicDirectoryItemResponse ToItem(ClinicDetailResponse detail) =>
        new()
        {
            ClinicId = detail.ClinicId,
            OrganizationId = detail.OrganizationId,
            Name = detail.Name,
            Slug = detail.Slug,
            IsActive = detail.IsActive,
            TimeZoneId = detail.TimeZoneId,
            City = detail.City,
        };
}
