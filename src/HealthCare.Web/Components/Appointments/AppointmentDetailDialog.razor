@namespace HealthCare.Web.Components.Appointments
@inherits FeedbackComponent<AppointmentDetailDialog.Args>
@using HealthCare.Contracts.Appointments
@using HealthCare.Web.Appointments

@if (_loading)
{
    <PageLoading />
}
else if (_appointment is null)
{
    <Alert Type="@AlertType.Error" Message="@(_error ?? "Appointment not found.")" ShowIcon="true" />
}
else
{
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <Alert Type="@AlertType.Error" Message="@_error" ShowIcon="true" Style="margin-bottom:0.75rem;" />
    }

    <div style="display:flex;flex-direction:column;gap:8px;">
        <div class="hc-caption">ID: @_appointment.Id</div>
        <div><strong>When:</strong> @ClinicTimeDisplay.FormatLocalWithZone(_appointment.AppointmentDateUtc, _appointment.ClinicTimeZoneId)</div>
        <div><strong>Duration:</strong> @_appointment.DurationMinutes min</div>
        <div>
            <strong>Status:</strong>
            <StatusBadge Text="@AppointmentStatusPresentation.DisplayLabel(_appointment.Status)"
                         Tone="@AppointmentStatusPresentation.ChipTone(_appointment.Status)" />
        </div>
        <div><strong>Clinic:</strong> @(_appointment.ClinicName ?? _appointment.ClinicId.ToString("D"))</div>
        <div><strong>Doctor:</strong> @(_appointment.DoctorDisplayName ?? "—")</div>
        <div>
            <strong>Patient:</strong>
            @(_appointment.PatientDisplayName ?? "—")
            @if (!string.IsNullOrWhiteSpace(_appointment.LocalPatientNumber))
            {
                <span> · @_appointment.LocalPatientNumber</span>
            }
        </div>
        <div><strong>Source:</strong> @_appointment.Source</div>
        <div><strong>Version:</strong> @_appointment.Version</div>
        <div class="hc-caption">Created: @ClinicTimeDisplay.FormatLocalWithZone(_appointment.CreatedAtUtc, _appointment.ClinicTimeZoneId)</div>
        <div class="hc-caption">Updated: @ClinicTimeDisplay.FormatLocalWithZone(_appointment.UpdatedAtUtc, _appointment.ClinicTimeZoneId)</div>
        @if (!string.IsNullOrWhiteSpace(_appointment.CancellationReason))
        {
            <div><strong>Cancellation reason:</strong> @_appointment.CancellationReason</div>
        }
    </div>
}

<div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;margin-top:1rem;">
    <Button OnClick="CloseAsync" Disabled="_busy">Close</Button>
    @if (_appointment is not null)
    {
        @foreach (var action in AppointmentActionRules.GetVisibleActions(_appointment.Status, Permissions))
        {
            <Button Type="@ButtonType.Primary" Disabled="_busy" OnClick="@(() => RunActionAsync(action))">
                @ActionLabel(action)
            </Button>
        }
    }
</div>

@code {
    public sealed class Args
    {
        public Guid AppointmentId { get; init; }
        public bool PlatformAdminBypass { get; init; }
    }

    [Inject] private IAppointmentApiClient AppointmentsApi { get; set; } = default!;
    [Inject] private IPermissionState Permissions { get; set; } = default!;
    [Inject] private IUiModalService Modals { get; set; } = default!;
    [Inject] private IUserNotificationService Notify { get; set; } = default!;

    private AppointmentResponse? _appointment;
    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private bool _changed;

    private Guid AppointmentId => Options.AppointmentId;
    private bool PlatformAdminBypass => Options.PlatformAdminBypass;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _appointment = await AppointmentsApi.GetByIdAsync(AppointmentId, PlatformAdminBypass);
        }
        catch (ApiProblemException ex)
        {
            _appointment = null;
            _error = AppointmentProblemMessages.ToUserMessage(ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RunActionAsync(AppointmentUiAction action)
    {
        if (_appointment is null || _busy)
        {
            return;
        }

        switch (action)
        {
            case AppointmentUiAction.Cancel:
                await OpenCancelAsync();
                return;
            case AppointmentUiAction.Reschedule:
                await OpenRescheduleAsync();
                return;
        }

        var confirmed = await Modals.ConfirmAsync(
            ActionLabel(action),
            $"Confirm {ActionLabel(action).ToLowerInvariant()} for this appointment?");
        if (!confirmed)
        {
            return;
        }

        await MutateAsync(action);
    }

    private async Task MutateAsync(AppointmentUiAction action)
    {
        if (_appointment is null)
        {
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var request = new AppointmentActionRequest { ExpectedVersion = _appointment.Version };
            _appointment = action switch
            {
                AppointmentUiAction.Confirm => await AppointmentsApi.ConfirmAsync(_appointment.Id, request, PlatformAdminBypass),
                AppointmentUiAction.CheckIn => await AppointmentsApi.CheckInAsync(_appointment.Id, request, PlatformAdminBypass),
                AppointmentUiAction.Complete => await AppointmentsApi.CompleteAsync(_appointment.Id, request, PlatformAdminBypass),
                AppointmentUiAction.NoShow => await AppointmentsApi.MarkNoShowAsync(_appointment.Id, request, PlatformAdminBypass),
                _ => _appointment,
            };
            _changed = true;
            Notify.Success($"{ActionLabel(action)} succeeded.");
        }
        catch (ApiProblemException ex) when (AppointmentProblemMessages.IsConcurrencyConflict(ex))
        {
            var reload = await Modals.ConfirmAsync(
                "Appointment changed",
                "This appointment was updated elsewhere. Reload the latest version?");
            if (reload)
            {
                await LoadAsync();
            }
            else
            {
                _error = AppointmentProblemMessages.ToUserMessage(ex);
            }
        }
        catch (ApiProblemException ex)
        {
            _error = AppointmentProblemMessages.ToUserMessage(ex);
            Notify.Error(_error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task OpenCancelAsync()
    {
        if (_appointment is null)
        {
            return;
        }

        var ok = await Modals.ShowAsync<CancelAppointmentDialog, CancelAppointmentDialog.Args>(
            "Cancel appointment",
            new CancelAppointmentDialog.Args
            {
                AppointmentId = _appointment.Id,
                ExpectedVersion = _appointment.Version,
                PlatformAdminBypass = PlatformAdminBypass,
            });
        if (ok)
        {
            _changed = true;
            await LoadAsync();
        }
    }

    private async Task OpenRescheduleAsync()
    {
        if (_appointment is null)
        {
            return;
        }

        var ok = await Modals.ShowAsync<RescheduleAppointmentDialog, RescheduleAppointmentDialog.Args>(
            "Reschedule appointment",
            new RescheduleAppointmentDialog.Args
            {
                Appointment = _appointment,
                PlatformAdminBypass = PlatformAdminBypass,
            },
            "560px");
        if (ok)
        {
            _changed = true;
            await LoadAsync();
        }
    }

    private Task ConfirmOkAsync() => OkCancelRef!.OkAsync(new ModalClosingEventArgs());

    private Task CancelCloseAsync() => OkCancelRef!.CancelAsync(new ModalClosingEventArgs());

    private Task CloseAsync() => _changed ? ConfirmOkAsync() : CancelCloseAsync();

    private static string ActionLabel(AppointmentUiAction action) => action switch
    {
        AppointmentUiAction.Confirm => "Confirm",
        AppointmentUiAction.CheckIn => "Check in",
        AppointmentUiAction.Complete => "Complete",
        AppointmentUiAction.NoShow => "No-show",
        AppointmentUiAction.Cancel => "Cancel",
        AppointmentUiAction.Reschedule => "Reschedule",
        _ => action.ToString(),
    };
}
