@namespace HealthCare.Web.Components.Appointments
@implements IDialogContentComponent<RescheduleAppointmentDialog.Args>
@using HealthCare.Contracts.Appointments
@using HealthCare.Web.Appointments

@if (Content.Appointment is null)
{
    <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false">Appointment is required.</FluentMessageBar>
}
else
{
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
        <div class="hc-caption">
            Clinic: @(Content.Appointment.ClinicName ?? Content.Appointment.ClinicId.ToString("D"))
            @if (!string.IsNullOrWhiteSpace(Content.Appointment.ClinicTimeZoneId))
            {
                <span> · @Content.Appointment.ClinicTimeZoneId</span>
            }
        </div>

        <FluentSelect TOption="string"
                      Value="@(_doctorId?.ToString() ?? "")"
                      ValueChanged="OnDoctorStringChanged"
                      Label="Doctor"
                      Required="true"
                      Disabled="@(_busy || _doctorsLoading)"
                      Style="width:100%;">
            @foreach (var doctor in _doctors)
            {
                <FluentOption Value="@doctor.StaffMemberId.ToString()">@doctor.DisplayName</FluentOption>
            }
        </FluentSelect>

        <FluentDatePicker Value="_date" ValueChanged="OnDateChanged" Label="New date" Disabled="_busy" Style="width:100%;" />
        <FluentNumberField @bind-Value="_durationMinutes" Label="Duration (minutes)" Min="5" Max="240" Disabled="_busy" Style="width:100%;" @bind-Value:after="OnDurationChangedAfter" />

        <FluentSelect TOption="string"
                      Value="@SelectedSlotKey"
                      ValueChanged="OnSlotKeyChanged"
                      Label="Available slot"
                      Required="true"
                      Disabled="@(_busy || _slotsLoading || _doctorId is null || _date is null)"
                      Style="width:100%;">
            @foreach (var slot in _slots)
            {
                <FluentOption Value="@SlotKey(slot)">@FormatSlot(slot)</FluentOption>
            }
        </FluentSelect>
        @if (_slotsLoading)
        {
            <FluentProgressRing />
        }
        else if (_doctorId is not null && _date is not null && _slots.Count == 0)
        {
            <FluentMessageBar Intent="MessageIntent.Info" AllowDismiss="false">No available slots for this date.</FluentMessageBar>
        }

        <FluentTextField @bind-Value="_reason" Label="Reason (optional)" Disabled="_busy" Style="width:100%;" />
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false">@_error</FluentMessageBar>
        }
    </FluentStack>
}
<FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Style="margin-top:1rem;justify-content:flex-end;">
    <FluentButton Appearance="Appearance.Outline" OnClick="CloseAsync" Disabled="_busy">Back</FluentButton>
    <FluentButton Appearance="Appearance.Accent" OnClick="SubmitAsync" Disabled="_busy || _selectedSlot is null">
        @if (_busy) { <FluentProgressRing Style="width:16px;height:16px;margin-right:0.35rem;" /> }
        Reschedule
    </FluentButton>
</FluentStack>

@code {
    public sealed class Args
    {
        public AppointmentResponse Appointment { get; init; } = default!;
        public bool PlatformAdminBypass { get; init; }
    }

    [Parameter] public Args Content { get; set; } = default!;
    [CascadingParameter] private FluentDialog Dialog { get; set; } = default!;
    [Inject] private IAppointmentApiClient AppointmentsApi { get; set; } = default!;
    [Inject] private IUserNotificationService Notify { get; set; } = default!;

    private AppointmentResponse Appointment => Content.Appointment;
    private bool PlatformAdminBypass => Content.PlatformAdminBypass;

    private Guid? _doctorId;
    private DateTime? _date;
    private int _durationMinutes = 30;
    private AvailableSlotResponse? _selectedSlot;
    private string? _reason;
    private List<ClinicDoctorResponse> _doctors = [];
    private List<AvailableSlotResponse> _slots = [];
    private bool _doctorsLoading;
    private bool _slotsLoading;
    private bool _busy;
    private string? _error;
    private string? _clinicSlug;

    protected override async Task OnInitializedAsync()
    {
        if (Appointment is null)
        {
            return;
        }

        _clinicSlug = Appointment.ClinicSlug;
        _doctorId = Appointment.DoctorStaffMemberId;
        _durationMinutes = Appointment.DurationMinutes;
        _date = ClinicTimeDisplay.ToClinicLocal(Appointment.AppointmentDateUtc, Appointment.ClinicTimeZoneId).DateTime.Date;
        await LoadDoctorsAsync();
        await LoadSlotsAsync();
    }

    private Task OnDurationChangedAfter() => OnDurationChanged(_durationMinutes);

    private async Task OnDoctorStringChanged(string? value)
    {
        Guid? doctorId = Guid.TryParse(value, out var id) ? id : null;
        await OnDoctorChanged(doctorId);
    }

    private string SelectedSlotKey => _selectedSlot is null ? string.Empty : SlotKey(_selectedSlot);

    private static string SlotKey(AvailableSlotResponse slot) =>
        $"{slot.StartUtc:O}|{slot.EndUtc:O}|{slot.DurationMinutes}";

    private Task OnSlotKeyChanged(string? value)
    {
        _selectedSlot = _slots.FirstOrDefault(s => SlotKey(s) == value);
        return Task.CompletedTask;
    }

    private async Task OnDoctorChanged(Guid? doctorId)
    {
        _doctorId = doctorId;
        _selectedSlot = null;
        await LoadSlotsAsync();
    }

    private async Task OnDateChanged(DateTime? date)
    {
        _date = date;
        _selectedSlot = null;
        await LoadSlotsAsync();
    }

    private async Task OnDurationChanged(int duration)
    {
        _durationMinutes = duration;
        _selectedSlot = null;
        await LoadSlotsAsync();
    }

    private async Task LoadDoctorsAsync()
    {
        if (string.IsNullOrWhiteSpace(_clinicSlug))
        {
            _error = "Clinic timezone/slug is missing for this appointment.";
            return;
        }

        _doctorsLoading = true;
        try
        {
            var doctors = await AppointmentsApi.ListClinicDoctorsAsync(_clinicSlug);
            _doctors = doctors.Where(d => d.AcceptsBookings).ToList();
        }
        catch (ApiProblemException ex)
        {
            _error = AppointmentProblemMessages.ToUserMessage(ex);
        }
        finally
        {
            _doctorsLoading = false;
        }
    }

    private async Task LoadSlotsAsync()
    {
        _slots = [];
        if (string.IsNullOrWhiteSpace(_clinicSlug) || _doctorId is not Guid doctorId || _date is not DateTime date)
        {
            return;
        }

        _slotsLoading = true;
        try
        {
            var slots = await AppointmentsApi.GetAvailableSlotsAsync(
                _clinicSlug,
                doctorId,
                DateOnly.FromDateTime(date),
                _durationMinutes);
            _slots = slots.ToList();
        }
        catch (ApiProblemException ex)
        {
            _error = AppointmentProblemMessages.ToUserMessage(ex);
        }
        finally
        {
            _slotsLoading = false;
        }
    }

    private async Task SubmitAsync()
    {
        if (_busy || Appointment is null || _selectedSlot is null || _doctorId is null)
        {
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var updated = await AppointmentsApi.RescheduleAsync(
                Appointment.Id,
                new RescheduleAppointmentRequest
                {
                    DoctorStaffMemberId = _doctorId,
                    AppointmentDateUtc = _selectedSlot.StartUtc,
                    DurationMinutes = _selectedSlot.DurationMinutes,
                    ExpectedVersion = Appointment.Version,
                    Reason = string.IsNullOrWhiteSpace(_reason) ? null : _reason.Trim(),
                },
                PlatformAdminBypass);
            Notify.Success("Appointment rescheduled.");
            await Dialog.CloseAsync(DialogResult.Ok(updated));
        }
        catch (ApiProblemException ex) when (AppointmentProblemMessages.IsConcurrencyConflict(ex))
        {
            _error = AppointmentProblemMessages.ToUserMessage(ex);
            Notify.Warning(_error);
        }
        catch (ApiProblemException ex)
        {
            _error = AppointmentProblemMessages.ToUserMessage(ex);
            Notify.Error(_error);
            if (string.Equals(ex.ErrorCode, "appointment.slot_unavailable", StringComparison.Ordinal))
            {
                await LoadSlotsAsync();
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task CloseAsync() => await Dialog.CancelAsync();

    private static string FormatSlot(AvailableSlotResponse? slot) =>
        slot is null ? string.Empty : $"{slot.StartLocal} – {slot.EndLocal} ({slot.TimeZoneId})";
}
