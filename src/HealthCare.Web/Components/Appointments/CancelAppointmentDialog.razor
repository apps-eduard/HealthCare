@namespace HealthCare.Web.Components.Appointments
@inherits FeedbackComponent<CancelAppointmentDialog.Args>
@using HealthCare.Contracts.Appointments
@using HealthCare.Web.Appointments

<Alert Type="@AlertType.Warning"
       Message="Cancelling an appointment cannot be undone from this screen."
       ShowIcon="true" />
<div style="margin-top:0.75rem;">
    <label>@FieldLabel.Mark("Cancellation reason")</label>
    <TextArea @bind-Value="_reason" Rows="3" Disabled="_busy" Style="width:100%;" />
</div>
@if (!string.IsNullOrWhiteSpace(_error))
{
    <Alert Type="@AlertType.Error" Message="@_error" ShowIcon="true" Style="margin-top:0.5rem;" />
}
<div style="display:flex;gap:8px;justify-content:flex-end;margin-top:1rem;">
    <Button OnClick="CancelCloseAsync" Disabled="_busy">Back</Button>
    <Button Type="@ButtonType.Primary"
            OnClick="SubmitAsync"
            Loading="_busy"
            Disabled="_busy || string.IsNullOrWhiteSpace(_reason)">
        Cancel appointment
    </Button>
</div>

@code {
    public sealed class Args
    {
        public Guid AppointmentId { get; init; }
        public int ExpectedVersion { get; init; }
        public bool PlatformAdminBypass { get; init; }
    }

    [Inject]
    private IAppointmentApiClient AppointmentsApi { get; set; } = default!;

    [Inject]
    private IUserNotificationService Notify { get; set; } = default!;

    private string? _reason;
    private bool _busy;
    private string? _error;

    private Task CancelCloseAsync() => OkCancelRef!.CancelAsync(new ModalClosingEventArgs());

    private Task ConfirmOkAsync() => OkCancelRef!.OkAsync(new ModalClosingEventArgs());

    private async Task SubmitAsync()
    {
        if (_busy || string.IsNullOrWhiteSpace(_reason))
        {
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            await AppointmentsApi.CancelAsync(
                Options.AppointmentId,
                new AppointmentActionRequest
                {
                    ExpectedVersion = Options.ExpectedVersion,
                    CancellationReason = _reason.Trim(),
                },
                Options.PlatformAdminBypass);
            Notify.Success("Appointment cancelled.");
            await ConfirmOkAsync();
        }
        catch (ApiProblemException ex) when (AppointmentProblemMessages.IsConcurrencyConflict(ex))
        {
            _error = AppointmentProblemMessages.ToUserMessage(ex);
            Notify.Warning(_error);
        }
        catch (ApiProblemException ex)
        {
            _error = AppointmentProblemMessages.ToUserMessage(ex);
            Notify.Error(_error);
        }
        finally
        {
            _busy = false;
        }
    }
}
