@namespace HealthCare.Web.Components.Appointments
@using HealthCare.Contracts.Appointments
@using HealthCare.Web.Appointments

<MudDialog>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Class="mb-3">
            Cancelling an appointment cannot be undone from this screen.
        </MudAlert>
        <MudTextField @bind-Value="_reason"
                      Label="Cancellation reason"
                      Required="true"
                      RequiredError="Reason is required"
                      Lines="3"
                      Variant="Variant.Outlined"
                      Disabled="_busy" />
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mt-2">@_error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_busy">Back</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="SubmitAsync" Disabled="_busy || string.IsNullOrWhiteSpace(_reason)">
            @if (_busy)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Cancel appointment
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Guid AppointmentId { get; set; }

    [Parameter]
    public int ExpectedVersion { get; set; }

    [Parameter]
    public bool PlatformAdminBypass { get; set; }

    [Inject]
    private IAppointmentApiClient AppointmentsApi { get; set; } = default!;

    [Inject]
    private ISnackbar Snackbar { get; set; } = default!;

    private string? _reason;
    private bool _busy;
    private string? _error;

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitAsync()
    {
        if (_busy || string.IsNullOrWhiteSpace(_reason))
        {
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var updated = await AppointmentsApi.CancelAsync(
                AppointmentId,
                new AppointmentActionRequest
                {
                    ExpectedVersion = ExpectedVersion,
                    CancellationReason = _reason.Trim(),
                },
                PlatformAdminBypass);
            Snackbar.Add("Appointment cancelled.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(updated));
        }
        catch (ApiProblemException ex) when (AppointmentProblemMessages.IsConcurrencyConflict(ex))
        {
            _error = AppointmentProblemMessages.ToUserMessage(ex);
            Snackbar.Add(_error, Severity.Warning);
        }
        catch (ApiProblemException ex)
        {
            _error = AppointmentProblemMessages.ToUserMessage(ex);
            Snackbar.Add(_error, Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }
}
