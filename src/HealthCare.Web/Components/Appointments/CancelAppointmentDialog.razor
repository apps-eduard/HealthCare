@namespace HealthCare.Web.Components.Appointments
@implements IDialogContentComponent<CancelAppointmentDialog.Args>
@using HealthCare.Contracts.Appointments
@using HealthCare.Web.Appointments

<FluentMessageBar Intent="MessageIntent.Warning" AllowDismiss="false">
    Cancelling an appointment cannot be undone from this screen.
</FluentMessageBar>
<FluentTextField @bind-Value="_reason"
                  Label="Cancellation reason"
                  Required="true"
                  TextFieldType="TextFieldType.Text"
                  Rows="3"
                  Disabled="_busy"
                  Style="width:100%;margin-top:0.75rem;" />
@if (!string.IsNullOrWhiteSpace(_error))
{
    <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false" Style="margin-top:0.5rem;">@_error</FluentMessageBar>
}
<FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Style="margin-top:1rem;justify-content:flex-end;">
    <FluentButton Appearance="Appearance.Outline" OnClick="CancelAsync" Disabled="_busy">Back</FluentButton>
    <FluentButton Appearance="Appearance.Accent" OnClick="SubmitAsync" Disabled="_busy || string.IsNullOrWhiteSpace(_reason)">
        @if (_busy)
        {
            <FluentProgressRing Style="width:16px;height:16px;margin-right:0.35rem;" />
        }
        Cancel appointment
    </FluentButton>
</FluentStack>

@code {
    public sealed class Args
    {
        public Guid AppointmentId { get; init; }
        public int ExpectedVersion { get; init; }
        public bool PlatformAdminBypass { get; init; }
    }

    [Parameter]
    public Args Content { get; set; } = default!;

    [CascadingParameter]
    private FluentDialog Dialog { get; set; } = default!;

    [Inject]
    private IAppointmentApiClient AppointmentsApi { get; set; } = default!;

    [Inject]
    private IUserNotificationService Notify { get; set; } = default!;

    private string? _reason;
    private bool _busy;
    private string? _error;

    private async Task CancelAsync() => await Dialog.CancelAsync();

    private async Task SubmitAsync()
    {
        if (_busy || string.IsNullOrWhiteSpace(_reason))
        {
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var updated = await AppointmentsApi.CancelAsync(
                Content.AppointmentId,
                new AppointmentActionRequest
                {
                    ExpectedVersion = Content.ExpectedVersion,
                    CancellationReason = _reason.Trim(),
                },
                Content.PlatformAdminBypass);
            Notify.Success("Appointment cancelled.");
            await Dialog.CloseAsync(DialogResult.Ok(updated));
        }
        catch (ApiProblemException ex) when (AppointmentProblemMessages.IsConcurrencyConflict(ex))
        {
            _error = AppointmentProblemMessages.ToUserMessage(ex);
            Notify.Warning(_error);
        }
        catch (ApiProblemException ex)
        {
            _error = AppointmentProblemMessages.ToUserMessage(ex);
            Notify.Error(_error);
        }
        finally
        {
            _busy = false;
        }
    }
}
