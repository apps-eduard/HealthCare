@namespace HealthCare.Web.Components.Appointments
@inherits FeedbackComponent<CreateAppointmentDialog.Args>
@using HealthCare.Contracts.Appointments
@using HealthCare.Contracts.Clinics
@using HealthCare.Web.Appointments
@using HealthCare.Web.Components.Clinics
@using HealthCare.Web.Components.Patients

@if (!Permissions.Has(WebPermissions.AppointmentsCreate))
{
    <Alert Type="@AlertType.Error" Message="You do not have permission to create appointments." ShowIcon="true" />
}
else
{
    <div style="display:flex;flex-direction:column;gap:12px;">
        @if (Permissions.IsPlatformAdmin && !PlatformTenant.HasOrganization)
        {
            <Alert Type="@AlertType.Warning"
                   Message="Select an organization in the platform banner before creating an appointment."
                   ShowIcon="true" />
        }
        @if (Permissions.CanFilterByClinic || Permissions.IsPlatformAdmin)
        {
            <ClinicPicker Value="_clinicId"
                          ValueChanged="OnClinicChanged"
                          Label="Clinic"
                          Required="true"
                          AllowClear="false"
                          ActiveOnly="true"
                          PlatformAdminBypass="@(Permissions.IsPlatformAdmin)"
                          PlatformOrganizationId="@(Permissions.IsPlatformAdmin ? PlatformTenant.SelectedOrganizationId : null)"
                          Disabled="@(_busy || (Permissions.IsPlatformAdmin && !PlatformTenant.HasOrganization))" />
        }
        else if (Permissions.Has(WebPermissions.ClinicsRead))
        {
            <ClinicPicker Label="Clinic" AllowClear="false" Required="false" Disabled="true" />
            <div class="hc-caption">Appointments are created in your assigned clinic.</div>
        }

        <PatientPicker Value="_patientId"
                       ValueChanged="OnPatientChanged"
                       ClinicId="_clinicId ?? Permissions.CurrentUser?.ClinicId"
                       PlatformAdminBypass="@(Permissions.IsPlatformAdmin)"
                       Required="true"
                       Disabled="_busy || (Permissions.CanFilterByClinic && _clinicId is null)" />

        <div>
            <label>@FieldLabel.Mark("Doctor")</label>
            <Select TItemValue="string"
                    TItem="string"
                    Value="@(_doctorId?.ToString() ?? "")"
                    ValueChanged="OnDoctorStringChanged"
                    Disabled="@(_busy || string.IsNullOrWhiteSpace(_clinicSlug) || _doctorsLoading)"
                    Style="width:100%;">
                <SelectOptions>
                    @foreach (var doctor in _doctors)
                    {
                        <SelectOption TItemValue="string"
                                      TItem="string"
                                      Value="@doctor.StaffMemberId.ToString()"
                                      Label="@doctor.DisplayName" />
                    }
                </SelectOptions>
            </Select>
        </div>
        @if (_doctorsLoading)
        {
            <Spin Size="@SpinSize.Small" />
        }
        else if (!string.IsNullOrWhiteSpace(_clinicSlug) && _doctors.Count == 0)
        {
            <div class="hc-caption">No bookable doctors for this clinic.</div>
        }

        <div>
            <label>Date</label>
            <DatePicker TValue="DateTime?"
                        Value="_date"
                        OnChange="OnDatePickerChanged"
                        Disabled="@(_busy || _doctorId is null)"
                        Style="width:100%;" />
        </div>
        <div>
            <label>Duration (minutes)</label>
            <AntDesign.InputNumber TValue="int"
                                   @bind-Value="_durationMinutes"
                                   OnChange="OnDurationNumberChanged"
                                   Disabled="@(_busy || _doctorId is null)"
                                   Style="width:100%;"
                                   Min="5"
                                   Max="240" />
        </div>

        <div>
            <label>@FieldLabel.Mark("Available slot")</label>
            <Select TItemValue="string"
                    TItem="string"
                    Value="@SelectedSlotKey"
                    ValueChanged="OnSlotKeyChanged"
                    Disabled="@(_busy || _slotsLoading || _doctorId is null || _date is null)"
                    Style="width:100%;">
                <SelectOptions>
                    @foreach (var slot in _slots)
                    {
                        <SelectOption TItemValue="string" TItem="string" Value="@SlotKey(slot)" Label="@FormatSlot(slot)" />
                    }
                </SelectOptions>
            </Select>
        </div>
        @if (_slotsLoading)
        {
            <Spin Size="@SpinSize.Small" />
        }
        else if (_doctorId is not null && _date is not null && _slots.Count == 0)
        {
            <Alert Type="@AlertType.Info" Message="No available slots for this date." ShowIcon="true" />
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <Alert Type="@AlertType.Error" Message="@_error" ShowIcon="true" />
        }
    </div>
}
<div style="display:flex;gap:8px;justify-content:flex-end;margin-top:1rem;">
    <Button OnClick="CancelCloseAsync" Disabled="_busy">Cancel</Button>
    <Button Type="@ButtonType.Primary" OnClick="SubmitAsync" Loading="_busy" Disabled="_busy || !CanSubmit">
        Create
    </Button>
</div>

@code {
    public sealed class Args
    {
        public Guid? InitialClinicId { get; init; }
        public bool PlatformAdminBypass { get; init; }
    }

    [Inject] private IAppointmentApiClient AppointmentsApi { get; set; } = default!;
    [Inject] private IClinicDirectoryApiClient ClinicsApi { get; set; } = default!;
    [Inject] private IClinicDirectoryCache ClinicCache { get; set; } = default!;
    [Inject] private IPermissionState Permissions { get; set; } = default!;
    [Inject] private IPlatformTenantContext PlatformTenant { get; set; } = default!;
    [Inject] private IUserNotificationService Notify { get; set; } = default!;

    private Guid? InitialClinicId => Options.InitialClinicId;
    private bool PlatformAdminBypass => Options.PlatformAdminBypass;

    private Guid? _clinicId;
    private string? _clinicSlug;
    private string? _clinicTimeZoneId;
    private Guid? _patientId;
    private Guid? _doctorId;
    private DateTime? _date = DateTime.Today;
    private int _durationMinutes = 30;
    private AvailableSlotResponse? _selectedSlot;
    private List<ClinicDoctorResponse> _doctors = [];
    private List<AvailableSlotResponse> _slots = [];
    private bool _doctorsLoading;
    private bool _slotsLoading;
    private bool _busy;
    private string? _error;

    private bool CanSubmit =>
        Permissions.Has(WebPermissions.AppointmentsCreate)
        && _patientId is not null
        && _doctorId is not null
        && _selectedSlot is not null
        && (!_busy)
        && (!Permissions.IsPlatformAdmin || (PlatformTenant.HasOrganization && _clinicId is not null))
        && (!Permissions.CanFilterByClinic || _clinicId is not null || !Permissions.IsOrganizationAdmin);

    protected override async Task OnInitializedAsync()
    {
        if (Permissions.IsPlatformAdmin && PlatformTenant.HasClinic)
        {
            _clinicId = PlatformTenant.SelectedClinicId;
        }
        else if (InitialClinicId is Guid clinicId)
        {
            _clinicId = clinicId;
        }
        else if (!Permissions.CanFilterByClinic && Permissions.CurrentUser?.ClinicId is Guid membershipClinic)
        {
            _clinicId = membershipClinic;
        }

        if (_clinicId is Guid resolvedClinic)
        {
            await ResolveClinicMetaAsync(resolvedClinic);
            await LoadDoctorsAsync();
        }
    }

    private async Task OnClinicChanged(Guid? clinicId)
    {
        _clinicId = clinicId;
        _doctorId = null;
        _selectedSlot = null;
        _doctors = [];
        _slots = [];
        _clinicSlug = null;
        _clinicTimeZoneId = null;
        if (clinicId is Guid id)
        {
            await ResolveClinicMetaAsync(id);
            await LoadDoctorsAsync();
        }
    }

    private Task OnPatientChanged(Guid? patientId)
    {
        _patientId = patientId;
        return Task.CompletedTask;
    }

    private async Task OnDurationNumberChanged(int value)
    {
        await OnDurationChanged(Math.Clamp(value, 5, 240));
    }

    private async Task OnDoctorStringChanged(string value)
    {
        Guid? doctorId = Guid.TryParse(value, out var id) ? id : null;
        await OnDoctorChanged(doctorId);
    }

    private string SelectedSlotKey => _selectedSlot is null ? string.Empty : SlotKey(_selectedSlot);

    private static string SlotKey(AvailableSlotResponse slot) =>
        $"{slot.StartUtc:O}|{slot.EndUtc:O}|{slot.DurationMinutes}";

    private Task OnSlotKeyChanged(string value)
    {
        _selectedSlot = _slots.FirstOrDefault(s => SlotKey(s) == value);
        return Task.CompletedTask;
    }

    private async Task OnDoctorChanged(Guid? doctorId)
    {
        _doctorId = doctorId;
        _selectedSlot = null;
        _slots = [];
        await LoadSlotsAsync();
    }

    private Task OnDatePickerChanged(DateTimeChangedEventArgs<DateTime?> args) =>
        OnDateChanged(args.Date);

    private async Task OnDateChanged(DateTime? date)
    {
        _date = date;
        _selectedSlot = null;
        await LoadSlotsAsync();
    }

    private async Task OnDurationChanged(int duration)
    {
        _durationMinutes = duration;
        _selectedSlot = null;
        await LoadSlotsAsync();
    }

    private async Task ResolveClinicMetaAsync(Guid clinicId)
    {
        try
        {
            if (ClinicCache.TryGet(clinicId, out var cached) && cached is not null)
            {
                _clinicSlug = cached.Slug;
                _clinicTimeZoneId = cached.TimeZoneId;
                return;
            }

            var detail = await ClinicsApi.GetByIdAsync(clinicId, Permissions.IsPlatformAdmin);
            ClinicCache.Set(detail);
            _clinicSlug = detail.Slug;
            _clinicTimeZoneId = detail.TimeZoneId;
        }
        catch (ApiProblemException ex)
        {
            _error = AppointmentProblemMessages.ToUserMessage(ex);
        }
    }

    private async Task LoadDoctorsAsync()
    {
        _doctors = [];
        if (!Permissions.Has(WebPermissions.AvailabilityRead))
        {
            return;
        }

        if (_clinicId is not Guid clinicId
            && string.IsNullOrWhiteSpace(_clinicSlug))
        {
            return;
        }

        _doctorsLoading = true;
        try
        {
            IReadOnlyList<ClinicDoctorResponse> doctors;
            if (_clinicId is Guid id)
            {
                doctors = await AppointmentsApi.ListClinicDoctorsByIdAsync(
                    id,
                    platformAdminBypass: PlatformAdminBypass || Permissions.IsPlatformAdmin);
            }
            else
            {
                doctors = await AppointmentsApi.ListClinicDoctorsAsync(_clinicSlug!);
            }

            _doctors = doctors.Where(d => d.AcceptsBookings).ToList();
        }
        catch (ApiProblemException ex)
        {
            _error = AppointmentProblemMessages.ToUserMessage(ex);
        }
        finally
        {
            _doctorsLoading = false;
        }
    }

    private async Task LoadSlotsAsync()
    {
        _slots = [];
        if (string.IsNullOrWhiteSpace(_clinicSlug)
            || _doctorId is not Guid doctorId
            || _date is not DateTime date
            || !Permissions.Has(WebPermissions.AvailabilityRead))
        {
            return;
        }

        _slotsLoading = true;
        try
        {
            var slots = await AppointmentsApi.GetAvailableSlotsAsync(
                _clinicSlug,
                doctorId,
                DateOnly.FromDateTime(date),
                _durationMinutes);
            _slots = slots.ToList();
        }
        catch (ApiProblemException ex)
        {
            _error = AppointmentProblemMessages.ToUserMessage(ex);
        }
        finally
        {
            _slotsLoading = false;
        }
    }

    private async Task SubmitAsync()
    {
        if (!CanSubmit || _selectedSlot is null || _patientId is null || _doctorId is null || _busy)
        {
            return;
        }

        if (Permissions.IsPlatformAdmin
            && (!PlatformTenant.HasOrganization || _clinicId is null || _clinicId == Guid.Empty))
        {
            _error = "Select organization and clinic before creating an appointment.";
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var bypass = (PlatformAdminBypass || Permissions.IsPlatformAdmin) && _clinicId is not null;

            await AppointmentsApi.CreateStaffAsync(
                new CreateStaffAppointmentRequest
                {
                    PatientId = _patientId.Value,
                    DoctorStaffMemberId = _doctorId.Value,
                    AppointmentDateUtc = _selectedSlot.StartUtc,
                    DurationMinutes = _selectedSlot.DurationMinutes,
                    ClinicId = Permissions.CanFilterByClinic || Permissions.IsPlatformAdmin ? _clinicId : null,
                },
                bypass);

            Notify.Success("Appointment created.");
            await LoadSlotsAsync();
            await ConfirmOkAsync();
        }
        catch (ApiProblemException ex)
        {
            _error = AppointmentProblemMessages.ToUserMessage(ex);
            Notify.Error(_error);
            if (string.Equals(ex.ErrorCode, "appointment.slot_unavailable", StringComparison.Ordinal))
            {
                await LoadSlotsAsync();
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private Task CancelCloseAsync() => OkCancelRef!.CancelAsync(new ModalClosingEventArgs());

    private Task ConfirmOkAsync() => OkCancelRef!.OkAsync(new ModalClosingEventArgs());

    private static string FormatSlot(AvailableSlotResponse? slot) =>
        slot is null ? string.Empty : $"{slot.StartLocal} – {slot.EndLocal} ({slot.TimeZoneId})";
}
