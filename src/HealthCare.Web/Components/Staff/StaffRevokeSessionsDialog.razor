@inherits FeedbackComponent<StaffRevokeSessionsDialog.Args>
@inject IStaffManagementApiClient StaffApi
@inject IPermissionState Permissions

<p style="margin-top:0">
    Revoke refresh tokens and update the security stamp for <b>@Options.DisplayName</b>.
    Existing API/BFF sessions fail on next validation.
</p>

<div style="display:flex;flex-direction:column;gap:12px;">
    <div>
        <label>Reason (optional)</label>
        <Input @bind-Value="_reason" Disabled="_busy" Style="width:100%;" />
    </div>
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <Alert Type="@AlertType.Error" Message="@_error" ShowIcon="true" />
    }
</div>
<div style="display:flex;gap:8px;justify-content:flex-end;margin-top:1rem;">
    <Button OnClick="CancelCloseAsync" Disabled="_busy">Cancel</Button>
    <Button Type="@ButtonType.Primary" Danger OnClick="SubmitAsync" Loading="_busy" Disabled="_busy">Revoke sessions</Button>
</div>

@code {
    public sealed class Args
    {
        public Guid StaffMemberId { get; init; }
        public string DisplayName { get; init; } = string.Empty;
    }

    private string? _reason;
    private bool _busy;
    private string? _error;

    private async Task SubmitAsync()
    {
        _error = null;
        _busy = true;
        try
        {
            await StaffApi.RevokeSessionsAsync(
                Options.StaffMemberId,
                new RevokeStaffSessionsRequest { Reason = _reason },
                platformAdminBypass: Permissions.IsPlatformAdmin);
            await OkCancelRef!.OkAsync(new ModalClosingEventArgs());
        }
        catch (ApiProblemException ex)
        {
            _error = StaffProblemMessages.From(ex);
        }
        finally
        {
            _busy = false;
        }
    }

    private Task CancelCloseAsync() => OkCancelRef!.CancelAsync(new ModalClosingEventArgs());
}
