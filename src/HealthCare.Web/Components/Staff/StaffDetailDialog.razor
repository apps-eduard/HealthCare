@implements IDialogContentComponent<StaffDetailDialog.Args>
@inject IStaffManagementApiClient StaffApi
@inject IPermissionState Permissions

@if (_loading)
{
    <PageLoading />
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false">@_error</FluentMessageBar>
}
else if (_detail is not null)
{
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
        <div><b>Name:</b> @($"{_detail.FirstName} {_detail.LastName}")</div>
        <div><b>Display name:</b> @(_detail.DisplayName ?? "—")</div>
        <div><b>Email:</b> @_detail.Email</div>
        <div><b>Job title:</b> @(_detail.JobTitle ?? "—")</div>
        <div><b>Phone:</b> @(_detail.PhoneNumber ?? "—")</div>
        <div><b>Organization:</b> @_detail.OrganizationId</div>
        <div><b>Clinic:</b> @_detail.ClinicId</div>
        <div><b>Role:</b> @_detail.Role</div>
        <div><b>Membership:</b> @(_detail.MembershipIsActive ? "Active" : "Inactive")</div>
        <div><b>Account enabled:</b> @(_detail.AccountIsActive ? "Yes" : "No")</div>
        <div><b>Email confirmed:</b> @(_detail.EmailConfirmed ? "Yes" : "No")</div>
        <div><b>Created:</b> @_detail.CreatedAtUtc.ToString("u")</div>
        <div><b>Updated:</b> @_detail.UpdatedAtUtc.ToString("u")</div>
        <div class="hc-caption">Version @_detail.Version</div>
    </FluentStack>
}
<FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Style="margin-top:1rem;justify-content:flex-end;">
    <FluentButton Appearance="Appearance.Outline" OnClick="CloseAsync">Close</FluentButton>
</FluentStack>

@code {
    public sealed class Args
    {
        public Guid StaffMemberId { get; init; }
    }

    [Parameter]
    public Args Content { get; set; } = default!;

    [CascadingParameter]
    private FluentDialog Dialog { get; set; } = default!;

    private StaffDetailResponse? _detail;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var bypass = Permissions.CurrentUser?.Roles.Contains(WebRoles.PlatformAdmin, StringComparer.Ordinal) == true;
            _detail = await StaffApi.GetByIdAsync(Content.StaffMemberId, platformAdminBypass: bypass);
        }
        catch (ApiProblemException ex)
        {
            _error = ex.ToUserMessage();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CloseAsync() => await Dialog.CloseAsync();
}
