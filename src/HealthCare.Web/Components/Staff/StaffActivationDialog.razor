@implements IDialogContentComponent<StaffActivationDialog.Args>
@inject IStaffManagementApiClient StaffApi
@inject IPermissionState Permissions

<p style="margin-top:0">
    @(Content.Activate ? "Activate" : "Deactivate") <b>@Content.DisplayName</b>?
</p>
<FluentTextField @bind-Value="_reason" Label="Administrative reason (optional)" Disabled="_busy" Style="width:100%;" />
@if (!string.IsNullOrWhiteSpace(_error))
{
    <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false" Style="margin-top:0.75rem;">@_error</FluentMessageBar>
}
<FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Style="margin-top:1rem;justify-content:flex-end;">
    <FluentButton Appearance="Appearance.Outline" OnClick="CancelAsync" Disabled="_busy">Cancel</FluentButton>
    <FluentButton Appearance="Appearance.Accent" OnClick="SubmitAsync" Disabled="_busy">
        @(Content.Activate ? "Activate" : "Deactivate")
    </FluentButton>
</FluentStack>

@code {
    public sealed class Args
    {
        public Guid StaffMemberId { get; init; }
        public int ExpectedVersion { get; init; }
        public bool Activate { get; init; }
        public string DisplayName { get; init; } = string.Empty;
    }

    [Parameter]
    public Args Content { get; set; } = default!;

    [CascadingParameter]
    private FluentDialog Dialog { get; set; } = default!;

    private string? _reason;
    private string? _error;
    private bool _busy;

    private async Task CancelAsync() => await Dialog.CancelAsync();

    private async Task SubmitAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var bypass = Permissions.CurrentUser?.Roles.Contains(WebRoles.PlatformAdmin, StringComparer.Ordinal) == true;
            var request = new StaffActivationRequest
            {
                ExpectedVersion = Content.ExpectedVersion,
                Reason = string.IsNullOrWhiteSpace(_reason) ? null : _reason.Trim(),
            };

            if (Content.Activate)
            {
                await StaffApi.ActivateAsync(Content.StaffMemberId, request, bypass);
            }
            else
            {
                await StaffApi.DeactivateAsync(Content.StaffMemberId, request, bypass);
            }

            await Dialog.CloseAsync(DialogResult.Ok(true));
        }
        catch (ApiProblemException ex)
        {
            _error = ex.ErrorCode switch
            {
                StaffErrorCodes.ConcurrencyConflict => "This record changed. Reload the list and try again.",
                StaffErrorCodes.LastAdminProtected => "The last administrator in scope cannot be deactivated.",
                _ => ex.ToUserMessage(),
            };
        }
        finally
        {
            _busy = false;
        }
    }
}
