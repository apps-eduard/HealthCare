@inherits FeedbackComponent<StaffActivationDialog.Args>
@inject IStaffManagementApiClient StaffApi
@inject IPermissionState Permissions

<p style="margin-top:0">
    @(Options.Activate ? "Activate" : "Deactivate") <b>@Options.DisplayName</b>?
</p>
<div>
    <label>Administrative reason (optional)</label>
    <Input @bind-Value="_reason" Disabled="_busy" Style="width:100%;" />
</div>
@if (!string.IsNullOrWhiteSpace(_error))
{
    <Alert Type="@AlertType.Error" Message="@_error" ShowIcon="true" Style="margin-top:0.75rem;" />
}
<div style="display:flex;gap:8px;justify-content:flex-end;margin-top:1rem;">
    <Button OnClick="CancelCloseAsync" Disabled="_busy">Cancel</Button>
    <Button Type="@ButtonType.Primary" OnClick="SubmitAsync" Loading="_busy" Disabled="_busy">
        @(Options.Activate ? "Activate" : "Deactivate")
    </Button>
</div>

@code {
    public sealed class Args
    {
        public Guid StaffMemberId { get; init; }
        public int ExpectedVersion { get; init; }
        public bool Activate { get; init; }
        public string DisplayName { get; init; } = string.Empty;
    }

    private string? _reason;
    private string? _error;
    private bool _busy;

    private Task CancelCloseAsync() => OkCancelRef!.CancelAsync(new ModalClosingEventArgs());

    private Task ConfirmOkAsync() => OkCancelRef!.OkAsync(new ModalClosingEventArgs());

    private async Task SubmitAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var bypass = Permissions.CurrentUser?.Roles.Contains(WebRoles.PlatformAdmin, StringComparer.Ordinal) == true;
            var request = new StaffActivationRequest
            {
                ExpectedVersion = Options.ExpectedVersion,
                Reason = string.IsNullOrWhiteSpace(_reason) ? null : _reason.Trim(),
            };

            if (Options.Activate)
            {
                await StaffApi.ActivateAsync(Options.StaffMemberId, request, bypass);
            }
            else
            {
                await StaffApi.DeactivateAsync(Options.StaffMemberId, request, bypass);
            }

            await ConfirmOkAsync();
        }
        catch (ApiProblemException ex)
        {
            _error = StaffProblemMessages.From(ex);
        }
        finally
        {
            _busy = false;
        }
    }
}
