@inject IStaffManagementApiClient StaffApi
@inject IPermissionState Permissions

<MudDialog>
    <DialogContent>
        <MudText Class="mb-3">
            @(Activate ? "Activate" : "Deactivate") <b>@DisplayName</b>?
        </MudText>
        <MudTextField @bind-Value="_reason" Label="Administrative reason (optional)" Disabled="_busy" />
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">@_error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Disabled="_busy">Cancel</MudButton>
        <MudButton Color="@(Activate ? Color.Success : Color.Warning)"
                   Variant="Variant.Filled"
                   OnClick="SubmitAsync"
                   Disabled="_busy">
            @(Activate ? "Activate" : "Deactivate")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Guid StaffMemberId { get; set; }

    [Parameter]
    public int ExpectedVersion { get; set; }

    [Parameter]
    public bool Activate { get; set; }

    [Parameter]
    public string DisplayName { get; set; } = string.Empty;

    private string? _reason;
    private string? _error;
    private bool _busy;

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var bypass = Permissions.CurrentUser?.Roles.Contains(WebRoles.PlatformAdmin, StringComparer.Ordinal) == true;
            var request = new StaffActivationRequest
            {
                ExpectedVersion = ExpectedVersion,
                Reason = string.IsNullOrWhiteSpace(_reason) ? null : _reason.Trim(),
            };

            if (Activate)
            {
                await StaffApi.ActivateAsync(StaffMemberId, request, bypass);
            }
            else
            {
                await StaffApi.DeactivateAsync(StaffMemberId, request, bypass);
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (ApiProblemException ex)
        {
            _error = ex.ErrorCode switch
            {
                StaffErrorCodes.ConcurrencyConflict => "This record changed. Reload the list and try again.",
                StaffErrorCodes.LastAdminProtected => "The last administrator in scope cannot be deactivated.",
                _ => ex.ToUserMessage(),
            };
        }
        finally
        {
            _busy = false;
        }
    }
}
