@inherits FeedbackComponent<StaffPasswordResetDialog.Args>
@inject IStaffManagementApiClient StaffApi
@inject IPermissionState Permissions

<p style="margin-top:0">
    Initiate a password reset for <b>@Options.DisplayName</b>. Active sessions will be revoked.
    The reset token is delivered through the email abstraction (Development captures it for testing).
</p>

<div style="display:flex;flex-direction:column;gap:12px;">
    <div>
        <label>Reason (optional)</label>
        <Input @bind-Value="_reason" Disabled="_busy" Style="width:100%;" />
    </div>
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <Alert Type="@AlertType.Error" Message="@_error" ShowIcon="true" />
    }
    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <Alert Type="@AlertType.Success" Message="@_message" ShowIcon="true" />
    }
</div>
<div style="display:flex;gap:8px;justify-content:flex-end;margin-top:1rem;">
    <Button OnClick="CancelCloseAsync" Disabled="_busy">Close</Button>
    <Button Type="@ButtonType.Primary" OnClick="SubmitAsync" Loading="_busy" Disabled="_busy || !string.IsNullOrWhiteSpace(_message)">
        Send reset
    </Button>
</div>

@code {
    public sealed class Args
    {
        public Guid StaffMemberId { get; init; }
        public string DisplayName { get; init; } = string.Empty;
    }

    private string? _reason;
    private bool _busy;
    private string? _error;
    private string? _message;

    private async Task SubmitAsync()
    {
        _error = null;
        _busy = true;
        try
        {
            var result = await StaffApi.RequestPasswordResetAsync(
                Options.StaffMemberId,
                new StaffPasswordResetRequest { Reason = _reason },
                platformAdminBypass: Permissions.IsPlatformAdmin);
            _message = result.Message;
            await OkCancelRef!.OkAsync(new ModalClosingEventArgs());
        }
        catch (ApiProblemException ex)
        {
            _error = StaffProblemMessages.From(ex);
        }
        finally
        {
            _busy = false;
        }
    }

    private Task CancelCloseAsync() => OkCancelRef!.CancelAsync(new ModalClosingEventArgs());
}
