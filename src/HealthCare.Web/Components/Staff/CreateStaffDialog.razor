@inherits FeedbackComponent<CreateStaffDialog.Args>
@inject IStaffManagementApiClient StaffApi
@inject IPermissionState Permissions
@inject IPlatformTenantContext PlatformTenant

<div style="display:flex;flex-direction:column;gap:12px;">
    <div>
        <label>@FieldLabel.Mark("Email")</label>
        <Input @bind-Value="_email" Disabled="_busy" Style="width:100%;" />
    </div>
    <div>
        <label>@FieldLabel.Mark("First name")</label>
        <Input @bind-Value="_firstName" Disabled="_busy" Style="width:100%;" />
    </div>
    <div>
        <label>@FieldLabel.Mark("Last name")</label>
        <Input @bind-Value="_lastName" Disabled="_busy" Style="width:100%;" />
    </div>
    <div>
        <label>Display name</label>
        <Input @bind-Value="_displayName" Disabled="_busy" Style="width:100%;" />
    </div>
    <div>
        <label>Job title</label>
        <Input @bind-Value="_jobTitle" Disabled="_busy" Style="width:100%;" />
    </div>
    <div>
        <label>Phone</label>
        <Input @bind-Value="_phone" Disabled="_busy" Style="width:100%;" />
    </div>
    @if (Permissions.IsPlatformAdmin && !PlatformTenant.HasOrganization)
    {
        <Alert Type="@AlertType.Warning"
               Message="Select an organization in the platform banner before creating staff."
               ShowIcon="true" />
    }
    @if (Permissions.CanFilterByClinic)
    {
        <ClinicPicker @bind-Value="_clinicId"
                      Label="Clinic"
                      Required="true"
                      AllowClear="false"
                      Disabled="@(_busy || (Permissions.IsPlatformAdmin && !PlatformTenant.HasOrganization))"
                      ActiveOnly="true"
                      PlatformAdminBypass="@(Permissions.IsPlatformAdmin)"
                      PlatformOrganizationId="@(Permissions.IsPlatformAdmin ? PlatformTenant.SelectedOrganizationId : null)"
                      HelperText="Choose an authorized clinic." />
    }
    else if (Permissions.Has(WebPermissions.ClinicsRead))
    {
        <ClinicPicker Label="Clinic" AllowClear="false" Disabled="true" />
    }
    <div>
        <label>Initial role</label>
        <Select TItemValue="string"
                TItem="string"
                @bind-Value="_role"
                Disabled="@(_busy || _rolesLoading)"
                Style="width:100%;">
            <SelectOptions>
                @foreach (var role in _roles.Where(r => r.AssignableByCurrentUser))
                {
                    <SelectOption TItemValue="string" TItem="string" Value="@role.Name" Label="@role.DisplayLabel" />
                }
            </SelectOptions>
        </Select>
    </div>
    <div>
        <label>@FieldLabel.Mark("Temporary password")</label>
        <InputPassword @bind-Value="_temporaryPassword" Disabled="_busy" Style="width:100%;" />
    </div>
    <div>
        <label>@FieldLabel.Mark("Confirm temporary password")</label>
        <InputPassword @bind-Value="_confirmPassword" Disabled="_busy" Style="width:100%;" />
    </div>
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <Alert Type="@AlertType.Error" Message="@_error" ShowIcon="true" />
    }
</div>
<div style="display:flex;gap:8px;justify-content:flex-end;margin-top:1rem;">
    <Button OnClick="CancelCloseAsync" Disabled="_busy">Cancel</Button>
    <Button Type="@ButtonType.Primary" OnClick="SubmitAsync" Loading="_busy" Disabled="_busy">Create</Button>
</div>

@code {
    public sealed class Args
    {
        public string? PreferredRole { get; init; }
    }

    private List<StaffRoleInfoResponse> _roles = [];
    private bool _rolesLoading = true;
    private bool _busy;
    private string? _error;

    private string _email = string.Empty;
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private string? _displayName;
    private string? _jobTitle;
    private string? _phone;
    private Guid? _clinicId;
    private string? _role;
    private string _temporaryPassword = string.Empty;
    private string _confirmPassword = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (Permissions.IsPlatformAdmin && PlatformTenant.HasClinic)
        {
            _clinicId = PlatformTenant.SelectedClinicId;
        }

        if (!Permissions.Has(WebPermissions.RolesRead))
        {
            _error = "Assignable roles could not be loaded (roles.read required).";
            _rolesLoading = false;
            return;
        }

        try
        {
            _roles = (await StaffApi.ListRolesAsync()).ToList();
            var preferred = Options?.PreferredRole;
            _role = _roles.FirstOrDefault(r =>
                         r.AssignableByCurrentUser
                         && preferred is not null
                         && string.Equals(r.Name, preferred, StringComparison.Ordinal))
                     ?.Name
                 ?? _roles.FirstOrDefault(r => r.AssignableByCurrentUser)?.Name;
        }
        catch (ApiProblemException ex)
        {
            _error = ex.ToUserMessage();
        }
        finally
        {
            _rolesLoading = false;
        }
    }

    private Task CancelCloseAsync() => OkCancelRef!.CancelAsync(new ModalClosingEventArgs());

    private Task ConfirmOkAsync() => OkCancelRef!.OkAsync(new ModalClosingEventArgs());

    private async Task SubmitAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_email)
            || string.IsNullOrWhiteSpace(_firstName)
            || string.IsNullOrWhiteSpace(_lastName)
            || string.IsNullOrWhiteSpace(_role)
            || string.IsNullOrWhiteSpace(_temporaryPassword))
        {
            _error = "Email, names, role, and temporary password are required.";
            return;
        }

        if (!string.Equals(_temporaryPassword, _confirmPassword, StringComparison.Ordinal))
        {
            _error = "Temporary password confirmation does not match.";
            return;
        }

        Guid? clinicId = null;
        if (Permissions.CanFilterByClinic)
        {
            if (_clinicId is null || _clinicId == Guid.Empty)
            {
                _error = "Select an authorized clinic.";
                return;
            }

            if (Permissions.IsPlatformAdmin
                && (!PlatformTenant.HasOrganization || PlatformTenant.SelectedOrganizationId is null))
            {
                _error = "Organization scope is required for platform clinic selection.";
                return;
            }

            clinicId = _clinicId;
        }

        _busy = true;
        try
        {
            var bypass = Permissions.IsPlatformAdmin && clinicId is not null;

            await StaffApi.CreateAsync(new CreateStaffRequest
            {
                Email = _email.Trim(),
                FirstName = _firstName.Trim(),
                LastName = _lastName.Trim(),
                DisplayName = string.IsNullOrWhiteSpace(_displayName) ? null : _displayName.Trim(),
                JobTitle = string.IsNullOrWhiteSpace(_jobTitle) ? null : _jobTitle.Trim(),
                PhoneNumber = string.IsNullOrWhiteSpace(_phone) ? null : _phone.Trim(),
                ClinicId = clinicId,
                Role = _role!,
                TemporaryPassword = _temporaryPassword,
            }, platformAdminBypass: bypass);

            _temporaryPassword = string.Empty;
            _confirmPassword = string.Empty;
            await ConfirmOkAsync();
        }
        catch (ApiProblemException ex)
        {
            _error = ex.ToUserMessage();
            _temporaryPassword = string.Empty;
            _confirmPassword = string.Empty;
        }
        finally
        {
            _busy = false;
        }
    }
}
