@inherits FeedbackComponent<StaffRolesDialog.Args>
@inject IStaffManagementApiClient StaffApi
@inject IPermissionState Permissions

<p style="margin-top:0">Update role for <b>@Options.DisplayName</b></p>
<div class="hc-caption" style="margin-bottom:0.75rem;">Current role: @Options.CurrentRole</div>

@if (_loading)
{
    <PageLoading />
}
else
{
    <div>
        <label>Assignable role</label>
        <Select TItemValue="string"
                TItem="string"
                @bind-Value="_selectedRole"
                Disabled="_busy"
                Style="width:100%;">
            <SelectOptions>
                @foreach (var role in _roles.Where(r => r.AssignableByCurrentUser))
                {
                    <SelectOption TItemValue="string" TItem="string" Value="@role.Name" Label="@role.DisplayLabel" />
                }
            </SelectOptions>
        </Select>
    </div>

    @if (_roles.Any(r => !r.AssignableByCurrentUser))
    {
        <div class="hc-caption" style="margin-top:0.5rem;">
            Not assignable: @string.Join(", ", _roles.Where(r => !r.AssignableByCurrentUser).Select(r => r.DisplayLabel))
        </div>
    }
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <Alert Type="@AlertType.Error" Message="@_error" ShowIcon="true" Style="margin-top:0.75rem;" />
}
<div style="display:flex;gap:8px;justify-content:flex-end;margin-top:1rem;">
    <Button OnClick="CancelCloseAsync" Disabled="_busy">Cancel</Button>
    <Button Type="@ButtonType.Primary"
            OnClick="SubmitAsync"
            Loading="_busy"
            Disabled="_busy || string.IsNullOrWhiteSpace(_selectedRole)">
        Assign role
    </Button>
</div>

@code {
    public sealed class Args
    {
        public Guid StaffMemberId { get; init; }
        public Guid TargetUserId { get; init; }
        public string CurrentRole { get; init; } = string.Empty;
        public string DisplayName { get; init; } = string.Empty;
    }

    private List<StaffRoleInfoResponse> _roles = [];
    private string? _selectedRole;
    private bool _loading = true;
    private bool _busy;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (!Permissions.Has(WebPermissions.RolesRead))
        {
            _error = "roles.read is required to load assignable roles.";
            _loading = false;
            return;
        }

        try
        {
            _roles = (await StaffApi.ListRolesAsync()).ToList();
            _selectedRole = _roles.FirstOrDefault(r => r.AssignableByCurrentUser && r.Name != Options.CurrentRole)?.Name
                            ?? _roles.FirstOrDefault(r => r.AssignableByCurrentUser)?.Name;
        }
        catch (ApiProblemException ex)
        {
            _error = ex.ToUserMessage();
        }
        finally
        {
            _loading = false;
        }
    }

    private Task CancelCloseAsync() => OkCancelRef!.CancelAsync(new ModalClosingEventArgs());

    private Task ConfirmOkAsync() => OkCancelRef!.OkAsync(new ModalClosingEventArgs());

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedRole) || !Permissions.Has(WebPermissions.RolesAssign))
        {
            _error = "Role assignment is not available.";
            return;
        }

        if (string.Equals(_selectedRole, Options.CurrentRole, StringComparison.Ordinal))
        {
            await ConfirmOkAsync();
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var bypass = Permissions.CurrentUser?.Roles.Contains(WebRoles.PlatformAdmin, StringComparer.Ordinal) == true;
            await StaffApi.AssignRoleAsync(Options.StaffMemberId, _selectedRole, bypass);
            await ConfirmOkAsync();
        }
        catch (ApiProblemException ex)
        {
            _error = ex.ErrorCode switch
            {
                StaffErrorCodes.SelfElevationDenied => "You cannot elevate your own role.",
                StaffErrorCodes.LastAdminProtected => "The last administrator in scope is protected.",
                StaffErrorCodes.RoleAssignmentDenied => "That role assignment is not permitted.",
                _ => ex.ToUserMessage(),
            };
        }
        finally
        {
            _busy = false;
        }
    }
}
