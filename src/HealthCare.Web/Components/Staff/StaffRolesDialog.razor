@implements IDialogContentComponent<StaffRolesDialog.Args>
@inject IStaffManagementApiClient StaffApi
@inject IPermissionState Permissions

<p style="margin-top:0">Update role for <b>@Content.DisplayName</b></p>
<div class="hc-caption" style="margin-bottom:0.75rem;">Current role: @Content.CurrentRole</div>

@if (_loading)
{
    <PageLoading />
}
else
{
    <FluentSelect TOption="string"
                  Label="Assignable role"
                  @bind-Value="_selectedRole"
                  Disabled="_busy"
                  Style="width:100%;">
        @foreach (var role in _roles.Where(r => r.AssignableByCurrentUser))
        {
            <FluentOption Value="@role.Name">@role.DisplayLabel</FluentOption>
        }
    </FluentSelect>

    @if (_roles.Any(r => !r.AssignableByCurrentUser))
    {
        <div class="hc-caption" style="margin-top:0.5rem;">
            Not assignable: @string.Join(", ", _roles.Where(r => !r.AssignableByCurrentUser).Select(r => r.DisplayLabel))
        </div>
    }
}

@if (!string.IsNullOrWhiteSpace(_error))
{
    <FluentMessageBar Intent="MessageIntent.Error" AllowDismiss="false" Style="margin-top:0.75rem;">@_error</FluentMessageBar>
}
<FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" Style="margin-top:1rem;justify-content:flex-end;">
    <FluentButton Appearance="Appearance.Outline" OnClick="CancelAsync" Disabled="_busy">Cancel</FluentButton>
    <FluentButton Appearance="Appearance.Accent" OnClick="SubmitAsync" Disabled="_busy || string.IsNullOrWhiteSpace(_selectedRole)">
        Assign role
    </FluentButton>
</FluentStack>

@code {
    public sealed class Args
    {
        public Guid StaffMemberId { get; init; }
        public Guid TargetUserId { get; init; }
        public string CurrentRole { get; init; } = string.Empty;
        public string DisplayName { get; init; } = string.Empty;
    }

    [Parameter]
    public Args Content { get; set; } = default!;

    [CascadingParameter]
    private FluentDialog Dialog { get; set; } = default!;

    private List<StaffRoleInfoResponse> _roles = [];
    private string? _selectedRole;
    private bool _loading = true;
    private bool _busy;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (!Permissions.Has(WebPermissions.RolesRead))
        {
            _error = "roles.read is required to load assignable roles.";
            _loading = false;
            return;
        }

        try
        {
            _roles = (await StaffApi.ListRolesAsync()).ToList();
            _selectedRole = _roles.FirstOrDefault(r => r.AssignableByCurrentUser && r.Name != Content.CurrentRole)?.Name
                            ?? _roles.FirstOrDefault(r => r.AssignableByCurrentUser)?.Name;
        }
        catch (ApiProblemException ex)
        {
            _error = ex.ToUserMessage();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CancelAsync() => await Dialog.CancelAsync();

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedRole) || !Permissions.Has(WebPermissions.RolesAssign))
        {
            _error = "Role assignment is not available.";
            return;
        }

        if (string.Equals(_selectedRole, Content.CurrentRole, StringComparison.Ordinal))
        {
            await Dialog.CloseAsync(DialogResult.Ok(true));
            return;
        }

        _busy = true;
        _error = null;
        try
        {
            var bypass = Permissions.CurrentUser?.Roles.Contains(WebRoles.PlatformAdmin, StringComparer.Ordinal) == true;
            await StaffApi.AssignRoleAsync(Content.StaffMemberId, _selectedRole, bypass);
            await Dialog.CloseAsync(DialogResult.Ok(true));
        }
        catch (ApiProblemException ex)
        {
            _error = ex.ErrorCode switch
            {
                StaffErrorCodes.SelfElevationDenied => "You cannot elevate your own role.",
                StaffErrorCodes.LastAdminProtected => "The last administrator in scope is protected.",
                StaffErrorCodes.RoleAssignmentDenied => "That role assignment is not permitted.",
                _ => ex.ToUserMessage(),
            };
        }
        finally
        {
            _busy = false;
        }
    }
}
