@namespace HealthCare.Web.Components.Shared

<div class="hc-state">
    <Alert Type="@AlertType.Warning"
           Message="Access denied"
           Description="@(string.IsNullOrWhiteSpace(Message) ? "You do not have permission to view this page." : Message)"
           ShowIcon="true" />
    @ChildContent
</div>

@code {
    [Parameter]
    public string? Message { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}