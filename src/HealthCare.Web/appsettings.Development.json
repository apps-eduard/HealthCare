{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Api": {
    "BaseUrl": "http://localhost:5080/"
  },
  "Bff": {
    "SessionIdleMinutes": 30,
    "AbsoluteSessionHours": 8,
    "TokenStore": "DistributedCache",
    "CookieName": "HealthCare.Staff.Auth",
    "RequireHttps": false,
    "LoginTicketSeconds": 60
  }
}
