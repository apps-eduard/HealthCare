# HealthCare local development environment placeholders
# Copy to .env and fill in values. Do not commit real secrets for production.

POSTGRES_HOST=100.110.26.112
POSTGRES_PORT=5432
POSTGRES_DB=healthcare_db
POSTGRES_USER=appuser
POSTGRES_PASSWORD=123

# Connection string used by the API
ConnectionStrings__DefaultConnection=Host=100.110.26.112;Port=5432;Database=healthcare_db;Username=appuser;Password=123

# Equivalent URL form (for tools that expect DATABASE_URL)
DATABASE_URL=postgresql://appuser:123@100.110.26.112:5432/healthcare_db

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5080

# JWT
Jwt__Issuer=HealthCare
Jwt__Audience=HealthCare
Jwt__SigningKey=DEV_ONLY_HealthCare_Jwt_Signing_Key_Change_Me_32+
Jwt__AccessTokenLifetimeMinutes=15
Jwt__RefreshTokenLifetimeDays=7

# Development admin seeder (Development environment only)
DevelopmentSeed__Admin__Email=admin@healthcare.local
DevelopmentSeed__Admin__Password=ChangeMe_Admin_1!

# Development patient seeder (Development environment only)
DevelopmentSeed__Patient__Email=patient@healthcare.local
DevelopmentSeed__Patient__Password=ChangeMe_Patient_1!
DevelopmentSeed__Patient__StaffEmail=doctor.a@healthcare.local
DevelopmentSeed__Patient__StaffPassword=ChangeMe_DoctorA_1!
DevelopmentSeed__Patient__OtherClinicStaffEmail=doctor.b@healthcare.local
DevelopmentSeed__Patient__OtherClinicStaffPassword=ChangeMe_DoctorB_1!

# Google auth (later Phase 2) — placeholders only
Google__ClientId=
Google__ClientSecret=

# Hangfire worker hosting (defaults: disabled outside Development)
# Storage remains available so the API can enqueue for a local or external worker.
Hangfire__Enabled=false
Hangfire__WorkerCount=2
Hangfire__Queues__0=default
Hangfire__Queues__1=reminders
Hangfire__Queues__2=summaries
Hangfire__ServerName=healthcare-api
Hangfire__ScheduleRecurringJobs=false
Hangfire__ShutdownTimeoutSeconds=30
Hangfire__Dashboard__Enabled=false
Hangfire__Dashboard__Path=/hangfire
